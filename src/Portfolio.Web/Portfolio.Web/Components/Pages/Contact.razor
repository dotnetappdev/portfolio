@page "/contact"
@rendermode InteractiveServer
@inject Portfolio.Web.Services.PortfolioApiService ApiService
@inject Portfolio.Web.Services.SmsSender SmsSender
@inject ISnackbar Snackbar

<PageTitle>Contact | David Buckley</PageTitle>

<div class="page-banner">
    <MudContainer MaxWidth="MaxWidth.ExtraLarge">
        <MudText Typo="Typo.h3" Class="fw-bold mb-1">Get In Touch</MudText>
        <MudText Typo="Typo.subtitle1">I'm always open to discussing new opportunities, interesting projects, or just having a chat about technology.</MudText>
    </MudContainer>
</div>

<div class="page-content">
<MudGrid Justify="Justify.Center">
    <MudItem xs="12" md="8">
        <MudCard Elevation="3">
            <MudCardContent>
                <MudForm @ref="_form" @bind-IsValid="_isValid">
                    <MudTextField @bind-Value="_model.Name" Label="Your Name" Required="true" RequiredError="Name is required"
                                  Variant="Variant.Outlined" Class="mb-4" Adornment="Adornment.Start"
                                  AdornmentIcon="@Icons.Material.Filled.Person" />
                    <MudTextField @bind-Value="_model.Email" Label="Email Address" Required="true"
                                  RequiredError="Email is required"
                                  Validation="@(new EmailAddressAttribute(){ErrorMessage="Please enter a valid email address"})"
                                  Variant="Variant.Outlined" Class="mb-4" Adornment="Adornment.Start"
                                  AdornmentIcon="@Icons.Material.Filled.Email" />
                    <MudTextField @bind-Value="_model.Subject" Label="Subject" Variant="Variant.Outlined"
                                  Class="mb-4" Adornment="Adornment.Start"
                                  AdornmentIcon="@Icons.Material.Filled.Subject" />
                    <MudTextField @bind-Value="_model.Message" Label="Message" Required="true"
                                  RequiredError="Message is required" Lines="6"
                                  Variant="Variant.Outlined" Class="mb-4" />
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large"
                               OnClick="@HandleSubmit" Disabled="@_sending"
                               StartIcon="@Icons.Material.Filled.Send">
                        @(_sending ? "Sending..." : "Send Message")
                    </MudButton>
                </MudForm>
            </MudCardContent>
        </MudCard>
    </MudItem>
</MudGrid>
</div>

@code {
    private MudForm _form = null!;
    private bool _isValid;
    private bool _sending;
    private Portfolio.Shared.Models.ContactMessageDto _model = new();

    private async Task HandleSubmit()
    {
        await _form.Validate();
        if (!_isValid) return;

        _sending = true;
        var success = await ApiService.SendContactMessageAsync(_model);
        _sending = false;

        if (success)
        {
            // Fire-and-forget SMS alert — SmsSender handles all exceptions internally
            _ = SmsSender.SendToAdminAsync(
                    $"New contact from {_model.Name} ({_model.Email}): {_model.Subject}")
                .ContinueWith(t => { /* exceptions are caught and logged inside SmsSender */ },
                    TaskContinuationOptions.OnlyOnFaulted);

            Snackbar.Add("Message sent successfully! I'll get back to you soon.", Severity.Success);
            _model = new Portfolio.Shared.Models.ContactMessageDto();
            await _form.ResetAsync();
        }
        else
        {
            Snackbar.Add("Unable to send message due to a connection issue. Please try again later or contact me directly.", Severity.Warning);
        }
    }
}

