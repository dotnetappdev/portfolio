@page "/admin"
@rendermode InteractiveServer
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore
@using Portfolio.Web.Components.Shared
@inject UserManager<Portfolio.Web.Data.ApplicationUser> UserManager
@inject Portfolio.Web.Data.ApplicationDbContext DbContext
@inject Portfolio.Web.Services.SmsSender SmsSender
@inject Portfolio.Web.Services.BlogService BlogService
@inject Portfolio.Web.Services.CmsPageService CmsPageService
@inject Portfolio.Web.Services.MenuService MenuService
@inject ISnackbar Snackbar

<PageTitle>Admin | David Buckley Portfolio</PageTitle>

<div class="page-banner">
    <MudContainer MaxWidth="MaxWidth.ExtraLarge">
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
            <MudAvatar Color="Color.Primary" Size="Size.Large" Style="background:rgba(196,181,253,0.15);">
                <MudIcon Icon="@Icons.Material.Filled.AdminPanelSettings" Style="font-size:32px;" />
            </MudAvatar>
            <MudStack Spacing="0">
                <MudText Typo="Typo.h4" Class="fw-bold">Admin Dashboard</MudText>
                <MudText Typo="Typo.subtitle1">Manage users, hero stats, SMS settings and portfolio content</MudText>
            </MudStack>
        </MudStack>
    </MudContainer>
</div>

<div class="page-content">

<MudTabs Elevation="2" Rounded="true" ApplyEffectsToContainer="true" Class="mt-4">

    <!-- ── Hero Stats tab ──────────────────────────────── -->
    <MudTabPanel Text="Hero Stats" Icon="@Icons.Material.Filled.Dashboard">
        <MudGrid Class="mt-4">
            <MudItem xs="12" md="5">
                <MudCard Elevation="3">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6">
                                <MudIcon Icon="@(_editingStat == null ? Icons.Material.Filled.AddChart : Icons.Material.Filled.Edit)" Class="mr-2" />
                                @(_editingStat == null ? "Add New Stat Card" : "Edit Stat Card")
                            </MudText>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent>
                        <MudForm @ref="_statForm" @bind-IsValid="_statFormValid">
                            <MudTextField @bind-Value="_statValue" Label="Value (e.g. 30+, AI, £1M+)"
                                          Required="true" RequiredError="Value is required"
                                          Variant="Variant.Outlined" Class="mb-3" />
                            <MudTextField @bind-Value="_statLabel" Label="Label (e.g. Years in .NET)"
                                          Required="true" RequiredError="Label is required"
                                          Variant="Variant.Outlined" Class="mb-3" />
                            <MudSelect @bind-Value="_statColor" Label="Colour" Variant="Variant.Outlined" Class="mb-3">
                                <MudSelectItem Value="@("Primary")">Primary (Violet)</MudSelectItem>
                                <MudSelectItem Value="@("Secondary")">Secondary (Cyan)</MudSelectItem>
                                <MudSelectItem Value="@("Tertiary")">Tertiary (Emerald)</MudSelectItem>
                                <MudSelectItem Value="@("Error")">Error (Red)</MudSelectItem>
                                <MudSelectItem Value="@("Success")">Success (Green)</MudSelectItem>
                                <MudSelectItem Value="@("Warning")">Warning (Amber)</MudSelectItem>
                            </MudSelect>
                            <MudNumericField @bind-Value="_statSortOrder" Label="Sort Order"
                                             Variant="Variant.Outlined" Class="mb-3" Min="1" />
                        </MudForm>
                    </MudCardContent>
                    <MudCardActions>
                        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                                   OnClick="@SaveStat" Disabled="@_savingStat"
                                   StartIcon="@Icons.Material.Filled.Save">
                            @(_savingStat ? "Saving..." : (_editingStat == null ? "Add Stat" : "Save Changes"))
                        </MudButton>
                        @if (_editingStat != null)
                        {
                            <MudButton Variant="Variant.Text" Color="Color.Default"
                                       OnClick="@CancelEditStat" Class="ml-2">
                                Cancel
                            </MudButton>
                        }
                    </MudCardActions>
                </MudCard>
            </MudItem>

            <MudItem xs="12" md="7">
                <MudCard Elevation="3">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6">
                                <MudIcon Icon="@Icons.Material.Filled.ViewModule" Class="mr-2" />
                                Current Stat Cards
                            </MudText>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent>
                        @if (_heroStats == null)
                        {
                            <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
                        }
                        else if (_heroStats.Count == 0)
                        {
                            <MudText Color="Color.Secondary">No stat cards yet. Add one using the form.</MudText>
                        }
                        else
                        {
                            <MudList T="string" Dense="true">
                                @foreach (var stat in _heroStats.OrderBy(s => s.SortOrder))
                                {
                                    <MudListItem>
                                        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                                <MudChip T="string" Color="@GetMudColor(stat.Color)" Size="Size.Small" Variant="Variant.Filled">
                                                    @stat.Value
                                                </MudChip>
                                                <MudStack Spacing="0">
                                                    <MudText Typo="Typo.body2">@stat.Label</MudText>
                                                    <MudText Typo="Typo.caption" Color="Color.Secondary">Order: @stat.SortOrder · @stat.Color</MudText>
                                                </MudStack>
                                            </MudStack>
                                            <MudStack Row="true" Spacing="0">
                                                <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                                               Size="Size.Small" Color="Color.Primary"
                                                               OnClick="@(() => StartEditStat(stat))"
                                                               aria-label="Edit stat card" />
                                                <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                                               Size="Size.Small" Color="Color.Error"
                                                               OnClick="@(() => DeleteStat(stat.Id))"
                                                               aria-label="Delete stat card" />
                                            </MudStack>
                                        </MudStack>
                                    </MudListItem>
                                }
                            </MudList>
                        }
                    </MudCardContent>
                </MudCard>
            </MudItem>
        </MudGrid>
    </MudTabPanel>

    <!-- ── Users tab ──────────────────────────────────── -->
    <MudTabPanel Text="Users" Icon="@Icons.Material.Filled.People">
        <MudGrid Class="mt-4">
            <MudItem xs="12" md="6">
                <MudCard Elevation="3">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6">
                                <MudIcon Icon="@Icons.Material.Filled.PersonAdd" Class="mr-2" />
                                Create New Account
                            </MudText>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent>
                        <MudForm @ref="_form" @bind-IsValid="_isValid">
                            <MudTextField @bind-Value="_newUser.Email" Label="Email Address" Required="true"
                                          RequiredError="Email is required" InputType="InputType.Email"
                                          Variant="Variant.Outlined" Class="mb-3" />
                            <MudTextField @bind-Value="_firstName" Label="First Name"
                                          Variant="Variant.Outlined" Class="mb-3" />
                            <MudTextField @bind-Value="_lastName" Label="Last Name"
                                          Variant="Variant.Outlined" Class="mb-3" />
                            <MudTextField @bind-Value="_newUser.Password" Label="Password" Required="true"
                                          RequiredError="Password is required"
                                          InputType="@(_showPassword ? InputType.Text : InputType.Password)"
                                          Variant="Variant.Outlined" Class="mb-3"
                                          Adornment="Adornment.End"
                                          AdornmentIcon="@(_showPassword ? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility)"
                                          OnAdornmentClick="@(() => _showPassword = !_showPassword)"
                                          HelperText="Min 8 chars, must include uppercase, number and special character" />
                            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                                       OnClick="@HandleCreateUser" Disabled="@_creating"
                                       StartIcon="@Icons.Material.Filled.PersonAdd">
                                @(_creating ? "Creating..." : "Create Account")
                            </MudButton>
                        </MudForm>
                    </MudCardContent>
                </MudCard>
            </MudItem>

            <MudItem xs="12" md="6">
                <MudCard Elevation="3">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6">
                                <MudIcon Icon="@Icons.Material.Filled.People" Class="mr-2" />
                                Existing Users
                            </MudText>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent>
                        @if (_users == null)
                        {
                            <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
                        }
                        else
                        {
                            <MudList T="string">
                                @foreach (var user in _users)
                                {
                                    <MudListItem>
                                        <MudStack Row="true" AlignItems="AlignItems.Center">
                                            <MudAvatar Color="Color.Primary" Size="Size.Small">
                                                <MudIcon Icon="@Icons.Material.Filled.Person" />
                                            </MudAvatar>
                                            <MudStack Spacing="0">
                                                <MudText Typo="Typo.body2">@user.Email</MudText>
                                                @if (!string.IsNullOrEmpty(user.FirstName))
                                                {
                                                    <MudText Typo="Typo.caption" Color="Color.Secondary">@user.FirstName @user.LastName</MudText>
                                                }
                                            </MudStack>
                                        </MudStack>
                                    </MudListItem>
                                }
                            </MudList>
                        }
                    </MudCardContent>
                </MudCard>
            </MudItem>
        </MudGrid>
    </MudTabPanel>
    <!-- ── SMS Settings tab ───────────────────────────────── -->
    <MudTabPanel Text="SMS Settings" Icon="@Icons.Material.Filled.Sms">
        @if (_smsSettings == null)
        {
            <MudProgressCircular Indeterminate="true" Color="Color.Primary" Class="mt-4" />
        }
        else
        {
        <MudGrid Class="mt-4">
            <!-- Provider & global settings -->
            <MudItem xs="12" md="6">
                <MudCard Elevation="3">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6">
                                <MudIcon Icon="@Icons.Material.Filled.SettingsPhone" Class="mr-2" />
                                SMS Provider
                            </MudText>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent>
                        <MudSwitch @bind-Value="_smsSettings.IsEnabled" Label="Enable SMS sending"
                                   Color="Color.Success" Class="mb-3" />

                        <MudSelect @bind-Value="_smsSettings.Provider" Label="Provider"
                                   Variant="Variant.Outlined" Class="mb-3">
                            <MudSelectItem Value="@("None")">None (disabled)</MudSelectItem>
                            <MudSelectItem Value="@("Twilio")">Twilio</MudSelectItem>
                            <MudSelectItem Value="@("ClickSend")">ClickSend</MudSelectItem>
                        </MudSelect>

                        <MudTextField @bind-Value="_smsSettings.AdminReceiverNumber"
                                      Label="Admin receiver number (E.164, e.g. +447911123456)"
                                      Variant="Variant.Outlined" Class="mb-3"
                                      HelperText="Contact-form alerts are sent to this number" />

                        <!-- Twilio credentials -->
                        @if (_smsSettings.Provider == "Twilio")
                        {
                            <MudDivider Class="my-3" />
                            <MudText Typo="Typo.subtitle2" Class="mb-2">Twilio credentials</MudText>
                            <MudTextField @bind-Value="_smsSettings.TwilioAccountSid"
                                          Label="Account SID" Variant="Variant.Outlined" Class="mb-3" />
                            <MudTextField @bind-Value="_smsSettings.TwilioAuthToken"
                                          Label="Auth Token"
                                          InputType="@(_showTwilioToken ? InputType.Text : InputType.Password)"
                                          Variant="Variant.Outlined" Class="mb-3"
                                          Adornment="Adornment.End"
                                          AdornmentIcon="@(_showTwilioToken ? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility)"
                                          OnAdornmentClick="@(() => _showTwilioToken = !_showTwilioToken)" />
                            <MudTextField @bind-Value="_smsSettings.TwilioFromNumber"
                                          Label="From number (E.164 or Messaging Service SID)"
                                          Variant="Variant.Outlined" Class="mb-3" />
                        }

                        <!-- ClickSend credentials -->
                        @if (_smsSettings.Provider == "ClickSend")
                        {
                            <MudDivider Class="my-3" />
                            <MudText Typo="Typo.subtitle2" Class="mb-2">ClickSend credentials</MudText>
                            <MudTextField @bind-Value="_smsSettings.ClickSendUsername"
                                          Label="Username (email)" Variant="Variant.Outlined" Class="mb-3" />
                            <MudTextField @bind-Value="_smsSettings.ClickSendApiKey"
                                          Label="API Key"
                                          InputType="@(_showClickSendKey ? InputType.Text : InputType.Password)"
                                          Variant="Variant.Outlined" Class="mb-3"
                                          Adornment="Adornment.End"
                                          AdornmentIcon="@(_showClickSendKey ? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility)"
                                          OnAdornmentClick="@(() => _showClickSendKey = !_showClickSendKey)" />
                            <MudTextField @bind-Value="_smsSettings.ClickSendFromName"
                                          Label="Sender ID (up to 11 chars or phone number)"
                                          Variant="Variant.Outlined" Class="mb-3" />
                        }
                    </MudCardContent>
                    <MudCardActions>
                        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                                   OnClick="@SaveSmsSettings" Disabled="@_savingSms"
                                   StartIcon="@Icons.Material.Filled.Save">
                            @(_savingSms ? "Saving..." : "Save SMS Settings")
                        </MudButton>
                        <MudButton Variant="Variant.Outlined" Color="Color.Secondary"
                                   OnClick="@SendTestSms" Disabled="@(!_smsSettings.IsEnabled || _sendingTestSms)"
                                   StartIcon="@Icons.Material.Filled.Send" Class="ml-2">
                            @(_sendingTestSms ? "Sending..." : "Send Test SMS")
                        </MudButton>
                    </MudCardActions>
                </MudCard>
            </MudItem>

            <!-- Info card -->
            <MudItem xs="12" md="6">
                <MudCard Elevation="3">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6">
                                <MudIcon Icon="@Icons.Material.Filled.Info" Class="mr-2" />
                                Setup Guide
                            </MudText>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent>
                        <MudText Typo="Typo.subtitle2" Class="mb-1">Twilio</MudText>
                        <MudText Typo="Typo.body2" Class="mb-2">
                            Sign up at <strong>twilio.com</strong>. Copy your <em>Account SID</em> and
                            <em>Auth Token</em> from the Console dashboard. Add a verified phone number as
                            the From number.
                        </MudText>
                        <MudDivider Class="my-2" />
                        <MudText Typo="Typo.subtitle2" Class="mb-1">ClickSend</MudText>
                        <MudText Typo="Typo.body2" Class="mb-2">
                            Sign up at <strong>clicksend.com</strong>. Your login email is the username;
                            generate an API key in <em>Account → API Credentials</em>.
                            The Sender ID can be up to 11 alphanumeric characters.
                        </MudText>
                        <MudDivider Class="my-2" />
                        <MudText Typo="Typo.subtitle2" Class="mb-1">Admin receiver number</MudText>
                        <MudText Typo="Typo.body2">
                            Contact-form submissions send an SMS alert to this number.
                            Must be in international E.164 format, e.g. <code>+447911123456</code>.
                        </MudText>
                    </MudCardContent>
                </MudCard>
            </MudItem>
        </MudGrid>
        }
    </MudTabPanel>

    <!-- ── Blog Posts tab ─────────────────────────────────── -->
    <MudTabPanel Text="Blog Posts" Icon="@Icons.Material.Filled.Article">
        <MudGrid Class="mt-4">

            <!-- Form: create / edit -->
            <MudItem xs="12">
                <MudCard Elevation="3">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6">
                                <MudIcon Icon="@(_editingPost == null ? Icons.Material.Filled.PostAdd : Icons.Material.Filled.Edit)" Class="mr-2" />
                                @(_editingPost == null ? "New Blog Post" : "Edit Blog Post")
                            </MudText>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent>
                        <MudForm @ref="_postForm" @bind-IsValid="_postFormValid">
                            <MudGrid>
                                <MudItem xs="12" md="8">
                                    <MudTextField @bind-Value="_postTitle" Label="Title" Required="true"
                                                  RequiredError="Title is required"
                                                  Variant="Variant.Outlined" Class="mb-3"
                                                  OnBlur="@GenerateSlugFromTitle" />
                                </MudItem>
                                <MudItem xs="12" md="4">
                                    <MudTextField @bind-Value="_postSlug" Label="Slug (URL)" Required="true"
                                                  RequiredError="Slug is required"
                                                  Variant="Variant.Outlined" Class="mb-3"
                                                  HelperText="e.g. my-post-title" />
                                </MudItem>
                                <MudItem xs="12">
                                    <MudTextField @bind-Value="_postSummary" Label="Summary" Required="true"
                                                  RequiredError="Summary is required"
                                                  Variant="Variant.Outlined" Class="mb-3" Lines="2" />
                                </MudItem>
                                <MudItem xs="12" md="4">
                                    <MudTextField @bind-Value="_postCategory" Label="Category" Required="true"
                                                  RequiredError="Category is required"
                                                  Variant="Variant.Outlined" Class="mb-3"
                                                  HelperText="e.g. AI, Security, .NET" />
                                </MudItem>
                                <MudItem xs="12" md="4">
                                    <MudTextField @bind-Value="_postTags" Label="Tags (comma-separated)"
                                                  Variant="Variant.Outlined" Class="mb-3"
                                                  HelperText="e.g. AI, .NET, C#" />
                                </MudItem>
                                <MudItem xs="12" md="2">
                                    <MudNumericField @bind-Value="_postReadMinutes" Label="Read (min)"
                                                     Variant="Variant.Outlined" Class="mb-3" Min="1" />
                                </MudItem>
                                <MudItem xs="12" md="2">
                                    <MudTextField @bind-Value="_postPublishedDateStr" Label="Published Date"
                                                  InputType="InputType.Date"
                                                  Variant="Variant.Outlined" Class="mb-3" />
                                </MudItem>
                                <MudItem xs="12">
                                    <MudText Typo="Typo.subtitle2" Class="mb-2">Post Body</MudText>
                                    <RichTextEditor @ref="_postBodyEditor" Placeholder="Write your post here..." />
                                </MudItem>
                                <MudItem xs="12">
                                    <MudSwitch @bind-Value="_postIsPublished" Label="Published"
                                               Color="Color.Success" />
                                </MudItem>

                                <!-- SEO section -->
                                <MudItem xs="12">
                                    <MudDivider Class="my-2" />
                                    <MudText Typo="Typo.subtitle2" Class="mb-2">
                                        <MudIcon Icon="@Icons.Material.Filled.TravelExplore" Size="Size.Small" Class="mr-1" />
                                        SEO &amp; Social
                                    </MudText>
                                </MudItem>
                                <MudItem xs="12" md="6">
                                    <MudTextField @bind-Value="_postMetaTitle" Label="Meta Title (overrides page title)"
                                                  Variant="Variant.Outlined" Class="mb-3"
                                                  HelperText="Leave blank to use the post title" />
                                </MudItem>
                                <MudItem xs="12" md="6">
                                    <MudTextField @bind-Value="_postOgImage" Label="OG Image URL"
                                                  Variant="Variant.Outlined" Class="mb-3"
                                                  HelperText="Social share image (1200×630 recommended)" />
                                </MudItem>
                                <MudItem xs="12" md="8">
                                    <MudTextField @bind-Value="_postMetaDescription" Label="Meta Description"
                                                  Variant="Variant.Outlined" Lines="2" Class="mb-3"
                                                  HelperText="Shown in search results. Leave blank to use the summary." />
                                </MudItem>
                                <MudItem xs="12" md="4">
                                    <MudTextField @bind-Value="_postCanonicalUrl" Label="Canonical URL"
                                                  Variant="Variant.Outlined" Class="mb-3"
                                                  HelperText="Leave blank to use the current URL" />
                                </MudItem>
                            </MudGrid>
                        </MudForm>
                    </MudCardContent>
                    <MudCardActions>
                        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                                   OnClick="@SavePost" Disabled="@_savingPost"
                                   StartIcon="@Icons.Material.Filled.Save">
                            @(_savingPost ? "Saving..." : (_editingPost == null ? "Create Post" : "Save Changes"))
                        </MudButton>
                        @if (_editingPost != null)
                        {
                            <MudButton Variant="Variant.Text" Color="Color.Default"
                                       OnClick="@CancelEditPost" Class="ml-2">Cancel</MudButton>
                        }
                    </MudCardActions>
                </MudCard>
            </MudItem>

            <!-- Post list -->
            <MudItem xs="12">
                <MudCard Elevation="3">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6">
                                <MudIcon Icon="@Icons.Material.Filled.List" Class="mr-2" />
                                All Blog Posts
                            </MudText>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent>
                        @if (_blogPosts == null)
                        {
                            <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
                        }
                        else if (_blogPosts.Count == 0)
                        {
                            <MudText Color="Color.Secondary">No blog posts yet. Create one using the form above.</MudText>
                        }
                        else
                        {
                            <MudTable Items="@_blogPosts" Hover="true" Dense="true" Breakpoint="Breakpoint.Sm">
                                <HeaderContent>
                                    <MudTh>Title</MudTh>
                                    <MudTh>Category</MudTh>
                                    <MudTh>Published</MudTh>
                                    <MudTh>Status</MudTh>
                                    <MudTh>Actions</MudTh>
                                </HeaderContent>
                                <RowTemplate>
                                    <MudTd DataLabel="Title">
                                        <MudText Typo="Typo.body2" Class="fw-bold">@context.Title</MudText>
                                        <MudText Typo="Typo.caption" Color="Color.Secondary">/@context.Slug</MudText>
                                    </MudTd>
                                    <MudTd DataLabel="Category">
                                        <MudChip T="string" Size="Size.Small" Color="@GetCategoryColor(context.Category)" Variant="Variant.Filled">
                                            @context.Category
                                        </MudChip>
                                    </MudTd>
                                    <MudTd DataLabel="Published">
                                        <MudText Typo="Typo.body2">@context.PublishedDate.ToString("d MMM yyyy")</MudText>
                                    </MudTd>
                                    <MudTd DataLabel="Status">
                                        @if (context.IsPublished)
                                        {
                                            <MudChip T="string" Size="Size.Small" Color="Color.Success" Variant="Variant.Filled">Published</MudChip>
                                        }
                                        else
                                        {
                                            <MudChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Outlined">Draft</MudChip>
                                        }
                                    </MudTd>
                                    <MudTd DataLabel="Actions">
                                        <MudStack Row="true" Spacing="0">
                                            <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                                           Size="Size.Small" Color="Color.Primary"
                                                           OnClick="@(() => StartEditPost(context))"
                                                           aria-label="Edit post" />
                                            <MudIconButton Icon="@(context.IsPublished ? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility)"
                                                           Size="Size.Small" Color="Color.Secondary"
                                                           OnClick="@(() => TogglePublishPost(context))"
                                                           aria-label="@(context.IsPublished ? "Unpublish" : "Publish")" />
                                            <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                                           Size="Size.Small" Color="Color.Error"
                                                           OnClick="@(() => DeletePost(context.Id))"
                                                           aria-label="Delete post" />
                                        </MudStack>
                                    </MudTd>
                                </RowTemplate>
                            </MudTable>
                        }
                    </MudCardContent>
                </MudCard>
            </MudItem>

        </MudGrid>
    </MudTabPanel>

    <!-- ── Pages tab ──────────────────────────────────────── -->
    <MudTabPanel Text="Pages" Icon="@Icons.Material.Filled.Pages">
        <MudGrid Class="mt-4">

            <!-- Form: create / edit -->
            <MudItem xs="12">
                <MudCard Elevation="3">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6">
                                <MudIcon Icon="@(_editingPage == null ? Icons.Material.Filled.Add : Icons.Material.Filled.Edit)" Class="mr-2" />
                                @(_editingPage == null ? "New Page" : "Edit Page")
                            </MudText>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent>
                        <MudForm @ref="_pageForm" @bind-IsValid="_pageFormValid">
                            <MudGrid>
                                <MudItem xs="12" md="8">
                                    <MudTextField @bind-Value="_pageTitle" Label="Page Title" Required="true"
                                                  RequiredError="Title is required"
                                                  Variant="Variant.Outlined" Class="mb-3"
                                                  OnBlur="@GeneratePageSlugFromTitle" />
                                </MudItem>
                                <MudItem xs="12" md="4">
                                    <MudTextField @bind-Value="_pageSlug" Label="Slug (URL path)" Required="true"
                                                  RequiredError="Slug is required"
                                                  Variant="Variant.Outlined" Class="mb-3"
                                                  HelperText="e.g. my-custom-page → /my-custom-page" />
                                </MudItem>
                                <MudItem xs="12">
                                    <MudText Typo="Typo.subtitle2" Class="mb-2">Page Content</MudText>
                                    <RichTextEditor @ref="_pageBodyEditor" Placeholder="Write your page content here..." />
                                </MudItem>
                                <MudItem xs="12" md="4">
                                    <MudTextField @bind-Value="_pagePublishedDateStr" Label="Published Date"
                                                  InputType="InputType.Date"
                                                  Variant="Variant.Outlined" Class="mb-3 mt-3" />
                                </MudItem>
                                <MudItem xs="12" md="8" Class="d-flex align-end">
                                    <MudSwitch @bind-Value="_pageIsPublished" Label="Published"
                                               Color="Color.Success" Class="mb-3 mt-3" />
                                </MudItem>

                                <!-- SEO section -->
                                <MudItem xs="12">
                                    <MudDivider Class="my-2" />
                                    <MudText Typo="Typo.subtitle2" Class="mb-2">
                                        <MudIcon Icon="@Icons.Material.Filled.TravelExplore" Size="Size.Small" Class="mr-1" />
                                        SEO &amp; Social
                                    </MudText>
                                </MudItem>
                                <MudItem xs="12" md="6">
                                    <MudTextField @bind-Value="_pageMetaTitle" Label="Meta Title"
                                                  Variant="Variant.Outlined" Class="mb-3"
                                                  HelperText="Leave blank to use the page title" />
                                </MudItem>
                                <MudItem xs="12" md="6">
                                    <MudTextField @bind-Value="_pageOgImage" Label="OG Image URL"
                                                  Variant="Variant.Outlined" Class="mb-3"
                                                  HelperText="Social share image (1200×630 recommended)" />
                                </MudItem>
                                <MudItem xs="12" md="8">
                                    <MudTextField @bind-Value="_pageMetaDescription" Label="Meta Description"
                                                  Variant="Variant.Outlined" Lines="2" Class="mb-3"
                                                  HelperText="Shown in search results (150–160 characters)" />
                                </MudItem>
                                <MudItem xs="12" md="4">
                                    <MudTextField @bind-Value="_pageCanonicalUrl" Label="Canonical URL"
                                                  Variant="Variant.Outlined" Class="mb-3"
                                                  HelperText="Leave blank to use the current URL" />
                                </MudItem>
                            </MudGrid>
                        </MudForm>
                    </MudCardContent>
                    <MudCardActions>
                        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                                   OnClick="@SavePage" Disabled="@_savingPage"
                                   StartIcon="@Icons.Material.Filled.Save">
                            @(_savingPage ? "Saving..." : (_editingPage == null ? "Create Page" : "Save Changes"))
                        </MudButton>
                        @if (_editingPage != null)
                        {
                            <MudButton Variant="Variant.Text" Color="Color.Default"
                                       OnClick="@CancelEditPage" Class="ml-2">Cancel</MudButton>
                        }
                    </MudCardActions>
                </MudCard>
            </MudItem>

            <!-- Page list -->
            <MudItem xs="12">
                <MudCard Elevation="3">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6">
                                <MudIcon Icon="@Icons.Material.Filled.List" Class="mr-2" />
                                All Pages
                            </MudText>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent>
                        @if (_cmsPages == null)
                        {
                            <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
                        }
                        else if (_cmsPages.Count == 0)
                        {
                            <MudText Color="Color.Secondary">No pages yet. Create one using the form above.</MudText>
                        }
                        else
                        {
                            <MudTable Items="@_cmsPages" Hover="true" Dense="true" Breakpoint="Breakpoint.Sm">
                                <HeaderContent>
                                    <MudTh>Title</MudTh>
                                    <MudTh>URL Slug</MudTh>
                                    <MudTh>Published</MudTh>
                                    <MudTh>Status</MudTh>
                                    <MudTh>Actions</MudTh>
                                </HeaderContent>
                                <RowTemplate>
                                    <MudTd DataLabel="Title">
                                        <MudText Typo="Typo.body2" Class="fw-bold">@context.Title</MudText>
                                    </MudTd>
                                    <MudTd DataLabel="URL Slug">
                                        <MudLink Href="@($"/{context.Slug}")"  Target="_blank" Typo="Typo.caption">
                                            /@context.Slug
                                        </MudLink>
                                    </MudTd>
                                    <MudTd DataLabel="Published">
                                        <MudText Typo="Typo.body2">@context.PublishedDate.ToString("d MMM yyyy")</MudText>
                                    </MudTd>
                                    <MudTd DataLabel="Status">
                                        @if (context.IsPublished)
                                        {
                                            <MudChip T="string" Size="Size.Small" Color="Color.Success" Variant="Variant.Filled">Published</MudChip>
                                        }
                                        else
                                        {
                                            <MudChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Outlined">Draft</MudChip>
                                        }
                                    </MudTd>
                                    <MudTd DataLabel="Actions">
                                        <MudStack Row="true" Spacing="0">
                                            <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                                           Size="Size.Small" Color="Color.Primary"
                                                           OnClick="@(() => StartEditPage(context))"
                                                           aria-label="Edit page" />
                                            <MudIconButton Icon="@(context.IsPublished ? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility)"
                                                           Size="Size.Small" Color="Color.Secondary"
                                                           OnClick="@(() => TogglePublishPage(context))"
                                                           aria-label="@(context.IsPublished ? "Unpublish" : "Publish")" />
                                            <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                                           Size="Size.Small" Color="Color.Error"
                                                           OnClick="@(() => DeletePage(context.Id))"
                                                           aria-label="Delete page" />
                                        </MudStack>
                                    </MudTd>
                                </RowTemplate>
                            </MudTable>
                        }
                    </MudCardContent>
                </MudCard>
            </MudItem>

        </MudGrid>
    </MudTabPanel>

    <!-- ── Menus tab ───────────────────────────────────────── -->
    <MudTabPanel Text="Menus" Icon="@Icons.Material.Filled.Menu">
        <MudGrid Class="mt-4">

            <!-- Add / edit form -->
            <MudItem xs="12" md="5">
                <MudCard Elevation="3">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6">
                                <MudIcon Icon="@(_editingMenuItem == null ? Icons.Material.Filled.AddLink : Icons.Material.Filled.Edit)" Class="mr-2" />
                                @(_editingMenuItem == null ? "Add Menu Item" : "Edit Menu Item")
                            </MudText>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent>
                        <MudForm @ref="_menuForm" @bind-IsValid="_menuFormValid">
                            <MudTextField @bind-Value="_menuLabel" Label="Label" Required="true"
                                          RequiredError="Label is required"
                                          Variant="Variant.Outlined" Class="mb-3" />
                            <MudTextField @bind-Value="_menuUrl" Label="URL" Required="true"
                                          RequiredError="URL is required"
                                          Variant="Variant.Outlined" Class="mb-3"
                                          HelperText="Use /path for internal, https:// for external" />
                            <MudSelect @bind-Value="_menuIcon" Label="Icon" Variant="Variant.Outlined" Class="mb-3">
                                <MudSelectItem Value="@("NavigateNext")">Default arrow</MudSelectItem>
                                <MudSelectItem Value="@("Home")">Home</MudSelectItem>
                                <MudSelectItem Value="@("Apps")">Apps/Projects</MudSelectItem>
                                <MudSelectItem Value="@("Code")">Code/Skills</MudSelectItem>
                                <MudSelectItem Value="@("Person")">Person/About</MudSelectItem>
                                <MudSelectItem Value="@("Article")">Article/Blog</MudSelectItem>
                                <MudSelectItem Value="@("Email")">Email/Contact</MudSelectItem>
                                <MudSelectItem Value="@("Pages")">Page</MudSelectItem>
                                <MudSelectItem Value="@("Description")">Document</MudSelectItem>
                                <MudSelectItem Value="@("Link")">External Link</MudSelectItem>
                            </MudSelect>
                            <MudNumericField @bind-Value="_menuSortOrder" Label="Sort Order"
                                             Variant="Variant.Outlined" Class="mb-3" Min="1" />
                            <MudSwitch @bind-Value="_menuIsVisible" Label="Visible in navigation"
                                       Color="Color.Success" Class="mb-2" />
                            <MudSwitch @bind-Value="_menuOpenInNewTab" Label="Open in new tab"
                                       Color="Color.Info" />
                        </MudForm>
                    </MudCardContent>
                    <MudCardActions>
                        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                                   OnClick="@SaveMenuItem" Disabled="@_savingMenuItem"
                                   StartIcon="@Icons.Material.Filled.Save">
                            @(_savingMenuItem ? "Saving..." : (_editingMenuItem == null ? "Add Item" : "Save Changes"))
                        </MudButton>
                        @if (_editingMenuItem != null)
                        {
                            <MudButton Variant="Variant.Text" Color="Color.Default"
                                       OnClick="@CancelEditMenuItem" Class="ml-2">Cancel</MudButton>
                        }
                    </MudCardActions>
                </MudCard>
            </MudItem>

            <!-- Menu item list -->
            <MudItem xs="12" md="7">
                <MudCard Elevation="3">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6">
                                <MudIcon Icon="@Icons.Material.Filled.List" Class="mr-2" />
                                Navigation Menu
                            </MudText>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent>
                        @if (_menuItems == null)
                        {
                            <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
                        }
                        else if (_menuItems.Count == 0)
                        {
                            <MudText Color="Color.Secondary">No menu items yet.</MudText>
                        }
                        else
                        {
                            <MudList T="string" Dense="true">
                                @foreach (var item in _menuItems.OrderBy(m => m.SortOrder))
                                {
                                    <MudListItem>
                                        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                                <MudText Typo="Typo.caption" Color="Color.Secondary" Style="min-width:24px;">@item.SortOrder</MudText>
                                                <MudStack Spacing="0">
                                                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                                        <MudText Typo="Typo.body2" Class="fw-bold">@item.Label</MudText>
                                                        @if (!item.IsVisible)
                                                        {
                                                            <MudChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Outlined">hidden</MudChip>
                                                        }
                                                        @if (item.OpenInNewTab)
                                                        {
                                                            <MudIcon Icon="@Icons.Material.Filled.OpenInNew" Size="Size.Small" Color="Color.Secondary" />
                                                        }
                                                    </MudStack>
                                                    <MudText Typo="Typo.caption" Color="Color.Secondary">@item.Url</MudText>
                                                </MudStack>
                                            </MudStack>
                                            <MudStack Row="true" Spacing="0">
                                                <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                                               Size="Size.Small" Color="Color.Primary"
                                                               OnClick="@(() => StartEditMenuItem(item))"
                                                               aria-label="Edit menu item" />
                                                <MudIconButton Icon="@(item.IsVisible ? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility)"
                                                               Size="Size.Small" Color="Color.Secondary"
                                                               OnClick="@(() => ToggleMenuItemVisibility(item))"
                                                               aria-label="Toggle visibility" />
                                                <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                                               Size="Size.Small" Color="Color.Error"
                                                               OnClick="@(() => DeleteMenuItem(item.Id))"
                                                               aria-label="Delete menu item" />
                                            </MudStack>
                                        </MudStack>
                                    </MudListItem>
                                }
                            </MudList>
                        }
                    </MudCardContent>
                </MudCard>
            </MudItem>

        </MudGrid>
    </MudTabPanel>

</MudTabs>
</div>

@code {
    // ── Users ───────────────────────────────────────────────
    private MudForm _form = null!;
    private bool _isValid;
    private bool _creating;
    private bool _showPassword;
    private string _firstName = string.Empty;
    private string _lastName = string.Empty;
    private Portfolio.Shared.Models.CreateUserDto _newUser = new();
    private List<Portfolio.Web.Data.ApplicationUser>? _users;

    // ── Hero Stats ──────────────────────────────────────────
    private MudForm _statForm = null!;
    private bool _statFormValid;
    private bool _savingStat;
    private List<Portfolio.Web.Data.HeroStat>? _heroStats;
    private Portfolio.Web.Data.HeroStat? _editingStat;
    private string _statValue = string.Empty;
    private string _statLabel = string.Empty;
    private string _statColor = "Primary";
    private int _statSortOrder = 1;

    protected override async Task OnInitializedAsync()
    {
        _users = await UserManager.Users.ToListAsync();
        _heroStats = await DbContext.HeroStats.OrderBy(s => s.SortOrder).ToListAsync();
        _smsSettings = await DbContext.SmsSettings.FirstOrDefaultAsync()
                       ?? new Portfolio.Web.Data.SmsSettings();
        _blogPosts = await BlogService.GetAllForAdminAsync();
        _cmsPages  = await CmsPageService.GetAllForAdminAsync();
        _menuItems = await MenuService.GetAllForAdminAsync();
    }

    // ── User management ─────────────────────────────────────
    private async Task HandleCreateUser()
    {
        await _form.Validate();
        if (!_isValid) return;

        _creating = true;
        var user = new Portfolio.Web.Data.ApplicationUser
        {
            UserName = _newUser.Email,
            Email = _newUser.Email,
            FirstName = _firstName,
            LastName = _lastName,
            EmailConfirmed = true
        };

        var result = await UserManager.CreateAsync(user, _newUser.Password);
        _creating = false;

        if (result.Succeeded)
        {
            Snackbar.Add($"Account created for {_newUser.Email}", Severity.Success);
            _newUser = new Portfolio.Shared.Models.CreateUserDto();
            _firstName = string.Empty;
            _lastName = string.Empty;
            _users = await UserManager.Users.ToListAsync();
        }
        else
        {
            var errors = string.Join(", ", result.Errors.Select(e => e.Description));
            Snackbar.Add($"Failed to create account: {errors}", Severity.Error);
        }
    }

    // ── Hero Stat management ────────────────────────────────
    private void StartEditStat(Portfolio.Web.Data.HeroStat stat)
    {
        _editingStat = stat;
        _statValue = stat.Value;
        _statLabel = stat.Label;
        _statColor = stat.Color;
        _statSortOrder = stat.SortOrder;
    }

    private void CancelEditStat()
    {
        _editingStat = null;
        _statValue = string.Empty;
        _statLabel = string.Empty;
        _statColor = "Primary";
        _statSortOrder = 1;
    }

    private async Task SaveStat()
    {
        await _statForm.Validate();
        if (!_statFormValid) return;

        _savingStat = true;

        if (_editingStat != null)
        {
            _editingStat.Value = _statValue;
            _editingStat.Label = _statLabel;
            _editingStat.Color = _statColor;
            _editingStat.SortOrder = _statSortOrder;
            DbContext.HeroStats.Update(_editingStat);
        }
        else
        {
            var newStat = new Portfolio.Web.Data.HeroStat
            {
                Value = _statValue,
                Label = _statLabel,
                Color = _statColor,
                SortOrder = _statSortOrder
            };
            DbContext.HeroStats.Add(newStat);
        }

        await DbContext.SaveChangesAsync();
        _heroStats = await DbContext.HeroStats.OrderBy(s => s.SortOrder).ToListAsync();
        _savingStat = false;
        CancelEditStat();
        Snackbar.Add("Stat card saved successfully.", Severity.Success);
    }

    private async Task DeleteStat(int id)
    {
        var stat = await DbContext.HeroStats.FindAsync(id);
        if (stat != null)
        {
            DbContext.HeroStats.Remove(stat);
            await DbContext.SaveChangesAsync();
            _heroStats = await DbContext.HeroStats.OrderBy(s => s.SortOrder).ToListAsync();
            Snackbar.Add("Stat card deleted.", Severity.Info);
        }
    }

    private Color GetMudColor(string colorName) => colorName switch
    {
        "Secondary" => Color.Secondary,
        "Tertiary"  => Color.Tertiary,
        "Error"     => Color.Error,
        "Success"   => Color.Success,
        "Warning"   => Color.Warning,
        _           => Color.Primary
    };

    // ── Blog CMS ────────────────────────────────────────────
    private MudForm _postForm = null!;
    private bool _postFormValid;
    private bool _savingPost;
    private List<Portfolio.Web.Data.BlogPost>? _blogPosts;
    private Portfolio.Web.Data.BlogPost? _editingPost;
    private RichTextEditor _postBodyEditor = null!;

    private string _postTitle          = string.Empty;
    private string _postSlug           = string.Empty;
    private string _postSummary        = string.Empty;
    private string _postCategory       = string.Empty;
    private string _postTags           = string.Empty;
    private int    _postReadMinutes    = 5;
    private bool   _postIsPublished    = true;
    private string _postPublishedDateStr = DateTime.Today.ToString("yyyy-MM-dd");
    // SEO
    private string? _postMetaTitle;
    private string? _postMetaDescription;
    private string? _postOgImage;
    private string? _postCanonicalUrl;

    private void GenerateSlugFromTitle()
    {
        if (_editingPost == null && !string.IsNullOrWhiteSpace(_postTitle) && string.IsNullOrWhiteSpace(_postSlug))
            _postSlug = GenerateSlug(_postTitle);
    }

    private static string GenerateSlug(string title) =>
        System.Text.RegularExpressions.Regex.Replace(title.ToLowerInvariant().Trim(), @"[^a-z0-9]+", "-").Trim('-');

    private async Task StartEditPost(Portfolio.Web.Data.BlogPost post)
    {
        _editingPost          = post;
        _postTitle            = post.Title;
        _postSlug             = post.Slug;
        _postSummary          = post.Summary;
        _postCategory         = post.Category;
        _postTags             = post.Tags;
        _postReadMinutes      = post.ReadMinutes;
        _postIsPublished      = post.IsPublished;
        _postPublishedDateStr = post.PublishedDate.ToString("yyyy-MM-dd");
        _postMetaTitle        = post.MetaTitle;
        _postMetaDescription  = post.MetaDescription;
        _postOgImage          = post.OgImage;
        _postCanonicalUrl     = post.CanonicalUrl;
        // Load body into WYSIWYG after state change re-renders editor
        await InvokeAsync(StateHasChanged);
        await _postBodyEditor.LoadAsync(post.Body);
    }

    private async Task CancelEditPost()
    {
        _editingPost         = null;
        _postTitle           = string.Empty;
        _postSlug            = string.Empty;
        _postSummary         = string.Empty;
        _postCategory        = string.Empty;
        _postTags            = string.Empty;
        _postReadMinutes     = 5;
        _postIsPublished     = true;
        _postPublishedDateStr   = DateTime.Today.ToString("yyyy-MM-dd");
        _postMetaTitle       = null;
        _postMetaDescription = null;
        _postOgImage         = null;
        _postCanonicalUrl    = null;
        await _postBodyEditor.LoadAsync(string.Empty);
    }

    private async Task SavePost()
    {
        await _postForm.Validate();
        if (!_postFormValid) return;

        _savingPost = true;

        var body          = await _postBodyEditor.GetValueAsync();
        var publishedDate = ParseDate(_postPublishedDateStr);

        if (_editingPost != null)
        {
            _editingPost.Title            = _postTitle;
            _editingPost.Slug             = _postSlug;
            _editingPost.Summary          = _postSummary;
            _editingPost.Category         = _postCategory;
            _editingPost.Tags             = _postTags;
            _editingPost.ReadMinutes      = _postReadMinutes;
            _editingPost.Body             = body;
            _editingPost.IsPublished      = _postIsPublished;
            _editingPost.PublishedDate    = publishedDate;
            _editingPost.MetaTitle        = NullIfEmpty(_postMetaTitle);
            _editingPost.MetaDescription  = NullIfEmpty(_postMetaDescription);
            _editingPost.OgImage          = NullIfEmpty(_postOgImage);
            _editingPost.CanonicalUrl     = NullIfEmpty(_postCanonicalUrl);
            await BlogService.UpdateAsync(_editingPost);
            Snackbar.Add("Blog post updated.", Severity.Success);
        }
        else
        {
            var newPost = new Portfolio.Web.Data.BlogPost
            {
                Title            = _postTitle,
                Slug             = _postSlug,
                Summary          = _postSummary,
                Category         = _postCategory,
                Tags             = _postTags,
                ReadMinutes      = _postReadMinutes,
                Body             = body,
                IsPublished      = _postIsPublished,
                PublishedDate    = publishedDate,
                MetaTitle        = NullIfEmpty(_postMetaTitle),
                MetaDescription  = NullIfEmpty(_postMetaDescription),
                OgImage          = NullIfEmpty(_postOgImage),
                CanonicalUrl     = NullIfEmpty(_postCanonicalUrl)
            };
            await BlogService.CreateAsync(newPost);
            Snackbar.Add("Blog post created.", Severity.Success);
        }

        _blogPosts  = await BlogService.GetAllForAdminAsync();
        _savingPost = false;
        await CancelEditPost();
    }

    private async Task TogglePublishPost(Portfolio.Web.Data.BlogPost post)
    {
        post.IsPublished = !post.IsPublished;
        await BlogService.UpdateAsync(post);
        _blogPosts = await BlogService.GetAllForAdminAsync();
        Snackbar.Add(post.IsPublished ? "Post published." : "Post moved to draft.", Severity.Info);
    }

    private async Task DeletePost(int id)
    {
        await BlogService.DeleteAsync(id);
        _blogPosts = await BlogService.GetAllForAdminAsync();
        Snackbar.Add("Blog post deleted.", Severity.Info);
    }

    private Color GetCategoryColor(string category) => category switch
    {
        "AI"       => Color.Tertiary,
        "Security" => Color.Error,
        ".NET"     => Color.Primary,
        _          => Color.Default
    };

    // ── Pages CMS ───────────────────────────────────────────
    private MudForm _pageForm = null!;
