        _pageTitle           = string.Empty;
        _pageSlug            = string.Empty;
        _pageIsPublished     = true;
        _pagePublishedDateStr = DateTime.Today.ToString("yyyy-MM-dd");
        _pageMetaTitle       = null;
        _pageMetaDescription = null;
        _pageOgImage         = null;
        _pageCanonicalUrl    = null;
        await _pageBodyEditor.LoadAsync(string.Empty);
