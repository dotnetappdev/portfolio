    private async Task SavePage()
    {
        await _pageForm.Validate();
        if (!_pageFormValid) return;

        _savingPage = true;

        var body          = await _pageBodyEditor.GetValueAsync();
        var publishedDate = ParseDate(_pagePublishedDateStr);

        if (_editingPage != null)
        {
            _editingPage.Title           = _pageTitle;
            _editingPage.Slug            = _pageSlug;
            _editingPage.Body            = body;
            _editingPage.IsPublished     = _pageIsPublished;
            _editingPage.PublishedDate   = publishedDate;
            _editingPage.MetaTitle       = NullIfEmpty(_pageMetaTitle);
            _editingPage.MetaDescription = NullIfEmpty(_pageMetaDescription);
            _editingPage.OgImage         = NullIfEmpty(_pageOgImage);
            _editingPage.CanonicalUrl    = NullIfEmpty(_pageCanonicalUrl);
            await CmsPageService.UpdateAsync(_editingPage);
            Snackbar.Add("Page updated.", Severity.Success);
        }
        else
        {
            var newPage = new Portfolio.Web.Data.CmsPage
            {
                Title           = _pageTitle,
                Slug            = _pageSlug,
                Body            = body,
                IsPublished     = _pageIsPublished,
                PublishedDate   = publishedDate,
                MetaTitle       = NullIfEmpty(_pageMetaTitle),
                MetaDescription = NullIfEmpty(_pageMetaDescription),
                OgImage         = NullIfEmpty(_pageOgImage),
                CanonicalUrl    = NullIfEmpty(_pageCanonicalUrl)
            };
            await CmsPageService.CreateAsync(newPage);
            Snackbar.Add("Page created.", Severity.Success);
        }

        _cmsPages  = await CmsPageService.GetAllForAdminAsync();
        _savingPage = false;
        await CancelEditPage();
    }

    private async Task TogglePublishPage(Portfolio.Web.Data.CmsPage page)
    {
        page.IsPublished = !page.IsPublished;
        await CmsPageService.UpdateAsync(page);
        _cmsPages = await CmsPageService.GetAllForAdminAsync();
        Snackbar.Add(page.IsPublished ? "Page published." : "Page moved to draft.", Severity.Info);
    }

    private async Task DeletePage(int id)
    {
        await CmsPageService.DeleteAsync(id);
        _cmsPages = await CmsPageService.GetAllForAdminAsync();
        Snackbar.Add("Page deleted.", Severity.Info);
    }

    // ── Menu Management ──────────────────────────────────────
    private MudForm _menuForm = null!;
    private bool _menuFormValid;
    private bool _savingMenuItem;
    private List<Portfolio.Web.Data.MenuItem>? _menuItems;
    private Portfolio.Web.Data.MenuItem? _editingMenuItem;

    private string _menuLabel       = string.Empty;
    private string _menuUrl         = string.Empty;
    private string _menuIcon        = "NavigateNext";
    private int    _menuSortOrder   = 10;
    private bool   _menuIsVisible   = true;
    private bool   _menuOpenInNewTab;

    private void StartEditMenuItem(Portfolio.Web.Data.MenuItem item)
    {
        _editingMenuItem   = item;
        _menuLabel         = item.Label;
        _menuUrl           = item.Url;
        _menuIcon          = item.Icon;
        _menuSortOrder     = item.SortOrder;
        _menuIsVisible     = item.IsVisible;
        _menuOpenInNewTab  = item.OpenInNewTab;
    }

    private void CancelEditMenuItem()
    {
        _editingMenuItem  = null;
        _menuLabel        = string.Empty;
        _menuUrl          = string.Empty;
        _menuIcon         = "NavigateNext";
        _menuSortOrder    = 10;
        _menuIsVisible    = true;
        _menuOpenInNewTab = false;
    }

    private async Task SaveMenuItem()
    {
        await _menuForm.Validate();
        if (!_menuFormValid) return;

        _savingMenuItem = true;

        if (_editingMenuItem != null)
        {
            _editingMenuItem.Label       = _menuLabel;
            _editingMenuItem.Url         = _menuUrl;
            _editingMenuItem.Icon        = _menuIcon;
            _editingMenuItem.SortOrder   = _menuSortOrder;
            _editingMenuItem.IsVisible   = _menuIsVisible;
            _editingMenuItem.OpenInNewTab = _menuOpenInNewTab;
            await MenuService.UpdateAsync(_editingMenuItem);
            Snackbar.Add("Menu item updated.", Severity.Success);
        }
        else
        {
            var item = new Portfolio.Web.Data.MenuItem
            {
                Label       = _menuLabel,
                Url         = _menuUrl,
                Icon        = _menuIcon,
                SortOrder   = _menuSortOrder,
                IsVisible   = _menuIsVisible,
                OpenInNewTab = _menuOpenInNewTab
            };
            await MenuService.CreateAsync(item);
            Snackbar.Add("Menu item added.", Severity.Success);
        }

        _menuItems      = await MenuService.GetAllForAdminAsync();
        _savingMenuItem = false;
        CancelEditMenuItem();
    }

    private async Task ToggleMenuItemVisibility(Portfolio.Web.Data.MenuItem item)
    {
        item.IsVisible = !item.IsVisible;
        await MenuService.UpdateAsync(item);
        _menuItems = await MenuService.GetAllForAdminAsync();
        Snackbar.Add(item.IsVisible ? "Menu item shown." : "Menu item hidden.", Severity.Info);
    }

    private async Task DeleteMenuItem(int id)
    {
        await MenuService.DeleteAsync(id);
        _menuItems = await MenuService.GetAllForAdminAsync();
        Snackbar.Add("Menu item deleted.", Severity.Info);
    }

    private static string? NullIfEmpty(string? value) =>
        string.IsNullOrWhiteSpace(value) ? null : value;

    private static DateTime ParseDate(string dateStr) =>
        DateTime.TryParse(dateStr, out var dt)
            ? DateTime.SpecifyKind(dt, DateTimeKind.Utc)
            : DateTime.UtcNow;

    // ── SMS Settings ────────────────────────────────────────
    private Portfolio.Web.Data.SmsSettings? _smsSettings;
    private bool _savingSms;
    private bool _sendingTestSms;
    private bool _showTwilioToken;
    private bool _showClickSendKey;

    private async Task SaveSmsSettings()
    {
        if (_smsSettings == null) return;
        _savingSms = true;

        if (_smsSettings.Id == 0)
            DbContext.SmsSettings.Add(_smsSettings);
        else
            DbContext.SmsSettings.Update(_smsSettings);

        await DbContext.SaveChangesAsync();
        _savingSms = false;
        Snackbar.Add("SMS settings saved.", Severity.Success);
    }

    private async Task SendTestSms()
    {
        if (_smsSettings == null || string.IsNullOrWhiteSpace(_smsSettings.AdminReceiverNumber))
        {
            Snackbar.Add("Set an admin receiver number before sending a test.", Severity.Warning);
            return;
        }

        _sendingTestSms = true;
        // Persist first so SmsSender reads the latest values
        await SaveSmsSettings();

        var result = await SmsSender.SendToAdminAsync("Test SMS from Portfolio admin — everything is working!");
        _sendingTestSms = false;

        if (result.Succeeded)
            Snackbar.Add($"Test SMS sent (id: {result.MessageId ?? "n/a"}).", Severity.Success);
        else
            Snackbar.Add($"Test SMS failed: {result.Error}", Severity.Error);
    }
}
