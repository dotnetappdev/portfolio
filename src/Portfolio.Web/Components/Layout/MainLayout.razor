@inherits LayoutComponentBase
@inject NavigationManager Navigation
@inject Portfolio.Web.Services.MenuService MenuService
@inject Portfolio.Web.Services.PortfolioApiService ApiService
@inject IDialogService DialogService
@inject ILogger<MainLayout> Logger

<a href="#main-content" class="skip-link">Skip to main content</a>

<MudThemeProvider @ref="_mudThemeProvider" @bind-IsDarkMode="_isDarkMode" Theme="_theme" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="1" Color="Color.Primary">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start" OnClick="@ToggleDrawer" />
        <MudText Typo="Typo.h6" Class="ml-2 cursor-pointer" @onclick='() => Navigation.NavigateTo("/")'>
            David Buckley
        </MudText>
        <MudSpacer />
        <MudHidden Breakpoint="Breakpoint.SmAndDown">
            @foreach (var item in _menuItems)
            {
                @if (item.OpenInNewTab)
                {
                    <MudButton Color="Color.Inherit" Href="@item.Url" Target="_blank"
                               aria-current="@(IsCurrentPage(item.Url) ? "page" : null)">@item.Label</MudButton>
                }
                else
                {
                    <MudButton Color="Color.Inherit" Href="@item.Url"
                               aria-current="@(IsCurrentPage(item.Url) ? "page" : null)">@item.Label</MudButton>
                }
            }
        </MudHidden>
        <MudTooltip Text="@(_isDarkMode ? "Switch to light mode" : "Switch to dark mode")" Placement="Placement.Bottom">
            <MudIconButton Icon="@(_isDarkMode ? Icons.Material.Filled.LightMode : Icons.Material.Filled.DarkMode)"
                           Color="Color.Inherit" OnClick="@ToggleDarkMode"
                           aria-label="@(_isDarkMode ? "Switch to light mode" : "Switch to dark mode")" />
        </MudTooltip>
        <AuthorizeView>
            <Authorized>
                <MudButton Color="Color.Inherit" Href="/admin">Admin</MudButton>
                <MudMenu Icon="@Icons.Material.Filled.AccountCircle" Color="Color.Inherit"
                         AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight"
                         aria-label="User menu">
                    <MudMenuItem Icon="@Icons.Material.Filled.Tune" OnClick="@OpenSettingsDialog">Quick Settings</MudMenuItem>
                    <MudMenuItem Icon="@Icons.Material.Filled.AdminPanelSettings" Href="/admin">Admin Panel</MudMenuItem>
                    <MudMenuItem Icon="@Icons.Material.Filled.Info" OnClick="@OpenAboutDialog">About</MudMenuItem>
                    <MudDivider />
                    <MudMenuItem Icon="@Icons.Material.Filled.Logout" Href="/logout">Logout</MudMenuItem>
                </MudMenu>
            </Authorized>
            <NotAuthorized>
                <MudButton Color="Color.Inherit" Href="/register">Register</MudButton>
                <MudButton Color="Color.Inherit" Href="/login">Login</MudButton>
            </NotAuthorized>
        </AuthorizeView>
    </MudAppBar>

    <MudDrawer @bind-Open="_drawerOpen" ClipMode="DrawerClipMode.Always" Elevation="2">
        <MudNavMenu>
            @foreach (var item in _menuItems)
            {
                <MudNavLink Href="@item.Url"
                            Icon="@GetMudIcon(item.Icon)"
                            Target="@(item.OpenInNewTab ? "_blank" : "_self")">
                    @item.Label
                </MudNavLink>
            }
            <AuthorizeView>
                <Authorized>
                    <MudNavLink Href="/admin" Icon="@Icons.Material.Filled.AdminPanelSettings">Admin</MudNavLink>
                    <MudNavLink Href="/logout" Icon="@Icons.Material.Filled.Logout">Logout</MudNavLink>
                </Authorized>
            </AuthorizeView>
        </MudNavMenu>
    </MudDrawer>

    <MudMainContent>
        <main id="main-content" tabindex="-1">
            @Body
        </main>
    </MudMainContent>

    <AccessibilityToolbar />
</MudLayout>

<MudScrollToTop>
    <MudFab Color="Color.Tertiary" StartIcon="@Icons.Material.Filled.ArrowUpward" Size="Size.Small" />
</MudScrollToTop>

@code {
    private bool _isDarkMode = true;
    private bool _drawerOpen = false;
    private MudThemeProvider _mudThemeProvider = null!;
    private List<Portfolio.Shared.Models.MenuItemDto> _menuItems = [];
    private MudTheme _theme = BuildTheme(null, null, null);

    protected override async Task OnInitializedAsync()
    {
        // For static SSR pre-rendering: load synchronously so the nav is populated on first render.
        // For interactive circuits (e.g. admin page): defer to OnAfterRenderAsync to avoid a
        // race condition where the async yield interferes with MudPopoverProvider registration.
        if (!RendererInfo.IsInteractive)
            _menuItems = await MenuService.GetVisibleItemsAsync();
    }

    private static string GetMudIcon(string iconName) => iconName switch
    {
        "Home"               => Icons.Material.Filled.Home,
        "Apps"               => Icons.Material.Filled.Apps,
        "Code"               => Icons.Material.Filled.Code,
        "Person"             => Icons.Material.Filled.Person,
        "Article"            => Icons.Material.Filled.Article,
        "Email"              => Icons.Material.Filled.Email,
        "AdminPanelSettings" => Icons.Material.Filled.AdminPanelSettings,
        "Link"               => Icons.Material.Filled.Link,
        "Pages"              => Icons.Material.Filled.Pages,
        "Description"        => Icons.Material.Filled.Description,
        _                    => Icons.Material.Filled.NavigateNext,
    };

    private static MudTheme BuildTheme(string? primary, string? secondary, string? tertiary)
    {
        // Default BookIt brand colours
        var lightPrimary  = primary   ?? "#5B5BD6";
        var lightSecondary = secondary ?? "#0EA5E9";
        var lightTertiary  = tertiary  ?? "#10B981";
        // Dark palette uses lighter tints for readability; keep them proportionally brighter.
        var darkPrimary  = primary   ?? "#C4B5FD";
        var darkSecondary = secondary ?? "#67E8F9";
        var darkTertiary  = tertiary  ?? "#6EE7B7";

        return new MudTheme
        {
            PaletteLight = new PaletteLight
            {
                Primary          = lightPrimary,
                Secondary        = lightSecondary,
                Tertiary         = lightTertiary,
                AppbarBackground = lightPrimary,
                Background       = "#F5F5FF",
                Surface          = "#FFFFFF",
                DrawerBackground = "#F0F0FA",
                DrawerText       = "#1A1A3E",
                TextPrimary      = "#11111A",
                TextSecondary    = "#6B6B8C",
                ActionDefault    = "#9595A8",
                Divider          = "#E4E4F0",
                LinesDefault     = "#E4E4F0",
                LinesInputs      = "#C4C4D8",
                TableLines       = "#E4E4F0",
                OverlayLight     = "rgba(255,255,255,0.75)",
            },
            PaletteDark = new PaletteDark
            {
                Primary          = darkPrimary,
                Secondary        = darkSecondary,
                Tertiary         = darkTertiary,
                AppbarBackground = "#0F0A1E",
                Background       = "#0F0A1E",
                Surface          = "#1E1335",
                DrawerBackground = "#180E2C",
                DrawerText       = "#EDE9FE",
                TextPrimary      = "#F5F0FF",
                TextSecondary    = "#A78BFA",
                ActionDefault    = "#7C3AED",
                Divider          = "#3B2A6E",
                LinesDefault     = "#3B2A6E",
                LinesInputs      = "#4C3A82",
                TableLines       = "#3B2A6E",
                OverlayDark      = "rgba(0,0,0,0.75)",
            }
        };
    }

    private readonly MudTheme _defaultTheme = BuildTheme(null, null, null);

    /// <summary>Notifies MainLayout that theme colors have changed so the UI can refresh.</summary>
    public void RefreshTheme(string? primary, string? secondary, string? tertiary)
    {
        _theme = BuildTheme(primary, secondary, tertiary);
        StateHasChanged();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // Load DB menu items for interactive circuits without risking a race with
            // MudPopoverProvider (which is why we do NOT do this in OnInitializedAsync).
            if (RendererInfo.IsInteractive)
            {
                _menuItems = await MenuService.GetVisibleItemsAsync();
            }

            // Load custom theme colors from DB.
            try
            {
                var pub = await ApiService.GetPublicAppSettingsAsync();
                if (pub is not null && (!string.IsNullOrWhiteSpace(pub.PrimaryColor) ||
                                        !string.IsNullOrWhiteSpace(pub.SecondaryColor) ||
                                        !string.IsNullOrWhiteSpace(pub.TertiaryColor)))
                {
                    _theme = BuildTheme(pub.PrimaryColor, pub.SecondaryColor, pub.TertiaryColor);
                }
            }
            catch (Exception ex) { Logger.LogWarning(ex, "Failed to load theme colors from public settings"); }

            StateHasChanged();
        }
    }

    private void ToggleDarkMode() => _isDarkMode = !_isDarkMode;
    private void ToggleDrawer() => _drawerOpen = !_drawerOpen;

    private async Task OpenAboutDialog()
    {
        var parameters = new DialogParameters<AboutDialog>();
        await DialogService.ShowAsync<AboutDialog>("About This Portfolio", parameters,
            new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Small, FullWidth = true });
    }

    private async Task OpenSettingsDialog()
    {
        await DialogService.ShowAsync<SettingsDialog>("Quick Settings",
            new DialogParameters(),
            new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Medium, FullWidth = true });
    }

    /// <summary>Returns true when the given href matches the current page path.</summary>
    private bool IsCurrentPage(string? href)
    {
        if (string.IsNullOrEmpty(href)) return false;
        // Cheap path extraction using string ops — avoids allocating a Uri object per call.
        var raw   = Navigation.Uri;
        var auth  = raw.IndexOf("://", StringComparison.Ordinal);
        var start = auth >= 0 ? raw.IndexOf('/', auth + 3) : 0;
        if (start < 0) start = 0;
        var end     = raw.IndexOfAny(['?', '#'], start);
        var rawPath = end >= 0 ? raw[start..end] : raw[start..];
        var current = rawPath.TrimEnd('/').ToLowerInvariant();
        var path    = "/" + href.TrimStart('/').TrimEnd('/').ToLowerInvariant();
        if (path == "/") return current is "" or "/";
        // Append "/" so "/about" never matches "/about-me" — full segment match only.
        return current == path || current.StartsWith(path + "/");
    }
}
