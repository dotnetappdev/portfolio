@rendermode InteractiveServer
@inject IJSRuntime JS
@implements IAsyncDisposable

@* Invisible aria-live region so screen readers pick up state changes *@
<div id="a11y-announce" aria-live="polite" aria-atomic="true" class="sr-only"></div>

<div class="a11y-toolbar" role="toolbar" aria-label="Accessibility tools">
    <MudTooltip Text="@(_isSpeaking ? "Stop reading aloud" : "Read page aloud")" Placement="Placement.Left">
        <MudFab Color="@(_isSpeaking ? Color.Error : Color.Secondary)"
                StartIcon="@(_isSpeaking ? Icons.Material.Filled.StopCircle : Icons.Material.Filled.RecordVoiceOver)"
                Size="Size.Small"
                OnClick="ToggleReadAloud"
                aria-label="@(_isSpeaking ? "Stop reading page aloud" : "Read page aloud")"
                aria-pressed="@_isSpeaking.ToString().ToLower()"
                Class="mb-2 d-block" />
    </MudTooltip>

    <MudTooltip Text="Increase text size" Placement="Placement.Left">
        <MudFab Color="Color.Default"
                StartIcon="@Icons.Material.Filled.TextIncrease"
                Size="Size.Small"
                OnClick="IncreaseFontSize"
                aria-label="Increase text size"
                aria-pressed="@_fontScaleActiveStr"
                Class="mb-2 d-block" />
    </MudTooltip>

    <MudTooltip Text="Reset text size" Placement="Placement.Left">
        <MudFab Color="Color.Default"
                StartIcon="@Icons.Material.Filled.FormatSize"
                Size="Size.Small"
                OnClick="ResetFontSize"
                aria-label="Reset text size to default"
                aria-pressed="@_fontScaleDefaultStr"
                Class="d-block" />
    </MudTooltip>
</div>

@code {
    private bool _isSpeaking;
    private string _fontScale = "default";
    private DotNetObjectReference<AccessibilityToolbar>? _dotNetRef;

    // Pre-computed aria-pressed strings — updated whenever _fontScale changes.
    private string _fontScaleActiveStr = "false";  // true when any enlarged scale is active
    private string _fontScaleDefaultStr = "true";  // true when at default (reset is the "on" state)

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                _dotNetRef = DotNetObjectReference.Create(this);
                await JS.InvokeVoidAsync("registerA11yCallback", _dotNetRef);

                _fontScale = await JS.InvokeAsync<string>("getSavedFontScale");
                UpdateFontScaleStrings();
                await JS.InvokeVoidAsync("setFontScale", _fontScale);
            }
            catch (Exception ex)
            {
                // JS interop is not available during pre-render; safe to ignore
                Console.WriteLine($"[AccessibilityToolbar] Could not restore font scale: {ex.Message}");
            }
        }
    }

    /// <summary>Called from JS when speech synthesis ends naturally or errors out.</summary>
    [JSInvokable]
    public void OnSpeechEnded()
    {
        _isSpeaking = false;
        InvokeAsync(StateHasChanged);
    }

    private async Task ToggleReadAloud()
    {
        try
        {
            if (_isSpeaking)
            {
                await JS.InvokeVoidAsync("stopReadingAloud");
                _isSpeaking = false;
                await JS.InvokeVoidAsync("announceToScreenReader", "Stopped reading.");
            }
            else
            {
                var started = await JS.InvokeAsync<bool>("readPageAloud", "main-content");
                _isSpeaking = started;
                if (started)
                    await JS.InvokeVoidAsync("announceToScreenReader", "Reading page aloud. Press the stop button to stop.");
                else
                    await JS.InvokeVoidAsync("announceToScreenReader", "Speech synthesis is not supported in this browser.");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[AccessibilityToolbar] Read aloud error: {ex.Message}");
        }
    }

    private async Task IncreaseFontSize()
    {
        _fontScale = _fontScale switch
        {
            "default" => "large",
            "large"   => "xlarge",
            _         => "xlarge"
        };
        UpdateFontScaleStrings();
        try
        {
            await JS.InvokeVoidAsync("setFontScale", _fontScale);
            var label = _fontScale == "large" ? "Text size increased to large." : "Text size increased to extra large.";
            await JS.InvokeVoidAsync("announceToScreenReader", label);
        }
        catch (Exception ex) { Console.WriteLine($"[AccessibilityToolbar] Font scale error: {ex.Message}"); }
    }

    private async Task ResetFontSize()
    {
        _fontScale = "default";
        UpdateFontScaleStrings();
        try
        {
            await JS.InvokeVoidAsync("setFontScale", _fontScale);
            await JS.InvokeVoidAsync("announceToScreenReader", "Text size reset to default.");
        }
        catch (Exception ex) { Console.WriteLine($"[AccessibilityToolbar] Font scale error: {ex.Message}"); }
    }

    private void UpdateFontScaleStrings()
    {
        _fontScaleActiveStr  = _fontScale != "default" ? "true" : "false";
        _fontScaleDefaultStr = _fontScale == "default" ? "true" : "false";
    }

    public async ValueTask DisposeAsync()
    {
        try { await JS.InvokeVoidAsync("registerA11yCallback", (object?)null); } catch { /* ignore */ }
        _dotNetRef?.Dispose();
    }
}
