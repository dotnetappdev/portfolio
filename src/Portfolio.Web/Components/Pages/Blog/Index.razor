@page "/blog"
@rendermode InteractiveServer
@using Portfolio.Web.Data
@inject Portfolio.Web.Services.BlogService BlogService

<PageTitle>Blog | David Buckley</PageTitle>

<div class="page-banner">
    <MudContainer MaxWidth="MaxWidth.ExtraLarge">
        <MudText Typo="Typo.h3" Class="fw-bold mb-1">Blog</MudText>
        <MudText Typo="Typo.subtitle1">Thoughts on AI development, application security, and .NET from someone who has been building software since 1994.</MudText>
    </MudContainer>
</div>

<div class="page-content">
@if (_posts == null)
{
    <MudProgressCircular Indeterminate="true" Color="Color.Primary" Class="mt-4" />
}
else
{
<MudGrid>
    @foreach (var post in _posts)
    {
        <MudItem xs="12">
            <MudCard Elevation="2" Class="mb-2">
                @if (!string.IsNullOrWhiteSpace(post.FeaturedImage))
                {
                    <MudCardMedia Image="@post.FeaturedImage" Height="200" />
                }
                <MudCardContent>
                    <MudGrid>
                        <MudItem xs="12" md="9">
                            <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-2" Spacing="1">
                                <MudChip T="string" Size="Size.Small" Color="@GetCategoryColor(post.Category)"
                                         Variant="Variant.Filled">@post.Category</MudChip>
                                @foreach (var tag in post.TagList.Take(3))
                                {
                                    <MudChip T="string" Size="Size.Small" Color="Color.Default"
                                             Variant="Variant.Outlined">@tag</MudChip>
                                }
                            </MudStack>
                            <MudLink Href="@($"/blog/{post.Slug}")" Typo="Typo.h5" Color="Color.Default"
                                     Class="fw-bold mb-2" Style="text-decoration:none;">
                                @post.Title
                            </MudLink>
                            <MudText Typo="Typo.body1" Color="Color.Secondary" Class="mt-2 mb-3">
                                @post.Summary
                            </MudText>
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                    <MudIcon Icon="@Icons.Material.Filled.CalendarToday" Size="Size.Small" Color="Color.Secondary" />
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">@post.PublishedDate.ToString("d MMMM yyyy")</MudText>
                                </MudStack>
                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                    <MudIcon Icon="@Icons.Material.Filled.AccessTime" Size="Size.Small" Color="Color.Secondary" />
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">@post.ReadMinutes min read</MudText>
                                </MudStack>
                            </MudStack>
                        </MudItem>
                        <MudItem xs="12" md="3" Class="d-flex align-end justify-end">
                            <MudButton Variant="Variant.Outlined" Color="Color.Primary"
                                       Href="@($"/blog/{post.Slug}")"
                                       EndIcon="@Icons.Material.Filled.ArrowForward">
                                Read Post
                            </MudButton>
                        </MudItem>
                    </MudGrid>
                </MudCardContent>
            </MudCard>
        </MudItem>
    }
</MudGrid>

@if (_totalPages > 1)
{
    <MudStack Row="true" Justify="Justify.Center" Class="mt-4">
        <MudPagination Count="@_totalPages" Selected="@_currentPage"
                       SelectedChanged="@OnPageChanged"
                       Color="Color.Primary" />
    </MudStack>
}
}
</div>

@code {
    private const int PageSize = 5;

    private IReadOnlyList<BlogPost>? _posts;
    private int _currentPage = 1;
    private int _totalPages = 1;

    protected override async Task OnInitializedAsync()
    {
        await LoadPageAsync(_currentPage);
    }

    private async Task OnPageChanged(int page)
    {
        _currentPage = page;
        await LoadPageAsync(page);
    }

    private async Task LoadPageAsync(int page)
    {
        var (posts, total) = await BlogService.GetPagedPostsAsync(page, PageSize);
        _posts = posts;
        _totalPages = (int)Math.Ceiling(total / (double)PageSize);
    }

    private Color GetCategoryColor(string category) => category switch
    {
        "AI" => Color.Tertiary,
        "Security" => Color.Error,
        ".NET" => Color.Primary,
        "Projects" => Color.Success,
        _ => Color.Default
    };
}

