@page "/not-found"

<PageTitle>Page Not Found</PageTitle>

<MudGrid Justify="Justify.Center" Class="mt-12">
    <MudItem xs="12" md="6" Class="text-center">
        <MudText Typo="Typo.h1" Color="Color.Primary" Class="fw-bold">404</MudText>
        <MudText Typo="Typo.h4" Class="mb-2">Page Not Found</MudText>
        <MudText Typo="Typo.body1" Color="Color.Secondary" Class="mb-6">
            The page you're looking for doesn't exist.
        </MudText>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" Href="/">Return Home</MudButton>
    </MudItem>
</MudGrid>