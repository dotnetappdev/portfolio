@page "/"
@rendermode InteractiveServer
@inject Portfolio.Web.Services.PortfolioApiService ApiService

<PageTitle>David Buckley | AI & Security Engineer</PageTitle>

<MudPaper Class="hero-section" Elevation="0" Square="true">
    <MudContainer MaxWidth="MaxWidth.ExtraLarge">
        <MudGrid Spacing="6">
            <!-- Left column: text & CTAs -->
            <MudItem xs="12" md="6" Class="d-flex flex-column justify-center">
                <MudChip T="string" Color="Color.Primary" Variant="Variant.Outlined" Size="Size.Small"
                         Icon="@Icons.Material.Filled.Rocket" Class="mb-4 hero-badge">
                    SENIOR SOFTWARE ENGINEER
                </MudChip>
                <MudText Typo="Typo.h2" Class="fw-bold hero-title mb-3">
                    Your software,<br />
                    <span class="hero-accent">always delivered.</span>
                </MudText>
                <MudText Typo="Typo.body1" Class="hero-subtitle mb-5">
                    The all-in-one .NET engineer for AI-driven apps, hardened APIs, and enterprise-grade
                    Blazor solutions. 30 years shipping production software, built to last and secured from day one.
                </MudText>
                <MudStack Row="true" Spacing="2" Class="mb-5" Wrap="Wrap.Wrap">
                    <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Large"
                               Href="/projects" StartIcon="@Icons.Material.Filled.Apps"
                               Class="hero-outline-btn">
                        View My Work
                    </MudButton>
                    <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Large"
                               Href="/contact" StartIcon="@Icons.Material.Filled.Email"
                               Class="hero-outline-btn">
                        Get In Touch
                    </MudButton>
                </MudStack>
                <MudStack Row="true" Spacing="3" Wrap="Wrap.Wrap">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                        <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Size="Size.Small" />
                        <MudText Typo="Typo.body2" Class="hero-trust-text">30-year track record</MudText>
                    </MudStack>
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                        <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Size="Size.Small" />
                        <MudText Typo="Typo.body2" Class="hero-trust-text">AI & Security specialist</MudText>
                    </MudStack>
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                        <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Size="Size.Small" />
                        <MudText Typo="Typo.body2" Class="hero-trust-text">Open to new roles</MudText>
                    </MudStack>
                </MudStack>
            </MudItem>

            <!-- Right column: portfolio stats dashboard -->
            <MudItem xs="12" md="6">
                <MudPaper Class="hero-dashboard" Elevation="8">
                    <div class="hero-dashboard-header">
                        <div class="hero-dashboard-dots">
                            <span class="dot dot-red"></span>
                            <span class="dot dot-amber"></span>
                            <span class="dot dot-green"></span>
                        </div>
                        <MudText Typo="Typo.caption" Class="hero-dashboard-title">Portfolio at a Glance</MudText>
                    </div>
                    <div class="hero-dashboard-body">
                        <MudGrid Spacing="3">
                            @if (_heroStats != null)
                            {
                                @foreach (var stat in _heroStats)
                                {
                                    <MudItem xs="6">
                                        <MudPaper Class="hero-stat-card" Elevation="0">
                                            <MudText Typo="Typo.h4" Class="@($"hero-stat-value hero-stat-{stat.Color.ToLower()}")">@stat.Value</MudText>
                                            <MudText Typo="Typo.caption" Class="hero-stat-label">@stat.Label</MudText>
                                        </MudPaper>
                                    </MudItem>
                                }
                            }
                        </MudGrid>
                        <MudDivider Class="my-3 hero-divider" />
                        <MudText Typo="Typo.caption" Class="hero-dashboard-subtitle mb-2">CORE EXPERTISE</MudText>
                        <MudStack Row="true" Spacing="1" Wrap="Wrap.Wrap">
                            <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Outlined">Semantic Kernel</MudChip>
                            <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Outlined">Azure OpenAI</MudChip>
                            <MudChip T="string" Size="Size.Small" Color="Color.Error" Variant="Variant.Outlined">OWASP</MudChip>
                            <MudChip T="string" Size="Size.Small" Color="Color.Success" Variant="Variant.Outlined">.NET 10</MudChip>
                            <MudChip T="string" Size="Size.Small" Color="Color.Secondary" Variant="Variant.Outlined">Blazor</MudChip>
                        </MudStack>
                    </div>
                </MudPaper>
            </MudItem>
        </MudGrid>
    </MudContainer>
</MudPaper>

<div class="page-content">

<MudText Typo="Typo.h4" Class="mb-2 fw-bold">Featured Projects</MudText>
<MudDivider Class="mb-6" />

@if (_projects == null)
{
    <MudGrid>
        @for (int i = 0; i < 4; i++)
        {
            <MudItem xs="12" sm="6" md="3">
                <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="200px" />
            </MudItem>
        }
    </MudGrid>
}
else
{
    <MudGrid>
        @foreach (var project in _projects.Take(4))
        {
            <MudItem xs="12" sm="6" md="3">
                <MudCard Elevation="3" Style="height:100%;">
                    <MudCardHeader Class="project-card-header">
                        <CardHeaderAvatar>
                            <MudAvatar Style="background:rgba(255,255,255,0.15);color:white;">
                                <MudIcon Icon="@GetProjectIcon(project.Category)" />
                            </MudAvatar>
                        </CardHeaderAvatar>
                        <CardHeaderContent>
                            @if (!string.IsNullOrWhiteSpace(project.Slug))
                            {
                                <MudLink Href="@($"/projects/{project.Slug}")" Typo="Typo.h6" Class="fw-bold" Style="text-decoration:none;color:white;">@project.Title</MudLink>
                            }
                            else
                            {
                                <MudText Typo="Typo.h6" Style="color:white;">@project.Title</MudText>
                            }
                            <MudText Typo="Typo.body2" Style="color:rgba(255,255,255,0.75);">@project.Category</MudText>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent>
                        <MudText Typo="Typo.body2">@project.ShortDescription</MudText>
                        <MudChipSet T="string" Class="mt-2">
                            @foreach (var tech in project.TechStack.Split(',').Take(3))
                            {
                                <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Outlined">@tech.Trim()</MudChip>
                            }
                        </MudChipSet>
                    </MudCardContent>
                    <MudCardActions>
                        @if (!string.IsNullOrWhiteSpace(project.Slug))
                        {
                            <MudButton Variant="Variant.Outlined" Color="Color.Primary" StartIcon="@Icons.Material.Filled.OpenInNew" Href="@($"/projects/{project.Slug}")" Size="Size.Small" Class="mr-2 mb-2">
                                Details
                            </MudButton>
                        }
                        @if (!string.IsNullOrWhiteSpace(project.BlogSlug))
                        {
                            <MudButton Variant="Variant.Outlined" Color="Color.Secondary" StartIcon="@Icons.Material.Filled.Article" Href="@($"/blog/{project.BlogSlug}")" Size="Size.Small" Class="mr-2 mb-2">
                                Story
                            </MudButton>
                        }
                        @if (project.GitHubUrl != null)
                        {
                            <MudButton Variant="Variant.Outlined" Color="Color.Default" StartIcon="@Icons.Custom.Brands.GitHub" Href="@project.GitHubUrl" Target="_blank" Size="Size.Small" Class="mr-2 mb-2">
                                GitHub
                            </MudButton>
                        }
                        @if (project.LiveUrl != null)
                        {
                            <MudButton Variant="Variant.Outlined" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Launch" Href="@project.LiveUrl" Target="_blank" Size="Size.Small" Class="mr-2 mb-2">
                                Live Demo
                            </MudButton>
                        }
                        @if (string.IsNullOrWhiteSpace(project.Slug) && project.GitHubUrl == null && project.LiveUrl == null)
                        {
                            <MudButton Variant="Variant.Outlined" Color="Color.Primary" Href="/projects" Size="Size.Small">
                                View All Projects
                            </MudButton>
                        }
                    </MudCardActions>
                </MudCard>
            </MudItem>
        }
    </MudGrid>
    <MudStack Row="true" Justify="Justify.Center" Class="mt-6">
        <MudButton Variant="Variant.Outlined" Color="Color.Primary" Href="/projects" EndIcon="@Icons.Material.Filled.ArrowForward">
            View All Projects
        </MudButton>
    </MudStack>
}

<MudGrid Class="mt-10 mb-8">
    <MudItem xs="12" md="6">
        <MudPaper Class="pa-8" Elevation="2">
            <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-3">
                <MudIcon Icon="@Icons.Material.Filled.Psychology" Color="Color.Primary" Style="font-size:36px;" />
                <MudText Typo="Typo.h5" Class="fw-bold ml-2">AI Development</MudText>
            </MudStack>
            <MudText Typo="Typo.body1" Class="mb-3">
                I specialise in AI-driven chat assistants and conversational interfaces that give real users
                genuine value. I have shipped AI assistants, document intelligence features, and anomaly
                detection tools using Semantic Kernel and Azure OpenAI. I am currently expanding across a
                wider set of LLMs: Ollama for local inference, Claude for reasoning-heavy tasks, and Codex
                for developer tooling, to stay at the leading edge of what is practical in production .NET.
            </MudText>
            <MudChipSet T="string">
                <MudChip T="string" Color="Color.Primary" Variant="Variant.Outlined" Size="Size.Small">Semantic Kernel</MudChip>
                <MudChip T="string" Color="Color.Primary" Variant="Variant.Outlined" Size="Size.Small">Azure OpenAI</MudChip>
                <MudChip T="string" Color="Color.Primary" Variant="Variant.Outlined" Size="Size.Small">Ollama</MudChip>
                <MudChip T="string" Color="Color.Primary" Variant="Variant.Outlined" Size="Size.Small">Claude</MudChip>
                <MudChip T="string" Color="Color.Primary" Variant="Variant.Outlined" Size="Size.Small">Codex</MudChip>
                <MudChip T="string" Color="Color.Primary" Variant="Variant.Outlined" Size="Size.Small">RAG</MudChip>
                <MudChip T="string" Color="Color.Primary" Variant="Variant.Outlined" Size="Size.Small">ML.NET</MudChip>
                <MudChip T="string" Color="Color.Primary" Variant="Variant.Outlined" Size="Size.Small">Vector Search</MudChip>
            </MudChipSet>
        </MudPaper>
    </MudItem>
    <MudItem xs="12" md="6">
        <MudPaper Class="pa-8" Elevation="2">
            <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-3">
                <MudIcon Icon="@Icons.Material.Filled.Security" Color="Color.Error" Style="font-size:36px;" />
                <MudText Typo="Typo.h5" Class="fw-bold ml-2">Application Security</MudText>
            </MudStack>
            <MudText Typo="Typo.body1" Class="mb-3">
                Security is not a checkbox at the end of a sprint. I build it into every layer from authentication
                design and threat modelling to penetration testing and dependency audits. Healthcare and finance
                projects have sharpened my instincts for what actually breaks in the wild.
            </MudText>
            <MudChipSet T="string">
                <MudChip T="string" Color="Color.Primary" Variant="Variant.Outlined" Size="Size.Small">OWASP</MudChip>
                <MudChip T="string" Color="Color.Primary" Variant="Variant.Outlined" Size="Size.Small">OAuth2 / OIDC</MudChip>
                <MudChip T="string" Color="Color.Primary" Variant="Variant.Outlined" Size="Size.Small">Threat Modelling</MudChip>
                <MudChip T="string" Color="Color.Primary" Variant="Variant.Outlined" Size="Size.Small">Pen Testing</MudChip>
                <MudChip T="string" Color="Color.Primary" Variant="Variant.Outlined" Size="Size.Small">ASP.NET Identity</MudChip>
            </MudChipSet>
        </MudPaper>
    </MudItem>
</MudGrid>

<MudPaper Class="pa-8 mb-8 text-center" Elevation="2">
    <MudText Typo="Typo.h4" Class="mb-3 fw-bold">Core Technologies</MudText>
    <MudChipSet T="string">
        @foreach (var tech in _coreSkills)
        {
            <MudChip T="string" Color="Color.Primary" Variant="Variant.Outlined">@tech</MudChip>
        }
    </MudChipSet>
</MudPaper>

</div>

@code {
    private List<Portfolio.Shared.Models.ProjectDto>? _projects;
    private List<Portfolio.Shared.Models.HeroStatDto>? _heroStats;

    private readonly string[] _coreSkills = {
        "C#", ".NET 10", "ASP.NET Core", "Blazor", "Semantic Kernel",
        "Azure OpenAI", "SQL Server", "Entity Framework Core", "REST APIs",
        "OAuth2", "OWASP", "MudBlazor", "Azure", ".NET MAUI"
    };

    protected override async Task OnInitializedAsync()
    {
        _projects   = await ApiService.GetProjectsAsync();
        _heroStats  = await ApiService.GetHeroStatsAsync();
    }

    private Color GetProjectColor(string category) => category switch
    {
        "Healthcare" => Color.Error,
        "Mobile Application" => Color.Secondary,
        "Web Application" => Color.Primary,
        "Work Project" => Color.Primary,
        "AI" => Color.Tertiary,
        "Security" => Color.Warning,
        _ => Color.Tertiary
    };

    private string GetProjectIcon(string category) => category switch
    {
        "Healthcare" => Icons.Material.Filled.LocalHospital,
        "Mobile Application" => Icons.Material.Filled.PhoneAndroid,
        "Web Application" => Icons.Material.Filled.Web,
        "Work Project" => Icons.Material.Filled.Work,
        "AI" => Icons.Material.Filled.Psychology,
        "Security" => Icons.Material.Filled.Security,
        _ => Icons.Material.Filled.Apps
    };
}
