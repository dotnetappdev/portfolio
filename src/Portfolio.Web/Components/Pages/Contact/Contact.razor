@page "/contact"
@rendermode InteractiveServer
@inject Portfolio.Web.Services.PortfolioApiService ApiService
@inject ISnackbar Snackbar

<PageTitle>Contact | David Buckley</PageTitle>

<div class="page-banner">
    <MudContainer MaxWidth="MaxWidth.ExtraLarge">
        <MudText Typo="Typo.h3" Class="fw-bold mb-1">Get In Touch</MudText>
        <MudText Typo="Typo.subtitle1">I'm always open to discussing new opportunities, interesting projects, or just having a chat about technology.</MudText>
    </MudContainer>
</div>

<div class="page-content">
<MudGrid Justify="Justify.Center">
    <MudItem xs="12" md="8">
        <MudCard Elevation="3">
            <MudCardContent>
                <MudForm @ref="_form" @bind-IsValid="_isValid">
                    <MudTextField @bind-Value="_model.Name" Label="Your Name" Required="true" RequiredError="Name is required"
                                  Variant="Variant.Outlined" Class="mb-4" Adornment="Adornment.Start"
                                  AdornmentIcon="@Icons.Material.Filled.Person" />
                    <MudTextField @bind-Value="_model.Email" Label="Email Address" Required="true"
                                  RequiredError="Email is required"
                                  Validation="@(new EmailAddressAttribute(){ErrorMessage="Please enter a valid email address"})"
                                  Variant="Variant.Outlined" Class="mb-4" Adornment="Adornment.Start"
                                  AdornmentIcon="@Icons.Material.Filled.Email" />
                    <MudTextField @bind-Value="_model.Subject" Label="Subject" Variant="Variant.Outlined"
                                  Class="mb-4" Adornment="Adornment.Start"
                                  AdornmentIcon="@Icons.Material.Filled.Subject" />
                    <MudTextField @bind-Value="_model.Message" Label="Message" Required="true"
                                  RequiredError="Message is required" Lines="6"
                                  Variant="Variant.Outlined" Class="mb-4" />

                    <!-- Security check (math CAPTCHA) -->
                    <MudPaper Class="pa-3 mb-4" Elevation="0" Style="border:1px solid var(--mud-palette-lines-inputs);border-radius:4px;">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Wrap="Wrap.Wrap">
                            <MudIcon Icon="@Icons.Material.Filled.Shield" Color="Color.Secondary" />
                            <MudText Typo="Typo.body2">Security check: What is <strong>@_captchaA + @_captchaB</strong>?</MudText>
                            <MudTextField @bind-Value="_captchaAnswer"
                                          Placeholder="Answer"
                                          Variant="Variant.Outlined"
                                          Margin="Margin.Dense"
                                          Style="max-width:100px;"
                                          Error="@_captchaError"
                                          ErrorText="Incorrect answer, please try again."
                                          InputType="InputType.Number" />
                        </MudStack>
                    </MudPaper>

                    <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large"
                               OnClick="@HandleSubmit" Disabled="@_sending"
                               StartIcon="@Icons.Material.Filled.Send">
                        @(_sending ? "Sending..." : "Send Message")
                    </MudButton>
                </MudForm>
            </MudCardContent>
        </MudCard>
    </MudItem>
</MudGrid>
</div>

@code {
    private MudForm _form = null!;
    private bool _isValid;
    private bool _sending;
    private Portfolio.Shared.Models.ContactMessageDto _model = new();

    // ── CAPTCHA ──────────────────────────────────────────────
    private int _captchaA;
    private int _captchaB;
    private string _captchaAnswer = string.Empty;
    private bool _captchaError;

    protected override void OnInitialized() => RegenerateCaptcha();

    private void RegenerateCaptcha()
    {
        var rng = Random.Shared;
        _captchaA = rng.Next(1, 10);
        _captchaB = rng.Next(1, 10);
        _captchaAnswer = string.Empty;
        _captchaError = false;
    }

    private async Task HandleSubmit()
    {
        await _form.ValidateAsync();
        if (!_isValid) return;

        // Validate CAPTCHA
        if (!int.TryParse(_captchaAnswer, out var answer) || answer != _captchaA + _captchaB)
        {
            _captchaError = true;
            RegenerateCaptcha();
            Snackbar.Add("Incorrect answer to the security question. Please try again.", Severity.Warning);
            return;
        }

        _sending = true;
        var success = await ApiService.SendContactMessageAsync(_model);
        _sending = false;

        if (success)
        {
            Snackbar.Add("Message sent successfully! I'll get back to you soon.", Severity.Success);
            _model = new Portfolio.Shared.Models.ContactMessageDto();
            await _form.ResetAsync();
            RegenerateCaptcha();
        }
        else
        {
            Snackbar.Add("Unable to send message due to a connection issue. Please try again later or contact me directly.", Severity.Warning);
            RegenerateCaptcha();
        }
    }
}

