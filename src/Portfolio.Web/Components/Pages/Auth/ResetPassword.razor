@page "/reset-password"
@using Microsoft.AspNetCore.WebUtilities
@inject Portfolio.Web.Services.PortfolioApiAuthService AuthService
@inject NavigationManager NavigationManager

<PageTitle>Reset Password | David Buckley Portfolio</PageTitle>

<MudGrid Justify="Justify.Center" Class="mt-8">
    <MudItem xs="12" sm="8" md="5">
        <MudCard Elevation="4">
            <MudCardHeader>
                <CardHeaderContent>
                    <MudText Typo="Typo.h5" Class="text-center fw-bold">Reset Password</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="text-center">
                        Enter your new password below
                    </MudText>
                </CardHeaderContent>
            </MudCardHeader>
            <MudCardContent>
                @if (_invalidLink)
                {
                    <MudAlert Severity="Severity.Error">
                        This reset link is invalid or has expired. Please request a new one.
                    </MudAlert>
                }
                else if (_success)
                {
                    <MudAlert Severity="Severity.Success" Class="mb-4">
                        Your password has been reset. You can now log in.
                    </MudAlert>
                    <MudButton Variant="Variant.Outlined" Color="Color.Primary" FullWidth="true"
                               Href="/login" StartIcon="@Icons.Material.Filled.Login" Class="hero-outline-btn">
                        Go to Login
                    </MudButton>
                }
                else
                {
                    @if (!string.IsNullOrWhiteSpace(_error))
                    {
                        <MudAlert Severity="Severity.Error" Class="mb-4">@_error</MudAlert>
                    }

                    <EditForm Model="_model" OnValidSubmit="HandleSubmit">
                        <DataAnnotationsValidator />
                        <div class="mb-4">
                            <label style="display:block;font-size:0.875rem;color:var(--mud-palette-text-secondary);margin-bottom:4px;">New Password</label>
                            <InputText @bind-Value="_model.NewPassword" type="password" autocomplete="new-password" required
                                       style="width:100%;padding:16px 14px;border:1px solid var(--mud-palette-lines-inputs);border-radius:4px;font-size:1rem;background:transparent;color:var(--mud-palette-text-primary);box-sizing:border-box;" />
                        </div>
                        <div class="mb-4">
                            <label style="display:block;font-size:0.875rem;color:var(--mud-palette-text-secondary);margin-bottom:4px;">Confirm Password</label>
                            <InputText @bind-Value="_model.ConfirmPassword" type="password" autocomplete="new-password" required
                                       style="width:100%;padding:16px 14px;border:1px solid var(--mud-palette-lines-inputs);border-radius:4px;font-size:1rem;background:transparent;color:var(--mud-palette-text-primary);box-sizing:border-box;" />
                        </div>
                        <MudButton Variant="Variant.Outlined" Color="Color.Primary" FullWidth="true"
                                   Size="Size.Large" ButtonType="ButtonType.Submit" Disabled="_loading"
                                   StartIcon="@Icons.Material.Filled.LockReset" Class="hero-outline-btn">
                            @(_loading ? "Resetting..." : "Reset Password")
                        </MudButton>
                    </EditForm>
                }
            </MudCardContent>
            @if (!_success && !_invalidLink)
            {
                <MudCardActions Class="justify-center pb-4">
                    <MudLink Href="/forgot-password" Color="Color.Primary">Request a new link</MudLink>
                </MudCardActions>
            }
        </MudCard>
    </MudItem>
</MudGrid>

@code {
    private readonly ResetPasswordFormModel _model = new();
    private bool _loading;
    private bool _success;
    private bool _invalidLink;
    private string? _error;
    private string _email  = "";
    private string _token  = "";

    protected override void OnInitialized()
    {
        var query = QueryHelpers.ParseQuery(new Uri(NavigationManager.Uri).Query);

        if (!query.TryGetValue("email", out var email) || !query.TryGetValue("token", out var token)
            || string.IsNullOrWhiteSpace(email) || string.IsNullOrWhiteSpace(token))
        {
            _invalidLink = true;
            return;
        }

        _email = email!;
        _token = token!;
    }

    private async Task HandleSubmit()
    {
        if (_model.NewPassword != _model.ConfirmPassword)
        {
            _error = "Passwords do not match.";
            return;
        }

        _loading = true;
        _error   = null;

        var (success, error) = await AuthService.ResetPasswordAsync(
            new Portfolio.Shared.Models.ResetPasswordDto
            {
                Email           = _email,
                Token           = _token,
                NewPassword     = _model.NewPassword,
                ConfirmPassword = _model.ConfirmPassword
            });

        _loading = false;

        if (success)
            _success = true;
        else
            _error = error ?? "Password reset failed. The link may have expired.";
    }

    private class ResetPasswordFormModel
    {
        public string NewPassword     { get; set; } = "";
        public string ConfirmPassword { get; set; } = "";
    }
}
