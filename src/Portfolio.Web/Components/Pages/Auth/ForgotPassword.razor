@page "/forgot-password"
@inject Portfolio.Web.Services.PortfolioApiAuthService AuthService
@inject NavigationManager NavigationManager

<PageTitle>Forgot Password | David Buckley Portfolio</PageTitle>

<MudGrid Justify="Justify.Center" Class="mt-8">
    <MudItem xs="12" sm="8" md="5">
        <MudCard Elevation="4">
            <MudCardHeader>
                <CardHeaderContent>
                    <MudText Typo="Typo.h5" Class="text-center fw-bold">Forgot Password</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="text-center">
                        Enter your email and we will send you a reset link
                    </MudText>
                </CardHeaderContent>
            </MudCardHeader>
            <MudCardContent>
                @if (_submitted)
                {
                    <MudAlert Severity="Severity.Success">
                        If that email is registered you will receive a reset link shortly.
                    </MudAlert>
                }
                else
                {
                    @if (!string.IsNullOrWhiteSpace(_error))
                    {
                        <MudAlert Severity="Severity.Error" Class="mb-4">@_error</MudAlert>
                    }

                    <EditForm Model="_model" OnValidSubmit="HandleSubmit">
                        <DataAnnotationsValidator />
                        <div class="mb-4">
                            <label style="display:block;font-size:0.875rem;color:var(--mud-palette-text-secondary);margin-bottom:4px;">Email</label>
                            <InputText @bind-Value="_model.Email" type="email" autocomplete="email" required
                                       style="width:100%;padding:16px 14px;border:1px solid var(--mud-palette-lines-inputs);border-radius:4px;font-size:1rem;background:transparent;color:var(--mud-palette-text-primary);box-sizing:border-box;" />
                        </div>
                        <MudButton Variant="Variant.Outlined" Color="Color.Primary" FullWidth="true"
                                   Size="Size.Large" ButtonType="ButtonType.Submit" Disabled="_loading"
                                   StartIcon="@Icons.Material.Filled.Email" Class="hero-outline-btn">
                            @(_loading ? "Sending..." : "Send Reset Link")
                        </MudButton>
                    </EditForm>
                }
            </MudCardContent>
            <MudCardActions Class="justify-center pb-4">
                <MudLink Href="/login" Color="Color.Primary">Back to login</MudLink>
            </MudCardActions>
        </MudCard>
    </MudItem>
</MudGrid>

@code {
    private readonly ForgotPasswordFormModel _model = new();
    private bool _loading;
    private bool _submitted;
    private string? _error;

    private async Task HandleSubmit()
    {
        _loading = true;
        _error   = null;

        var baseUrl = NavigationManager.BaseUri;
        var (success, error) = await AuthService.ForgotPasswordAsync(
            new Portfolio.Shared.Models.ForgotPasswordDto
            {
                Email           = _model.Email,
                CallbackBaseUrl = baseUrl
            });

        _loading = false;

        if (success)
            _submitted = true;
        else
            _error = error ?? "An error occurred. Please try again.";
    }

    private class ForgotPasswordFormModel
    {
        public string Email { get; set; } = "";
    }
}
