@page "/admin"
@rendermode InteractiveServer
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@using Microsoft.EntityFrameworkCore
@using Portfolio.Web.Components.Shared
@using Portfolio.Shared.Models
@inject Portfolio.Web.Services.PortfolioApiAuthService ApiAuthService
@inject Portfolio.Web.Data.ApplicationDbContext DbContext
@inject Portfolio.Web.Services.SmsSender SmsSender
@inject Portfolio.Web.Services.EmailSender EmailSender
@inject Portfolio.Web.Services.BlogService BlogService
@inject Portfolio.Web.Services.CmsPageService CmsPageService
@inject Portfolio.Web.Services.MenuService MenuService
@inject Portfolio.Web.Services.AppSettingsService AppSettingsService
@inject Portfolio.Web.Services.StaticSiteGeneratorService StaticSiteGenerator
@inject Portfolio.Web.Services.PortfolioApiService ApiService
@inject ISnackbar Snackbar
@inject IJSRuntime JSRuntime
@inject AuthenticationStateProvider AuthStateProvider
@inject IDialogService DialogService

<PageTitle>Admin | David Buckley Portfolio</PageTitle>

<div class="page-banner">
    <MudContainer MaxWidth="MaxWidth.ExtraLarge">
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
            <MudAvatar Color="Color.Primary" Size="Size.Large" Style="background:rgba(196,181,253,0.15);">
                <MudIcon Icon="@Icons.Material.Filled.AdminPanelSettings" Style="font-size:32px;" />
            </MudAvatar>
            <MudStack Spacing="0">
                <MudText Typo="Typo.h4" Class="fw-bold">Admin Dashboard</MudText>
                <MudText Typo="Typo.subtitle1">Manage users, hero stats, SMS settings and portfolio content</MudText>
            </MudStack>
        </MudStack>
    </MudContainer>
</div>

<div class="page-content">

<MudTabs Elevation="2" Rounded="true" ApplyEffectsToContainer="true" Class="mt-4">

    <!-- ── Hero Stats tab ──────────────────────────────── -->
    <MudTabPanel Text="Hero Stats" Icon="@Icons.Material.Filled.Dashboard">
        <MudGrid Class="mt-4">
            <MudItem xs="12" md="5">
                <MudCard Elevation="3">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6">
                                <MudIcon Icon="@(_editingStat == null ? Icons.Material.Filled.AddChart : Icons.Material.Filled.Edit)" Class="mr-2" />
                                @(_editingStat == null ? "Add New Stat Card" : "Edit Stat Card")
                            </MudText>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent>
                        <MudForm @ref="_statForm" @bind-IsValid="_statFormValid">
                            <MudTextField @bind-Value="_statValue" Label="Value (e.g. 30+, AI, £1M+)"
                                          Required="true" RequiredError="Value is required"
                                          Variant="Variant.Outlined" Class="mb-3" />
                            <MudTextField @bind-Value="_statLabel" Label="Label (e.g. Years in .NET)"
                                          Required="true" RequiredError="Label is required"
                                          Variant="Variant.Outlined" Class="mb-3" />
                            <MudSelect @bind-Value="_statColor" Label="Colour" Variant="Variant.Outlined" Class="mb-3">
                                <MudSelectItem Value="@("Primary")">Primary (Violet)</MudSelectItem>
                                <MudSelectItem Value="@("Secondary")">Secondary (Cyan)</MudSelectItem>
                                <MudSelectItem Value="@("Tertiary")">Tertiary (Emerald)</MudSelectItem>
                                <MudSelectItem Value="@("Error")">Error (Red)</MudSelectItem>
                                <MudSelectItem Value="@("Success")">Success (Green)</MudSelectItem>
                                <MudSelectItem Value="@("Warning")">Warning (Amber)</MudSelectItem>
                            </MudSelect>
                            <MudNumericField @bind-Value="_statSortOrder" Label="Sort Order"
                                             Variant="Variant.Outlined" Class="mb-3" Min="1" />
                        </MudForm>
                    </MudCardContent>
                    <MudCardActions>
                        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                                   OnClick="@SaveStat" Disabled="@_savingStat"
                                   StartIcon="@Icons.Material.Filled.Save">
                            @(_savingStat ? "Saving..." : (_editingStat == null ? "Add Stat" : "Save Changes"))
                        </MudButton>
                        @if (_editingStat != null)
                        {
                            <MudButton Variant="Variant.Text" Color="Color.Default"
                                       OnClick="@CancelEditStat" Class="ml-2">
                                Cancel
                            </MudButton>
                        }
                    </MudCardActions>
                </MudCard>
            </MudItem>

            <MudItem xs="12" md="7">
                <MudCard Elevation="3">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6">
                                <MudIcon Icon="@Icons.Material.Filled.ViewModule" Class="mr-2" />
                                Current Stat Cards
                            </MudText>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent>
                        @if (_heroStats == null)
                        {
                            <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
                        }
                        else if (_heroStats.Count == 0)
                        {
                            <MudText Color="Color.Secondary">No stat cards yet. Add one using the form.</MudText>
                        }
                        else
                        {
                            <MudList T="string" Dense="true">
                                @foreach (var stat in _heroStats.OrderBy(s => s.SortOrder))
                                {
                                    <MudListItem>
                                        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                                <MudChip T="string" Color="@GetMudColor(stat.Color)" Size="Size.Small" Variant="Variant.Filled">
                                                    @stat.Value
                                                </MudChip>
                                                <MudStack Spacing="0">
                                                    <MudText Typo="Typo.body2">@stat.Label</MudText>
                                                    <MudText Typo="Typo.caption" Color="Color.Secondary">Order: @stat.SortOrder · @stat.Color</MudText>
                                                </MudStack>
                                            </MudStack>
                                            <MudStack Row="true" Spacing="0">
                                                <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                                               Size="Size.Small" Color="Color.Primary"
                                                               OnClick="@(() => StartEditStat(stat))"
                                                               aria-label="Edit stat card" />
                                                <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                                               Size="Size.Small" Color="Color.Error"
                                                               OnClick="@(() => DeleteStat(stat.Id))"
                                                               aria-label="Delete stat card" />
                                            </MudStack>
                                        </MudStack>
                                    </MudListItem>
                                }
                            </MudList>
                        }
                    </MudCardContent>
                </MudCard>
            </MudItem>
        </MudGrid>
    </MudTabPanel>

    <!-- ── Users tab ──────────────────────────────────── -->
    <MudTabPanel Text="Users" Icon="@Icons.Material.Filled.People">
        <MudGrid Class="mt-4">

            <!-- ── Create / Edit User ── -->
            <MudItem xs="12" md="5">
                <MudCard Elevation="3">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6">
                                <MudIcon Icon="@(_editingUser == null ? Icons.Material.Filled.PersonAdd : Icons.Material.Filled.Edit)" Class="mr-2" />
                                @(_editingUser == null ? "Create New Account" : "Edit Account")
                            </MudText>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent>
                        <MudForm @ref="_form" @bind-IsValid="_isValid">
                            <MudTextField @bind-Value="_newUser.Email" Label="Email Address" Required="true"
                                          RequiredError="Email is required" InputType="InputType.Email"
                                          Variant="Variant.Outlined" Class="mb-3" />
                            <MudTextField @bind-Value="_firstName" Label="First Name"
                                          Variant="Variant.Outlined" Class="mb-3" />
                            <MudTextField @bind-Value="_lastName" Label="Last Name"
                                          Variant="Variant.Outlined" Class="mb-3" />
                            @if (_editingUser == null)
                            {
                                <MudTextField @bind-Value="_newUser.Password" Label="Password" Required="true"
                                              RequiredError="Password is required"
                                              InputType="@(_showPassword ? InputType.Text : InputType.Password)"
                                              Variant="Variant.Outlined" Class="mb-3"
                                              Adornment="Adornment.End"
                                              AdornmentIcon="@(_showPassword ? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility)"
                                              OnAdornmentClick="@(() => _showPassword = !_showPassword)"
                                              HelperText="Min 8 chars, must include uppercase, number and special character" />
                            }
                            else
                            {
                                <MudTextField @bind-Value="_newPassword" Label="New Password (leave blank to keep current)"
                                              InputType="@(_showPassword ? InputType.Text : InputType.Password)"
                                              Variant="Variant.Outlined" Class="mb-3"
                                              Adornment="Adornment.End"
                                              AdornmentIcon="@(_showPassword ? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility)"
                                              OnAdornmentClick="@(() => _showPassword = !_showPassword)" />
                            }
                        </MudForm>
                    </MudCardContent>
                    <MudCardActions>
                        @if (_editingUser == null)
                        {
                            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                                       OnClick="@HandleCreateUser" Disabled="@_creating"
                                       StartIcon="@Icons.Material.Filled.PersonAdd">
                                @(_creating ? "Creating..." : "Create Account")
                            </MudButton>
                        }
                        else
                        {
                            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                                       OnClick="@HandleUpdateUser" Disabled="@_creating"
                                       StartIcon="@Icons.Material.Filled.Save">
                                @(_creating ? "Saving..." : "Save Changes")
                            </MudButton>
                            <MudButton Variant="Variant.Text" Color="Color.Default"
                                       OnClick="@CancelEditUser" Class="ml-2">Cancel</MudButton>
                        }
                    </MudCardActions>
                </MudCard>

                <!-- ── Roles Management ── -->
                <MudCard Elevation="3" Class="mt-4">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6">
                                <MudIcon Icon="@Icons.Material.Filled.Badge" Class="mr-2" />
                                Roles Management
                            </MudText>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent>
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-3">
                            <MudTextField @bind-Value="_newRoleName" Label="New Role Name"
                                          Variant="Variant.Outlined" Style="flex:1" />
                            <MudButton Variant="Variant.Filled" Color="Color.Secondary"
                                       OnClick="@HandleCreateRole"
                                       StartIcon="@Icons.Material.Filled.Add">Add</MudButton>
                        </MudStack>
                        @if (_roles == null)
                        {
                            <MudProgressCircular Indeterminate="true" Color="Color.Primary" Size="Size.Small" />
                        }
                        else
                        {
                            <MudList T="string" Dense="true">
                                @foreach (var role in _roles)
                                {
                                    <MudListItem>
                                        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                                            <MudChip T="string" Color="Color.Primary" Size="Size.Small" Variant="Variant.Outlined">@role.Name</MudChip>
                                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error"
                                                           OnClick="@(() => HandleDeleteRole(role.Name))"
                                                           aria-label="@($"Delete role {role.Name}")" />
                                        </MudStack>
                                    </MudListItem>
                                }
                            </MudList>
                        }
                    </MudCardContent>
                </MudCard>
            </MudItem>

            <!-- ── Existing Users ── -->
            <MudItem xs="12" md="7">
                <MudCard Elevation="3">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6">
                                <MudIcon Icon="@Icons.Material.Filled.People" Class="mr-2" />
                                Application Users
                            </MudText>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent>
                        @if (_users == null)
                        {
                            <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
                        }
                        else
                        {
                            <MudList T="string">
                                @foreach (var user in _users)
                                {
                                    <MudListItem>
                                        <MudStack Spacing="1">
                                            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                                    <MudAvatar Color="Color.Primary" Size="Size.Small">
                                                        <MudIcon Icon="@Icons.Material.Filled.Person" />
                                                    </MudAvatar>
                                                    <MudStack Spacing="0">
                                                        <MudText Typo="Typo.body2">@user.Email</MudText>
                                                        @if (!string.IsNullOrEmpty(user.FirstName))
                                                        {
                                                            <MudText Typo="Typo.caption" Color="Color.Secondary">@user.FirstName @user.LastName</MudText>
                                                        }
                                                    </MudStack>
                                                </MudStack>
                                                <MudStack Row="true" Spacing="0">
                                                    <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Color="Color.Primary"
                                                                   OnClick="@(() => StartEditUser(user))"
                                                                   aria-label="Edit user" />
                                                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error"
                                                                   OnClick="@(() => HandleDeleteUser(user.Id))"
                                                                   aria-label="Delete user" />
                                                </MudStack>
                                            </MudStack>
                                            <!-- Roles row -->
                                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1" Class="ml-9">
                                                @foreach (var role in user.Roles)
                                                {
                                                    <MudChip T="string" Size="Size.Small" Color="Color.Secondary" Variant="Variant.Filled"
                                                             OnClose="@(() => HandleRemoveUserRole(user.Id, role))"
                                                             CloseIcon="@Icons.Material.Filled.Close">
                                                        @role
                                                    </MudChip>
                                                }
                                                <!-- Add role button -->
                                                @if (_roles != null && _roles.Any(r => !user.Roles.Contains(r.Name)))
                                                {
                                                    <MudMenu Icon="@Icons.Material.Filled.AddCircleOutline" Size="Size.Small"
                                                             Color="Color.Primary" Dense="true"
                                                             aria-label="Assign role">
                                                        @foreach (var role in _roles.Where(r => !user.Roles.Contains(r.Name)))
                                                        {
                                                            <MudMenuItem OnClick="@(() => HandleAddUserRole(user.Id, role.Name))">@role.Name</MudMenuItem>
                                                        }
                                                    </MudMenu>
                                                }
                                            </MudStack>
                                            <!-- Claims row -->
                                            @if (user.Claims.Count > 0)
                                            {
                                                <MudStack Row="true" Spacing="1" Class="ml-9">
                                                    @foreach (var claim in user.Claims)
                                                    {
                                                        <MudTooltip Text="@claim.Type">
                                                            <MudChip T="string" Size="Size.Small" Color="Color.Tertiary" Variant="Variant.Outlined">
                                                                @claim.Value
                                                            </MudChip>
                                                        </MudTooltip>
                                                    }
                                                </MudStack>
                                            }
                                        </MudStack>
                                    </MudListItem>
                                }
                            </MudList>
                        }
                    </MudCardContent>
                </MudCard>
            </MudItem>
        </MudGrid>
    </MudTabPanel>
    <!-- ── Settings tab ───────────────────────────────────── -->
    <MudTabPanel Text="Settings" Icon="@Icons.Material.Filled.Settings">
        <MudGrid Class="mt-4">

            <!-- ── API Settings card ── -->
            <MudItem xs="12" md="6">
                <MudCard Elevation="3">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6">
                                <MudIcon Icon="@Icons.Material.Filled.Api" Class="mr-2" />
                                API Settings
                            </MudText>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent>
                        @if (_appSettings == null)
                        {
                            <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
                        }
                        else
                        {
                            <MudTextField @bind-Value="_appSettings.ApiBaseUrl"
                                          Label="Portfolio API Base URL"
                                          Variant="Variant.Outlined" Class="mb-3"
                                          HelperText="Base URL of the Portfolio API, e.g. https://api.example.com/ (used by the Projects, Skills and Contact pages)"
                                          Placeholder="https://localhost:7002/" />
                        }
                    </MudCardContent>
                    @if (_appSettings != null)
                    {
                    <MudCardActions>
                        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                                   OnClick="@SaveAppSettings" Disabled="@_savingAppSettings"
                                   StartIcon="@Icons.Material.Filled.Save">
                            @(_savingAppSettings ? "Saving..." : "Save API Settings")
                        </MudButton>
                    </MudCardActions>
                    }
                </MudCard>
            </MudItem>

            <!-- ── Google Analytics card ── -->
            <MudItem xs="12" md="6">
                <MudCard Elevation="3">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6">
                                <MudIcon Icon="@Icons.Material.Filled.Analytics" Class="mr-2" />
                                Google Analytics
                            </MudText>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent>
                        @if (_appSettings == null)
                        {
                            <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
                        }
                        else
                        {
                            <MudTextField @bind-Value="_appSettings.GoogleAnalyticsId"
                                          Label="GA4 Measurement ID"
                                          Variant="Variant.Outlined" Class="mb-3"
                                          HelperText="Your Google Analytics 4 Measurement ID, e.g. G-XXXXXXXXXX. Leave empty to disable analytics."
                                          Placeholder="G-XXXXXXXXXX" />
                            @if (!string.IsNullOrWhiteSpace(_appSettings.GoogleAnalyticsId))
                            {
                                <MudAlert Severity="Severity.Success" Dense="true" Class="mt-2">
                                    Analytics active — tracking ID: <strong>@_appSettings.GoogleAnalyticsId</strong>
                                </MudAlert>
                            }
                            else
                            {
                                <MudAlert Severity="Severity.Info" Dense="true" Class="mt-2">
                                    Analytics disabled. Enter a Measurement ID to enable tracking.
                                </MudAlert>
                            }
                        }
                    </MudCardContent>
                    @if (_appSettings != null)
                    {
                    <MudCardActions>
                        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                                   OnClick="@SaveAppSettings" Disabled="@_savingAppSettings"
                                   StartIcon="@Icons.Material.Filled.Save">
                            @(_savingAppSettings ? "Saving..." : "Save Analytics Settings")
                        </MudButton>
                    </MudCardActions>
                    }
                </MudCard>
            </MudItem>

            <!-- ── SMS Settings cards ── -->
            @if (_smsSettings == null)
            {
                <MudItem xs="12"><MudProgressCircular Indeterminate="true" Color="Color.Primary" Class="mt-4" /></MudItem>
            }
            else
            {
                <!-- Provider & global settings -->
                <MudItem xs="12" md="6">
                    <MudCard Elevation="3">
                        <MudCardHeader>
                            <CardHeaderContent>
                                <MudText Typo="Typo.h6">
                                    <MudIcon Icon="@Icons.Material.Filled.SettingsPhone" Class="mr-2" />
                                    SMS Provider
                                </MudText>
                            </CardHeaderContent>
                        </MudCardHeader>
                        <MudCardContent>
                            <MudSwitch @bind-Value="_smsSettings.IsEnabled" Label="Enable SMS sending"
                                       Color="Color.Success" Class="mb-3" />

                            <MudSelect @bind-Value="_smsSettings.Provider" Label="Provider"
                                       Variant="Variant.Outlined" Class="mb-3">
                                <MudSelectItem Value="@("None")">None (disabled)</MudSelectItem>
                                <MudSelectItem Value="@("Twilio")">Twilio</MudSelectItem>
                                <MudSelectItem Value="@("ClickSend")">ClickSend</MudSelectItem>
                            </MudSelect>

                            <MudTextField @bind-Value="_smsSettings.AdminReceiverNumber"
                                          Label="Admin receiver number (E.164, e.g. +447911123456)"
                                          Variant="Variant.Outlined" Class="mb-3"
                                          HelperText="Contact-form alerts are sent to this number" />

                            <!-- Twilio credentials -->
                            @if (_smsSettings.Provider == "Twilio")
                            {
                                <MudDivider Class="my-3" />
                                <MudText Typo="Typo.subtitle2" Class="mb-2">Twilio credentials</MudText>
                                <MudTextField @bind-Value="_smsSettings.TwilioAccountSid"
                                              Label="Account SID" Variant="Variant.Outlined" Class="mb-3" />
                                <MudTextField @bind-Value="_smsSettings.TwilioAuthToken"
                                              Label="Auth Token"
                                              InputType="@(_showTwilioToken ? InputType.Text : InputType.Password)"
                                              Variant="Variant.Outlined" Class="mb-3"
                                              Adornment="Adornment.End"
                                              AdornmentIcon="@(_showTwilioToken ? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility)"
                                              OnAdornmentClick="@(() => _showTwilioToken = !_showTwilioToken)" />
                                <MudTextField @bind-Value="_smsSettings.TwilioFromNumber"
                                              Label="From number (E.164 or Messaging Service SID)"
                                              Variant="Variant.Outlined" Class="mb-3" />
                            }

                            <!-- ClickSend credentials -->
                            @if (_smsSettings.Provider == "ClickSend")
                            {
                                <MudDivider Class="my-3" />
                                <MudText Typo="Typo.subtitle2" Class="mb-2">ClickSend credentials</MudText>
                                <MudTextField @bind-Value="_smsSettings.ClickSendUsername"
                                              Label="Username (email)" Variant="Variant.Outlined" Class="mb-3" />
                                <MudTextField @bind-Value="_smsSettings.ClickSendApiKey"
                                              Label="API Key"
                                              InputType="@(_showClickSendKey ? InputType.Text : InputType.Password)"
                                              Variant="Variant.Outlined" Class="mb-3"
                                              Adornment="Adornment.End"
                                              AdornmentIcon="@(_showClickSendKey ? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility)"
                                              OnAdornmentClick="@(() => _showClickSendKey = !_showClickSendKey)" />
                                <MudTextField @bind-Value="_smsSettings.ClickSendFromName"
                                              Label="Sender ID (up to 11 chars or phone number)"
                                              Variant="Variant.Outlined" Class="mb-3" />
                            }
                        </MudCardContent>
                        <MudCardActions>
                            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                                       OnClick="@SaveSmsSettings" Disabled="@_savingSms"
                                       StartIcon="@Icons.Material.Filled.Save">
                                @(_savingSms ? "Saving..." : "Save SMS Settings")
                            </MudButton>
                            <MudButton Variant="Variant.Outlined" Color="Color.Secondary"
                                       OnClick="@SendTestSms" Disabled="@(!_smsSettings.IsEnabled || _sendingTestSms)"
                                       StartIcon="@Icons.Material.Filled.Send" Class="ml-2">
                                @(_sendingTestSms ? "Sending..." : "Send Test SMS")
                            </MudButton>
                        </MudCardActions>
                    </MudCard>
                </MudItem>

                <!-- Info card -->
                <MudItem xs="12" md="6">
                    <MudCard Elevation="3">
                        <MudCardHeader>
                            <CardHeaderContent>
                                <MudText Typo="Typo.h6">
                                    <MudIcon Icon="@Icons.Material.Filled.Info" Class="mr-2" />
                                    Setup Guide
                                </MudText>
                            </CardHeaderContent>
                        </MudCardHeader>
                        <MudCardContent>
                            <MudText Typo="Typo.subtitle2" Class="mb-1">Twilio</MudText>
                            <MudText Typo="Typo.body2" Class="mb-2">
                                Sign up at <strong>twilio.com</strong>. Copy your <em>Account SID</em> and
                                <em>Auth Token</em> from the Console dashboard. Add a verified phone number as
                                the From number.
                            </MudText>
                            <MudDivider Class="my-2" />
                            <MudText Typo="Typo.subtitle2" Class="mb-1">ClickSend</MudText>
                            <MudText Typo="Typo.body2" Class="mb-2">
                                Sign up at <strong>clicksend.com</strong>. Your login email is the username;
                                generate an API key in <em>Account → API Credentials</em>.
                                The Sender ID can be up to 11 alphanumeric characters.
                            </MudText>
                            <MudDivider Class="my-2" />
                            <MudText Typo="Typo.subtitle2" Class="mb-1">Admin receiver number</MudText>
                            <MudText Typo="Typo.body2">
                                Contact-form submissions send an SMS alert to this number.
                                Must be in international E.164 format, e.g. <code>+447911123456</code>.
                            </MudText>
                        </MudCardContent>
                    </MudCard>
                </MudItem>
            }

            <!-- ── Mail (SMTP) Settings ── -->
            @if (_mailSettings == null)
            {
                <MudItem xs="12"><MudProgressCircular Indeterminate="true" Color="Color.Primary" Class="mt-4" /></MudItem>
            }
            else
            {
                <MudItem xs="12" md="6">
                    <MudCard Elevation="3">
                        <MudCardHeader>
                            <CardHeaderContent>
                                <MudText Typo="Typo.h6">
                                    <MudIcon Icon="@Icons.Material.Filled.Email" Class="mr-2" />
                                    Mail (SMTP) Settings
                                </MudText>
                            </CardHeaderContent>
                        </MudCardHeader>
                        <MudCardContent>
                            <MudSwitch @bind-Value="_mailSettings.IsEnabled" Label="Enable outbound email"
                                       Color="Color.Success" Class="mb-3" />
                            <MudTextField @bind-Value="_mailSettings.SmtpHost"
                                          Label="SMTP Host" Variant="Variant.Outlined" Class="mb-3"
                                          Placeholder="smtp.gmail.com" />
                            <MudNumericField @bind-Value="_mailSettings.SmtpPort"
                                             Label="SMTP Port" Variant="Variant.Outlined" Class="mb-3"
                                             Min="1" Max="65535" />
                            <MudSwitch @bind-Value="_mailSettings.UseSsl" Label="Use SSL/TLS"
                                       Color="Color.Primary" Class="mb-3" />
                            <MudTextField @bind-Value="_mailSettings.SmtpUsername"
                                          Label="Username" Variant="Variant.Outlined" Class="mb-3" />
                            <MudTextField @bind-Value="_mailSettings.SmtpPassword"
                                          Label="Password"
                                          InputType="@(_showSmtpPassword ? InputType.Text : InputType.Password)"
                                          Variant="Variant.Outlined" Class="mb-3"
                                          Adornment="Adornment.End"
                                          AdornmentIcon="@(_showSmtpPassword ? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility)"
                                          OnAdornmentClick="@(() => _showSmtpPassword = !_showSmtpPassword)" />
                            <MudTextField @bind-Value="_mailSettings.FromAddress"
                                          Label="From Address" Variant="Variant.Outlined" Class="mb-3"
                                          Placeholder="noreply@example.com" />
                            <MudTextField @bind-Value="_mailSettings.FromName"
                                          Label="From Name" Variant="Variant.Outlined" Class="mb-3"
                                          Placeholder="David Buckley Portfolio" />
                        </MudCardContent>
                        <MudCardActions>
                            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                                       OnClick="@SaveMailSettings" Disabled="@_savingMail"
                                       StartIcon="@Icons.Material.Filled.Save">
                                @(_savingMail ? "Saving..." : "Save Mail Settings")
                            </MudButton>
                            <MudButton Variant="Variant.Outlined" Color="Color.Secondary"
                                       OnClick="@SendTestEmail" Disabled="@(!_mailSettings.IsEnabled || _sendingTestEmail)"
                                       StartIcon="@Icons.Material.Filled.Send" Class="ml-2">
                                @(_sendingTestEmail ? "Sending..." : "Send Test Email")
                            </MudButton>
                        </MudCardActions>
                    </MudCard>
                </MudItem>

                <!-- Visitor Notification Settings -->
                <MudItem xs="12" md="6">
                    <MudCard Elevation="3">
                        <MudCardHeader>
                            <CardHeaderContent>
                                <MudText Typo="Typo.h6">
                                    <MudIcon Icon="@Icons.Material.Filled.Visibility" Class="mr-2" />
                                    Visitor Notifications
                                </MudText>
                            </CardHeaderContent>
                        </MudCardHeader>
                        <MudCardContent>
                            @if (_appSettings == null)
                            {
                                <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
                            }
                            else
                            {
                                <MudSwitch @bind-Value="_appSettings.VisitorNotificationsEnabled"
                                           Label="Email me when a new visitor arrives"
                                           Color="Color.Success" Class="mb-3" />
                                <MudTextField @bind-Value="_appSettings.VisitorNotificationEmail"
                                              Label="Notification Email Address"
                                              Variant="Variant.Outlined" Class="mb-3"
                                              HelperText="Leave blank to use the Mail Settings From Address"
                                              Placeholder="you@example.com" />
                                <MudText Typo="Typo.subtitle2" Class="mb-1">Email Template</MudText>
                                <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-2">
                                    Available placeholders: <code>{{ip}}</code>, <code>{{page}}</code>, <code>{{time}}</code>
                                </MudText>
                                <MudTextField @bind-Value="_appSettings.VisitorEmailTemplate"
                                              Label="HTML Email Body"
                                              Variant="Variant.Outlined"
                                              Lines="6"
                                              Placeholder="@DefaultVisitorTemplate"
                                              HelperText="Leave blank to use the default template" />
                            }
                        </MudCardContent>
                        @if (_appSettings != null)
                        {
                        <MudCardActions>
                            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                                       OnClick="@SaveAppSettings" Disabled="@_savingAppSettings"
                                       StartIcon="@Icons.Material.Filled.Save">
                                @(_savingAppSettings ? "Saving..." : "Save Visitor Settings")
                            </MudButton>
                        </MudCardActions>
                        }
                    </MudCard>
                </MudItem>
            }

        </MudGrid>
    </MudTabPanel>

        <!-- ── Blog Posts tab ─────────────────────────────────── -->
    <MudTabPanel Text="Blog Posts" Icon="@Icons.Material.Filled.Article">
        <MudGrid Class="mt-4">

            @if (!_postShowEditor)
            {
                <!-- ── Posts: list view (like WP "All Posts") ── -->
                <MudItem xs="12">
                    <MudCard Elevation="3">
                        <MudCardHeader>
                            <CardHeaderContent>
                                <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                                    <MudText Typo="Typo.h6">
                                        <MudIcon Icon="@Icons.Material.Filled.Article" Class="mr-2" />
                                        Posts
                                        @if (_blogPosts != null)
                                        {
                                            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="ml-2">(@_blogPosts.Count total)</MudText>
                                        }
                                    </MudText>
                                    <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
                                               StartIcon="@Icons.Material.Filled.Add"
                                               OnClick="@OpenNewPostEditor">
                                        Add New Post
                                    </MudButton>
                                </MudStack>
                            </CardHeaderContent>
                        </MudCardHeader>
                        <MudCardContent>
                            <!-- Status filter tabs -->
                            <MudStack Row="true" Spacing="1" Class="mb-3">
                                @foreach (var label in new[] { "All", "Published", "Drafts" })
                                {
                                    var count = label switch {
                                        "Published" => _blogPosts?.Count(p => p.IsPublished) ?? 0,
                                        "Drafts"    => _blogPosts?.Count(p => !p.IsPublished) ?? 0,
                                        _           => _blogPosts?.Count ?? 0
                                    };
                                    <MudChip T="string" Size="Size.Small" OnClick="@(() => _postStatusFilter = label)"
                                             Color="@(_postStatusFilter == label ? Color.Primary : Color.Default)"
                                             Variant="@(_postStatusFilter == label ? Variant.Filled : Variant.Outlined)">
                                        @label (@count)
                                    </MudChip>
                                }
                            </MudStack>

                            @if (_blogPosts == null)
                            {
                                <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
                            }
                            else
                            {
                                var filtered = _postStatusFilter switch {
                                    "Published" => _blogPosts.Where(p => p.IsPublished).ToList(),
                                    "Drafts"    => _blogPosts.Where(p => !p.IsPublished).ToList(),
                                    _           => _blogPosts
                                };

                                @if (filtered.Count == 0)
                                {
                                    <MudText Color="Color.Secondary" Class="pa-4">No posts in this view.</MudText>
                                }
                                else
                                {
                                     <MudTable Items="@filtered" Hover="true" Dense="true" Breakpoint="Breakpoint.Sm"
                                                      RowsPerPage="10">
                                        <HeaderContent>
                                            <MudTh>Title</MudTh>
                                            <MudTh>Category</MudTh>
                                            <MudTh>Date</MudTh>
                                            <MudTh>Status</MudTh>
                                            <MudTh>Actions</MudTh>
                                        </HeaderContent>
                                        <RowTemplate>
                                            <MudTd DataLabel="Title">
                                                <MudStack Spacing="0">
                                                    <MudText Typo="Typo.body2" Class="fw-bold">@context.Title</MudText>
                                                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                                        <MudText Typo="Typo.caption" Color="Color.Secondary">/@context.Slug</MudText>
                                                        @if (context.IsPublished)
                                                        {
                                                            <MudLink Href="@($"/blog/{context.Slug}")" Target="_blank"
                                                                     Typo="Typo.caption" Color="Color.Primary" Style="font-size:0.7rem;">
                                                                View ↗
                                                            </MudLink>
                                                        }
                                                    </MudStack>
                                                </MudStack>
                                            </MudTd>
                                            <MudTd DataLabel="Category">
                                                <MudChip T="string" Size="Size.Small" Color="@GetCategoryColor(context.Category)" Variant="Variant.Filled">
                                                    @context.Category
                                                </MudChip>
                                            </MudTd>
                                            <MudTd DataLabel="Date">
                                                <MudStack Spacing="0">
                                                    <MudText Typo="Typo.body2">@context.PublishedDate.ToString("d MMM yyyy")</MudText>
                                                    @if (context.UpdatedAt.HasValue)
                                                    {
                                                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                                                            Updated @context.UpdatedAt.Value.ToString("d MMM yyyy")
                                                        </MudText>
                                                    }
                                                </MudStack>
                                            </MudTd>
                                            <MudTd DataLabel="Status">
                                                @if (context.IsPublished)
                                                {
                                                    <MudChip T="string" Size="Size.Small" Color="Color.Success" Variant="Variant.Filled">Published</MudChip>
                                                }
                                                else
                                                {
                                                    <MudChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Outlined">Draft</MudChip>
                                                }
                                            </MudTd>
                                            <MudTd DataLabel="Actions">
                                                <MudStack Row="true" Spacing="0">
                                                    <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                                                   Size="Size.Small" Color="Color.Primary"
                                                                   OnClick="@(() => StartEditPost(context))"
                                                                   aria-label="Edit post" />
                                                    <MudIconButton Icon="@(context.IsPublished ? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility)"
                                                                   Size="Size.Small" Color="Color.Secondary"
                                                                   OnClick="@(() => TogglePublishPost(context))"
                                                                   aria-label="@(context.IsPublished ? "Unpublish" : "Publish")" />
                                                    <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                                                   Size="Size.Small" Color="Color.Error"
                                                                   OnClick="@(() => DeletePost(context.Id))"
                                                                   aria-label="Delete post" />
                                                </MudStack>
                                            </MudTd>
                                        </RowTemplate>
                                        <PagerContent>
                                            <MudTablePager PageSizeOptions="new int[] { 5, 10, 25 }" />
                                        </PagerContent>
                                    </MudTable>
                                }
                            }
                        </MudCardContent>
                    </MudCard>
                </MudItem>
            }
            else
            {
                <!-- ── Posts: editor view (WordPress-style) ── -->
                <MudItem xs="12">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-3" Spacing="1">
                        <MudButton Variant="Variant.Text" Color="Color.Default" Size="Size.Small"
                                   StartIcon="@Icons.Material.Filled.ArrowBack"
                                   OnClick="@CancelEditPost">
                            ← Posts
                        </MudButton>
                        <MudText Typo="Typo.h6">
                            @(_editingPost == null ? "Add New Post" : "Edit Post")
                        </MudText>
                    </MudStack>
                </MudItem>

                <!-- Editor: left content + right sidebar -->
                <MudItem xs="12" md="8">
                    <MudForm @ref="_postForm" @bind-IsValid="_postFormValid">
                        <!-- Title -->
                        <MudCard Elevation="2" Class="mb-4">
                            <MudCardContent Class="pb-0">
                                <MudTextField @bind-Value="_postTitle" Label="Post Title" Required="true"
                                              RequiredError="Title is required"
                                              Variant="Variant.Outlined"
                                              Typo="Typo.h5"
                                              OnBlur="@GenerateSlugFromTitle"
                                              Style="font-size:1.4rem;font-weight:600;" />
                                <MudStack Row="true" AlignItems="AlignItems.Center" Class="mt-1 mb-2" Spacing="1">
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">Permalink:</MudText>
                                    <MudTextField @bind-Value="_postSlug" Required="true"
                                                  RequiredError="Slug is required"
                                                  Variant="Variant.Text" Margin="Margin.Dense"
                                                  Typo="Typo.caption"
                                                  Style="max-width:320px;" />
                                </MudStack>
                            </MudCardContent>
                        </MudCard>

                        <!-- Body -->
                        <MudCard Elevation="2" Class="mb-4">
                            <MudCardContent>
                                <MudText Typo="Typo.subtitle2" Class="mb-2">Content</MudText>
                                <RichTextEditor @ref="_postBodyEditor" Placeholder="Write your post here…" />
                            </MudCardContent>
                        </MudCard>

                        <!-- Excerpt / Summary -->
                        <MudCard Elevation="2" Class="mb-4">
                            <MudCardContent>
                                <MudText Typo="Typo.subtitle2" Class="mb-2">Excerpt</MudText>
                                <MudTextField @bind-Value="_postSummary" Label="Excerpt" Required="true"
                                              RequiredError="Excerpt is required"
                                              Variant="Variant.Outlined" Lines="3"
                                              HelperText="Used on blog listing cards and as the default meta description." />
                            </MudCardContent>
                        </MudCard>
                    </MudForm>
                </MudItem>

                <!-- Sidebar -->
                <MudItem xs="12" md="4">

                    <!-- Publish card -->
                    <MudCard Elevation="2" Class="mb-4">
                        <MudCardHeader>
                            <CardHeaderContent>
                                <MudText Typo="Typo.subtitle2">
                                    <MudIcon Icon="@Icons.Material.Filled.Publish" Size="Size.Small" Class="mr-1" />
                                    Publish
                                </MudText>
                            </CardHeaderContent>
                        </MudCardHeader>
                        <MudCardContent>
                            <MudStack Spacing="2">
                                <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                                    <MudText Typo="Typo.body2">Status</MudText>
                                    <MudChip T="string" Size="Size.Small"
                                             Color="@(_postIsPublished ? Color.Success : Color.Default)"
                                             Variant="@(_postIsPublished ? Variant.Filled : Variant.Outlined)">
                                        @(_postIsPublished ? "Published" : "Draft")
                                    </MudChip>
                                </MudStack>
                                <MudSwitch @bind-Value="_postIsPublished" Label="@(_postIsPublished ? "Published" : "Save as Draft")"
                                           Color="Color.Success" />
                                <MudTextField @bind-Value="_postPublishedDateStr" Label="Publish Date"
                                              InputType="InputType.Date" Variant="Variant.Outlined"
                                              Margin="Margin.Dense" />
                            </MudStack>
                        </MudCardContent>
                        <MudCardActions>
                            <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true"
                                       OnClick="@SavePost" Disabled="@_savingPost"
                                       StartIcon="@Icons.Material.Filled.Save">
                                @(_savingPost ? "Saving…" : (_editingPost == null ? (_postIsPublished ? "Publish" : "Save Draft") : "Update"))
                            </MudButton>
                        </MudCardActions>
                    </MudCard>

                    <!-- Document settings card -->
                    <MudCard Elevation="2" Class="mb-4">
                        <MudCardHeader>
                            <CardHeaderContent>
                                <MudText Typo="Typo.subtitle2">
                                    <MudIcon Icon="@Icons.Material.Filled.Tune" Size="Size.Small" Class="mr-1" />
                                    Post Settings
                                </MudText>
                            </CardHeaderContent>
                        </MudCardHeader>
                        <MudCardContent>
                            <MudTextField @bind-Value="_postCategory" Label="Category" Required="true"
                                          RequiredError="Category is required"
                                          Variant="Variant.Outlined" Class="mb-3"
                                          HelperText="e.g. AI, Security, .NET" />
                            <MudTextField @bind-Value="_postTags" Label="Tags"
                                          Variant="Variant.Outlined" Class="mb-3"
                                          HelperText="Comma-separated, e.g. AI, .NET, C#" />
                            <MudNumericField @bind-Value="_postReadMinutes" Label="Read time (min)"
                                             Variant="Variant.Outlined" Min="1" />
                        </MudCardContent>
                    </MudCard>

                    <!-- Featured Image card -->
                    <MudCard Elevation="2" Class="mb-4">
                        <MudCardHeader>
                            <CardHeaderContent>
                                <MudText Typo="Typo.subtitle2">
                                    <MudIcon Icon="@Icons.Material.Filled.Image" Size="Size.Small" Class="mr-1" />
                                    Featured Image
                                </MudText>
                            </CardHeaderContent>
                        </MudCardHeader>
                        <MudCardContent>
                            @if (!string.IsNullOrWhiteSpace(_postFeaturedImage))
                            {
                                <img src="@_postFeaturedImage" alt="Featured image preview"
                                     style="width:100%;max-height:160px;object-fit:cover;border-radius:4px;margin-bottom:8px;" />
                            }
                            <MudTextField @bind-Value="_postFeaturedImage" Label="Featured Image URL"
                                          Variant="Variant.Outlined"
                                          HelperText="Full URL to the hero image (recommended 1200×630)" />
                        </MudCardContent>
                    </MudCard>

                    <!-- SEO card -->
                    <MudExpansionPanel Text="SEO & Social" Icon="@Icons.Material.Filled.TravelExplore"
                                       Class="mb-4">
                        <MudStack Spacing="3" Class="pa-2">
                            <MudTextField @bind-Value="_postMetaTitle" Label="Meta Title"
                                          Variant="Variant.Outlined"
                                          HelperText="Leave blank to use the post title" />
                            <MudTextField @bind-Value="_postMetaDescription" Label="Meta Description"
                                          Variant="Variant.Outlined" Lines="2"
                                          HelperText="Leave blank to use the excerpt" />
                            <MudTextField @bind-Value="_postOgImage" Label="OG Image URL"
                                          Variant="Variant.Outlined"
                                          HelperText="Leave blank to use featured image" />
                            <MudTextField @bind-Value="_postCanonicalUrl" Label="Canonical URL"
                                          Variant="Variant.Outlined"
                                          HelperText="Leave blank to use the current URL" />
                        </MudStack>
                    </MudExpansionPanel>

                </MudItem>
            }

        </MudGrid>
    </MudTabPanel>

    <!-- ── Pages tab ──────────────────────────────────────── -->
    <MudTabPanel Text="Pages" Icon="@Icons.Material.Filled.Pages">
        <MudGrid Class="mt-4">

            @if (!_pageShowEditor)
            {
                <!-- ── Pages: list view ── -->
