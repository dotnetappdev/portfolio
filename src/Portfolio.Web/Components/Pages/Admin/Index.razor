                                              Style="font-size:1.4rem;font-weight:600;" />
                                <MudStack Row="true" AlignItems="AlignItems.Center" Class="mt-1 mb-2" Spacing="1">
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">Permalink:</MudText>
                                    <MudTextField @bind-Value="_pageSlug" Required="true"
                                                  RequiredError="Slug is required"
                                                  Variant="Variant.Text" Margin="Margin.Dense"
                                                  Typo="Typo.caption"
                                                  Style="max-width:320px;"
                                                  HelperText="e.g. my-custom-page → /my-custom-page" />
                                </MudStack>
                            </MudCardContent>
                        </MudCard>

                        <!-- Body -->
                        <MudCard Elevation="2" Class="mb-4">
                            <MudCardContent>
                                <MudText Typo="Typo.subtitle2" Class="mb-2">Content</MudText>
                                <RichTextEditor @ref="_pageBodyEditor" Placeholder="Write your page content here…" />
                            </MudCardContent>
                        </MudCard>
                    </MudForm>
                </MudItem>

                <!-- Sidebar -->
                <MudItem xs="12" md="4">

                    <!-- Publish card -->
                    <MudCard Elevation="2" Class="mb-4">
                        <MudCardHeader>
                            <CardHeaderContent>
                                <MudText Typo="Typo.subtitle2">
                                    <MudIcon Icon="@Icons.Material.Filled.Publish" Size="Size.Small" Class="mr-1" />
                                    Publish
                                </MudText>
                            </CardHeaderContent>
                        </MudCardHeader>
                        <MudCardContent>
                            <MudStack Spacing="2">
                                <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                                    <MudText Typo="Typo.body2">Status</MudText>
                                    <MudChip T="string" Size="Size.Small"
                                             Color="@(_pageIsPublished ? Color.Success : Color.Default)"
                                             Variant="@(_pageIsPublished ? Variant.Filled : Variant.Outlined)">
                                        @(_pageIsPublished ? "Published" : "Draft")
                                    </MudChip>
                                </MudStack>
                                <MudSwitch @bind-Value="_pageIsPublished" Label="@(_pageIsPublished ? "Published" : "Save as Draft")"
                                           Color="Color.Success" />
                                <MudTextField @bind-Value="_pagePublishedDateStr" Label="Publish Date"
                                              InputType="InputType.Date" Variant="Variant.Outlined"
                                              Margin="Margin.Dense" />
                            </MudStack>
                        </MudCardContent>
                        <MudCardActions>
                            <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true"
                                       OnClick="@SavePage" Disabled="@_savingPage"
                                       StartIcon="@Icons.Material.Filled.Save">
                                @(_savingPage ? "Saving…" : (_editingPage == null ? (_pageIsPublished ? "Publish" : "Save Draft") : "Update"))
                            </MudButton>
                        </MudCardActions>
                    </MudCard>

                    <!-- Featured Image card -->
                    <MudCard Elevation="2" Class="mb-4">
                        <MudCardHeader>
                            <CardHeaderContent>
                                <MudText Typo="Typo.subtitle2">
                                    <MudIcon Icon="@Icons.Material.Filled.Image" Size="Size.Small" Class="mr-1" />
                                    Featured Image
                                </MudText>
                            </CardHeaderContent>
                        </MudCardHeader>
                        <MudCardContent>
                            @if (!string.IsNullOrWhiteSpace(_pageFeaturedImage))
                            {
                                <img src="@_pageFeaturedImage" alt="Featured image preview"
                                     style="width:100%;max-height:160px;object-fit:cover;border-radius:4px;margin-bottom:8px;" />
                            }
                            <MudTextField @bind-Value="_pageFeaturedImage" Label="Featured Image URL"
                                          Variant="Variant.Outlined"
                                          HelperText="Full URL to the hero image" />
                        </MudCardContent>
                    </MudCard>

                    <!-- SEO card -->
                    <MudExpansionPanel Text="SEO & Social" Icon="@Icons.Material.Filled.TravelExplore"
                                       Class="mb-4">
                        <MudStack Spacing="3" Class="pa-2">
                            <MudTextField @bind-Value="_pageMetaTitle" Label="Meta Title"
                                          Variant="Variant.Outlined"
                                          HelperText="Leave blank to use the page title" />
                            <MudTextField @bind-Value="_pageMetaDescription" Label="Meta Description"
                                          Variant="Variant.Outlined" Lines="2"
                                          HelperText="Shown in search results (150–160 characters)" />
                            <MudTextField @bind-Value="_pageOgImage" Label="OG Image URL"
                                          Variant="Variant.Outlined"
                                          HelperText="Leave blank to use featured image" />
                            <MudTextField @bind-Value="_pageCanonicalUrl" Label="Canonical URL"
                                          Variant="Variant.Outlined"
                                          HelperText="Leave blank to use the current URL" />
                        </MudStack>
                    </MudExpansionPanel>

                </MudItem>
            }

        </MudGrid>
    </MudTabPanel>

    <!-- ── Menus tab ───────────────────────────────────────── -->
    <MudTabPanel Text="Menus" Icon="@Icons.Material.Filled.Menu">
        <MudGrid Class="mt-4">

            <!-- Add / edit form -->
            <MudItem xs="12" md="5">
                <MudCard Elevation="3">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6">
                                <MudIcon Icon="@(_editingMenuItem == null ? Icons.Material.Filled.AddLink : Icons.Material.Filled.Edit)" Class="mr-2" />
                                @(_editingMenuItem == null ? "Add Menu Item" : "Edit Menu Item")
                            </MudText>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent>
                        <MudForm @ref="_menuForm" @bind-IsValid="_menuFormValid">
                            <MudTextField @bind-Value="_menuLabel" Label="Label" Required="true"
                                          RequiredError="Label is required"
                                          Variant="Variant.Outlined" Class="mb-3" />
                            <MudTextField @bind-Value="_menuUrl" Label="URL" Required="true"
                                          RequiredError="URL is required"
                                          Variant="Variant.Outlined" Class="mb-3"
                                          HelperText="Use /path for internal, https:// for external" />
                            <MudSelect @bind-Value="_menuIcon" Label="Icon" Variant="Variant.Outlined" Class="mb-3">
                                <MudSelectItem Value="@("NavigateNext")">Default arrow</MudSelectItem>
                                <MudSelectItem Value="@("Home")">Home</MudSelectItem>
                                <MudSelectItem Value="@("Apps")">Apps/Projects</MudSelectItem>
                                <MudSelectItem Value="@("Code")">Code/Skills</MudSelectItem>
                                <MudSelectItem Value="@("Person")">Person/About</MudSelectItem>
                                <MudSelectItem Value="@("Article")">Article/Blog</MudSelectItem>
                                <MudSelectItem Value="@("Email")">Email/Contact</MudSelectItem>
                                <MudSelectItem Value="@("Pages")">Page</MudSelectItem>
                                <MudSelectItem Value="@("Description")">Document</MudSelectItem>
                                <MudSelectItem Value="@("Link")">External Link</MudSelectItem>
                            </MudSelect>
                            <MudNumericField @bind-Value="_menuSortOrder" Label="Sort Order"
                                             Variant="Variant.Outlined" Class="mb-3" Min="1" />
                            <MudSwitch @bind-Value="_menuIsVisible" Label="Visible in navigation"
                                       Color="Color.Success" Class="mb-2" />
                            <MudSwitch @bind-Value="_menuOpenInNewTab" Label="Open in new tab"
                                       Color="Color.Info" />
                        </MudForm>
                    </MudCardContent>
                    <MudCardActions>
                        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                                   OnClick="@SaveMenuItem" Disabled="@_savingMenuItem"
                                   StartIcon="@Icons.Material.Filled.Save">
                            @(_savingMenuItem ? "Saving..." : (_editingMenuItem == null ? "Add Item" : "Save Changes"))
                        </MudButton>
                        @if (_editingMenuItem != null)
                        {
                            <MudButton Variant="Variant.Text" Color="Color.Default"
                                       OnClick="@CancelEditMenuItem" Class="ml-2">Cancel</MudButton>
                        }
                    </MudCardActions>
                </MudCard>
            </MudItem>

            <!-- Menu item list -->
            <MudItem xs="12" md="7">
                <MudCard Elevation="3">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6">
                                <MudIcon Icon="@Icons.Material.Filled.List" Class="mr-2" />
                                Navigation Menu
                            </MudText>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent>
                        @if (_menuItems == null)
                        {
                            <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
                        }
                        else if (_menuItems.Count == 0)
                        {
                            <MudText Color="Color.Secondary">No menu items yet.</MudText>
                        }
                        else
                        {
                            <MudList T="string" Dense="true">
                                @foreach (var item in _menuItems.OrderBy(m => m.SortOrder))
                                {
                                    <MudListItem>
                                        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                                <MudText Typo="Typo.caption" Color="Color.Secondary" Style="min-width:24px;">@item.SortOrder</MudText>
                                                <MudStack Spacing="0">
                                                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                                        <MudText Typo="Typo.body2" Class="fw-bold">@item.Label</MudText>
                                                        @if (!item.IsVisible)
                                                        {
                                                            <MudChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Outlined">hidden</MudChip>
                                                        }
                                                        @if (item.OpenInNewTab)
                                                        {
                                                            <MudIcon Icon="@Icons.Material.Filled.OpenInNew" Size="Size.Small" Color="Color.Secondary" />
                                                        }
                                                    </MudStack>
                                                    <MudText Typo="Typo.caption" Color="Color.Secondary">@item.Url</MudText>
                                                </MudStack>
                                            </MudStack>
                                            <MudStack Row="true" Spacing="0">
                                                <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                                               Size="Size.Small" Color="Color.Primary"
                                                               OnClick="@(() => StartEditMenuItem(item))"
                                                               aria-label="Edit menu item" />
                                                <MudIconButton Icon="@(item.IsVisible ? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility)"
                                                               Size="Size.Small" Color="Color.Secondary"
                                                               OnClick="@(() => ToggleMenuItemVisibility(item))"
                                                               aria-label="Toggle visibility" />
                                                <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                                               Size="Size.Small" Color="Color.Error"
                                                               OnClick="@(() => DeleteMenuItem(item.Id))"
                                                               aria-label="Delete menu item" />
                                            </MudStack>
                                        </MudStack>
                                    </MudListItem>
                                }
                            </MudList>
                        }
                    </MudCardContent>
                </MudCard>
            </MudItem>

        </MudGrid>
    </MudTabPanel>

    <!-- ── Projects tab ───────────────────────────────────── -->
    <MudTabPanel Text="Projects" Icon="@Icons.Material.Filled.Apps">
        <MudGrid Class="mt-4">

            @if (!_projectShowEditor)
            {
                <!-- ── Projects: list view ── -->
                <MudItem xs="12">
                    <MudCard Elevation="3">
                        <MudCardHeader>
                            <CardHeaderContent>
                                <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                                    <MudText Typo="Typo.h6">
                                        <MudIcon Icon="@Icons.Material.Filled.Apps" Class="mr-2" />
                                        Projects
                                        @if (_projects != null)
                                        {
                                            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="ml-2">(@_projects.Count total)</MudText>
                                        }
                                    </MudText>
                                    <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
                                               StartIcon="@Icons.Material.Filled.Add"
                                               OnClick="@OpenNewProjectEditor">
                                        Add New Project
                                    </MudButton>
                                </MudStack>
                            </CardHeaderContent>
                        </MudCardHeader>
                        <MudCardContent>
                            @if (_projects == null)
                            {
                                <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
                            }
                            else if (_projects.Count == 0)
                            {
                                <MudText Color="Color.Secondary" Class="pa-4">No projects yet. Add one using the button above.</MudText>
                            }
                            else
                            {
                                <MudTable Items="@_projects" Hover="true" Dense="true" Breakpoint="Breakpoint.Sm"
                                          RowsPerPage="10">
                                    <HeaderContent>
                                        <MudTh>Title</MudTh>
                                        <MudTh>Category</MudTh>
                                        <MudTh>GitHub</MudTh>
                                        <MudTh>Featured</MudTh>
                                        <MudTh>Order</MudTh>
                                        <MudTh>Actions</MudTh>
                                    </HeaderContent>
                                    <RowTemplate>
                                        <MudTd DataLabel="Title">
                                            <MudStack Spacing="0">
                                                <MudText Typo="Typo.body2" Class="fw-bold">@context.Title</MudText>
                                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                                    <MudText Typo="Typo.caption" Color="Color.Secondary">/projects/@context.Slug</MudText>
                                                    {
                                                        <MudLink Href="@($"/projects/{context.Slug}")" Target="_blank"
                                                                 Typo="Typo.caption" Color="Color.Primary" Style="font-size:0.7rem;">
                                                            View ↗
                                                        </MudLink>
                                                    }
                                                </MudStack>
                                            </MudStack>
                                        </MudTd>
                                        <MudTd DataLabel="Category">
                                            <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Outlined">@context.Category</MudChip>
                                        </MudTd>
                                        <MudTd DataLabel="GitHub">
                                            @if (!string.IsNullOrWhiteSpace(context.GitHubUrl))
                                            {
                                                <MudLink Href="@context.GitHubUrl" Target="_blank" Color="Color.Default">
                                                    <MudIcon Icon="@Icons.Custom.Brands.GitHub" Size="Size.Small" Class="mr-1" />
                                                    View
                                                </MudLink>
                                            }
                                            else
                                            {
                                                <MudText Typo="Typo.caption" Color="Color.Secondary">—</MudText>
                                            }
                                        </MudTd>
                                        <MudTd DataLabel="Featured">
                                            @if (context.IsFeatured)
                                            {
                                                <MudChip T="string" Size="Size.Small" Color="Color.Warning" Variant="Variant.Filled">Featured</MudChip>
                                            }
                                        </MudTd>
                                        <MudTd DataLabel="Order">@context.SortOrder</MudTd>
                                        <MudTd DataLabel="Actions">
                                            <MudStack Row="true" Spacing="0">
                                                <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                                               Size="Size.Small" Color="Color.Primary"
                                                               OnClick="@(() => StartEditProject(context))"
                                                               aria-label="Edit project" />
                                                <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                                               Size="Size.Small" Color="Color.Error"
                                                               OnClick="@(() => DeleteProject(context.Id))"
                                                               aria-label="Delete project" />
                                            </MudStack>
                                        </MudTd>
                                    </RowTemplate>
                                    <PagerContent>
                                        <MudTablePager PageSizeOptions="new int[] { 5, 10, 25 }" />
                                    </PagerContent>
                                </MudTable>
                            }
                        </MudCardContent>
                    </MudCard>
                </MudItem>
            }
            else
            {
                <!-- ── Projects: editor view ── -->
                <MudItem xs="12">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-3" Spacing="1">
                        <MudButton Variant="Variant.Text" Color="Color.Default" Size="Size.Small"
                                   StartIcon="@Icons.Material.Filled.ArrowBack"
                                   OnClick="@CancelEditProject">
                            ← Projects
                        </MudButton>
                        <MudText Typo="Typo.h6">
                            @(_editingProject == null ? "Add New Project" : "Edit Project")
                        </MudText>
                    </MudStack>
                </MudItem>

                <MudItem xs="12" md="8">
                    <MudForm @ref="_projectForm" @bind-IsValid="_projectFormValid">
                        <!-- Title, Slug & Short Description -->
                        <MudCard Elevation="2" Class="mb-4">
                            <MudCardContent Class="pb-0">
                                <MudTextField @bind-Value="_projectTitle" Label="Project Title" Required="true"
                                              RequiredError="Title is required"
                                              Variant="Variant.Outlined" Class="mb-2"
                                              Typo="Typo.h5"
                                              OnBlur="@GenerateProjectSlugFromTitle"
                                              Style="font-size:1.4rem;font-weight:600;" />
                                <MudStack Row="true" AlignItems="AlignItems.Center" Class="mt-1 mb-3" Spacing="1">
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">Permalink: /projects/</MudText>
                                    <MudTextField @bind-Value="_projectSlug" Required="true"
                                                  RequiredError="Slug is required"
                                                  Variant="Variant.Text" Margin="Margin.Dense"
                                                  Typo="Typo.caption"
                                                  Style="max-width:320px;"
                                                  HelperText="SEO-friendly URL slug, e.g. bookit" />
                                </MudStack>
                                <MudTextField @bind-Value="_projectShortDescription" Label="Short Description" Required="true"
                                              RequiredError="Short description is required"
                                              Variant="Variant.Outlined" Class="mb-3"
                                              HelperText="Used on listing cards — keep it under 100 characters." />
                            </MudCardContent>
                        </MudCard>

                        <!-- Full Description -->
                        <MudCard Elevation="2" Class="mb-4">
                            <MudCardContent>
                                <MudText Typo="Typo.subtitle2" Class="mb-2">Full Description</MudText>
                                <MudTextField @bind-Value="_projectDescription" Label="Description" Required="true"
                                              RequiredError="Description is required"
                                              Variant="Variant.Outlined" Lines="5" />
                            </MudCardContent>
                        </MudCard>

                        <!-- Tech Stack -->
                        <MudCard Elevation="2" Class="mb-4">
                            <MudCardContent>
                                <MudTextField @bind-Value="_projectTechStack" Label="Tech Stack"
                                              Variant="Variant.Outlined"
                                              HelperText="Comma-separated, e.g. Blazor, ASP.NET Core, SQL Server" />
                            </MudCardContent>
                        </MudCard>
                    </MudForm>
                </MudItem>

                <!-- Sidebar -->
                <MudItem xs="12" md="4">

                    <!-- Save card -->
                    <MudCard Elevation="2" Class="mb-4">
                        <MudCardHeader>
                            <CardHeaderContent>
                                <MudText Typo="Typo.subtitle2">
                                    <MudIcon Icon="@Icons.Material.Filled.Save" Size="Size.Small" Class="mr-1" />
                                    Save
                                </MudText>
                            </CardHeaderContent>
                        </MudCardHeader>
                        <MudCardActions>
                            <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true"
                                       OnClick="@SaveProject" Disabled="@_savingProject"
                                       StartIcon="@Icons.Material.Filled.Save">
                                @(_savingProject ? "Saving…" : (_editingProject == null ? "Add Project" : "Save Changes"))
                            </MudButton>
                        </MudCardActions>
                    </MudCard>

                    <!-- Project Settings -->
                    <MudCard Elevation="2" Class="mb-4">
                        <MudCardHeader>
                            <CardHeaderContent>
                                <MudText Typo="Typo.subtitle2">
                                    <MudIcon Icon="@Icons.Material.Filled.Tune" Size="Size.Small" Class="mr-1" />
                                    Project Settings
                                </MudText>
                            </CardHeaderContent>
                        </MudCardHeader>
                        <MudCardContent>
                            <MudTextField @bind-Value="_projectCategory" Label="Category" Required="true"
                                          RequiredError="Category is required"
                                          Variant="Variant.Outlined" Class="mb-3"
                                          HelperText="e.g. Work Project, Healthcare, AI, Security" />
                            <MudNumericField @bind-Value="_projectSortOrder" Label="Sort Order"
                                             Variant="Variant.Outlined" Class="mb-3" Min="1"
                                             HelperText="Lower numbers appear first" />
                            <MudSwitch @bind-Value="_projectIsFeatured" Label="@(_projectIsFeatured ? "Featured on home page" : "Not featured")"
                                       Color="Color.Warning" />
                        </MudCardContent>
                    </MudCard>

                    <!-- GitHub & Live URL card -->
                    <MudCard Elevation="2" Class="mb-4">
                        <MudCardHeader>
                            <CardHeaderContent>
                                <MudText Typo="Typo.subtitle2">
                                    <MudIcon Icon="@Icons.Custom.Brands.GitHub" Size="Size.Small" Class="mr-1" />
                                    Links
                                </MudText>
                            </CardHeaderContent>
                        </MudCardHeader>
                        <MudCardContent>
                            <!-- GitHub URL with validate button -->
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1" Class="mb-3">
                                <MudTextField @bind-Value="_projectGitHubUrl" Label="GitHub Repository URL"
                                              Variant="Variant.Outlined" FullWidth="true"
                                              Placeholder="https://github.com/username/repo"
                                              HelperText="Optional — shown as a GitHub button on project cards" />
                                <MudTooltip Text="Open GitHub URL in new tab to validate">
                                    <MudIconButton Icon="@Icons.Material.Filled.OpenInNew"
                                                   Color="Color.Default" Size="Size.Medium"
                                                   Disabled="@string.IsNullOrWhiteSpace(_projectGitHubUrl)"
                                                   OnClick="@(() => ValidateUrl(_projectGitHubUrl))"
                                                   aria-label="Validate GitHub URL" />
                                </MudTooltip>
                            </MudStack>

                            <!-- Live URL with validate button -->
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1" Class="mb-3">
                                <MudTextField @bind-Value="_projectLiveUrl" Label="Live Demo URL"
                                              Variant="Variant.Outlined" FullWidth="true"
                                              Placeholder="https://example.com"
                                              HelperText="Optional — shown as a Live Demo button on project cards" />
                                <MudTooltip Text="Open Live URL in new tab to validate">
                                    <MudIconButton Icon="@Icons.Material.Filled.OpenInNew"
                                                   Color="Color.Default" Size="Size.Medium"
                                                   Disabled="@string.IsNullOrWhiteSpace(_projectLiveUrl)"
                                                   OnClick="@(() => ValidateUrl(_projectLiveUrl))"
                                                   aria-label="Validate live URL" />
                                </MudTooltip>
                            </MudStack>

                            <!-- Image URL -->
                            <MudTextField @bind-Value="_projectImageUrl" Label="Image URL"
                                          Variant="Variant.Outlined"
                                          Placeholder="/images/project.png"
                                          HelperText="Optional project image" />
                        </MudCardContent>
                    </MudCard>

                </MudItem>
            }

        </MudGrid>
    </MudTabPanel>

    <!-- ── Static Site tab ─────────────────────────────────── -->
    <MudTabPanel Text="Static Site" Icon="@Icons.Material.Filled.Download">
        <MudGrid Class="mt-4">
            <MudItem xs="12" md="8">
                <MudCard Elevation="3">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6">
                                <MudIcon Icon="@Icons.Material.Filled.FolderZip" Class="mr-2" />
                                Generate Static Site
                            </MudText>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent>
                        <MudText Typo="Typo.body1" Class="mb-3">
                            Generate a complete, self-contained static HTML snapshot of your portfolio, dark mode by default,
                            with all blog posts, projects, skills, and CMS pages baked in. The result is a ZIP file ready
                            to deploy to GitHub Pages, Netlify, Azure Static Web Apps, or any static host.
                        </MudText>
                        <MudList T="string" Dense="true" Class="mb-4">
                            <MudListItem Icon="@Icons.Material.Filled.CheckCircle" IconColor="Color.Success">Home, About, Projects, Skills, Contact pages</MudListItem>
                            <MudListItem Icon="@Icons.Material.Filled.CheckCircle" IconColor="Color.Success">Blog listing and individual post pages</MudListItem>
                            <MudListItem Icon="@Icons.Material.Filled.CheckCircle" IconColor="Color.Success">All custom CMS pages</MudListItem>
                            <MudListItem Icon="@Icons.Material.Filled.CheckCircle" IconColor="Color.Success">Dark mode by default with the portfolio brand theme</MudListItem>
                            <MudListItem Icon="@Icons.Material.Filled.CheckCircle" IconColor="Color.Success">Responsive navigation with mobile hamburger menu</MudListItem>
                            <MudListItem Icon="@Icons.Material.Filled.CheckCircle" IconColor="Color.Success">Technology chips on projects and blog posts</MudListItem>
                            <MudListItem Icon="@Icons.Material.Filled.CheckCircle" IconColor="Color.Success">Project images and featured images included</MudListItem>
                        </MudList>
                        @if (_generatingStaticSite)
                        {
                            <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="mb-3" />
                            <MudText Typo="Typo.body2" Color="Color.Secondary">Generating static site, this may take a few seconds…</MudText>
                        }
                        else if (!string.IsNullOrEmpty(_staticSiteMessage))
                        {
                            <MudAlert Severity="@_staticSiteSeverity" Class="mb-3">@_staticSiteMessage</MudAlert>
                        }
                    </MudCardContent>
                    <MudCardActions>
                        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                                   OnClick="@GenerateStaticSite"
                                   Disabled="@_generatingStaticSite"
                                   StartIcon="@Icons.Material.Filled.FolderZip">
                            @(_generatingStaticSite ? "Generating…" : "Generate & Download ZIP")
