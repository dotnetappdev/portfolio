    private async Task StartEditPage(Portfolio.Shared.Models.CmsPageDto page)
    {
        _editingPage         = page;
        _pageTitle           = page.Title;
        _pageSlug            = page.Slug;
        _pageIsPublished     = page.IsPublished;
        _pagePublishedDateStr = page.PublishedDate.ToString("yyyy-MM-dd");
        _pageFeaturedImage   = page.FeaturedImage;
        _pageMetaTitle       = page.MetaTitle;
        _pageMetaDescription = page.MetaDescription;
        _pageOgImage         = page.OgImage;
