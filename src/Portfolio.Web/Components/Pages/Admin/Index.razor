    private static string FormatFileSize(long bytes)
    {
        if (bytes < 1024)               return $"{bytes} B";
        if (bytes < 1024 * 1024)        return $"{bytes / 1024.0:F1} KB";
        if (bytes < 1024 * 1024 * 1024) return $"{bytes / (1024.0 * 1024):F1} MB";
        return $"{bytes / (1024.0 * 1024 * 1024):F1} GB";
    }

    // ── Static Site Generator ────────────────────────────────
    private bool _generatingStaticSite;
    private string _staticSiteMessage = string.Empty;
    private Severity _staticSiteSeverity = Severity.Success;

    private async Task GenerateStaticSite()
    {
        _generatingStaticSite = true;
        _staticSiteMessage = string.Empty;
        StateHasChanged();

        try
        {
            var bytes = await StaticSiteGenerator.GenerateAsync();
            var timestamp = DateTime.UtcNow.ToString("yyyyMMdd-HHmm");
            var fileName = $"portfolio-static-{timestamp}.zip";

            // Trigger browser download via a data URI — avoids needing a separate HTTP round-trip
            // while staying inside the Blazor Server circuit.
            var base64 = Convert.ToBase64String(bytes);
            await JSRuntime.InvokeVoidAsync("downloadFileFromBase64", fileName, "application/zip", base64);

            _staticSiteMessage = $"Static site generated successfully ({bytes.Length / 1024:N0} KB). Your download should start automatically.";
            _staticSiteSeverity = Severity.Success;
            Snackbar.Add($"Static site ZIP downloaded ({bytes.Length / 1024:N0} KB).", Severity.Success);
        }
        catch (Exception ex)
        {
            _staticSiteMessage = $"Generation failed: {ex.Message}";
            _staticSiteSeverity = Severity.Error;
            Snackbar.Add("Static site generation failed. See the error message for details.", Severity.Error);
        }
        finally
        {
            _generatingStaticSite = false;
        }
    }
