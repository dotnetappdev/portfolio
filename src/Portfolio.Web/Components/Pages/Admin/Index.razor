    // ── Mail Settings ────────────────────────────────────────
    private Portfolio.Web.Data.MailSettings? _mailSettings;
    private bool _savingMail;
    private bool _sendingTestEmail;
    private bool _showSmtpPassword;

    private async Task SaveMailSettings()
    {
        if (_mailSettings == null) return;
        _savingMail = true;

        if (_mailSettings.Id == 0)
            DbContext.MailSettings.Add(_mailSettings);
        else
            DbContext.MailSettings.Update(_mailSettings);

        await DbContext.SaveChangesAsync();
        _savingMail = false;
        Snackbar.Add("Mail settings saved.", Severity.Success);
    }

    private async Task SendTestEmail()
    {
        if (_mailSettings == null || string.IsNullOrWhiteSpace(_mailSettings.FromAddress))
        {
            Snackbar.Add("Set a From Address before sending a test email.", Severity.Warning);
            return;
        }

        _sendingTestEmail = true;
        await SaveMailSettings();

        var ok = await EmailSender.SendTestAsync(_mailSettings.FromAddress);
        _sendingTestEmail = false;

        if (ok)
            Snackbar.Add("Test email sent successfully.", Severity.Success);
        else
            Snackbar.Add("Failed to send test email — check the SMTP settings and server logs.", Severity.Error);
    }

    // ── SMS Settings ────────────────────────────────────────
    private Portfolio.Web.Data.SmsSettings? _smsSettings;
    private bool _savingSms;
    private bool _sendingTestSms;
    private bool _showTwilioToken;
    private bool _showClickSendKey;

    private async Task SaveSmsSettings()
    {
        if (_smsSettings == null) return;
        _savingSms = true;

        if (_smsSettings.Id == 0)
            DbContext.SmsSettings.Add(_smsSettings);
        else
            DbContext.SmsSettings.Update(_smsSettings);

        await DbContext.SaveChangesAsync();
        _savingSms = false;
        Snackbar.Add("SMS settings saved.", Severity.Success);
    }

    private async Task SendTestSms()
    {
        if (_smsSettings == null || string.IsNullOrWhiteSpace(_smsSettings.AdminReceiverNumber))
        {
            Snackbar.Add("Set an admin receiver number before sending a test.", Severity.Warning);
            return;
        }

        _sendingTestSms = true;
        // Persist first so SmsSender reads the latest values
        await SaveSmsSettings();

        var result = await SmsSender.SendToAdminAsync("Test SMS from Portfolio admin: everything is working!");
        _sendingTestSms = false;

        if (result.Succeeded)
            Snackbar.Add($"Test SMS sent (id: {result.MessageId ?? "n/a"}).", Severity.Success);
        else
            Snackbar.Add($"Test SMS failed: {result.Error}", Severity.Error);
    }

    // ── Static Site Generator ────────────────────────────────
    private bool _generatingStaticSite;
    private string _staticSiteMessage = string.Empty;
    private Severity _staticSiteSeverity = Severity.Success;

    private async Task GenerateStaticSite()
    {
        _generatingStaticSite = true;
        _staticSiteMessage = string.Empty;
        StateHasChanged();

        try
        {
            var bytes = await StaticSiteGenerator.GenerateAsync();
            var timestamp = DateTime.UtcNow.ToString("yyyyMMdd-HHmm");
            var fileName = $"portfolio-static-{timestamp}.zip";

            // Trigger browser download via a data URI — avoids needing a separate HTTP round-trip
            // while staying inside the Blazor Server circuit.
            var base64 = Convert.ToBase64String(bytes);
            await JSRuntime.InvokeVoidAsync("downloadFileFromBase64", fileName, "application/zip", base64);

            _staticSiteMessage = $"Static site generated successfully ({bytes.Length / 1024:N0} KB). Your download should start automatically.";
            _staticSiteSeverity = Severity.Success;
            Snackbar.Add($"Static site ZIP downloaded ({bytes.Length / 1024:N0} KB).", Severity.Success);
        }
        catch (Exception ex)
        {
            _staticSiteMessage = $"Generation failed: {ex.Message}";
            _staticSiteSeverity = Severity.Error;
            Snackbar.Add("Static site generation failed. See the error message for details.", Severity.Error);
        }
        finally
        {
            _generatingStaticSite = false;
        }
    }
