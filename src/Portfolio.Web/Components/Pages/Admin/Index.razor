    private static string? NullIfEmpty(string? value) =>
        string.IsNullOrWhiteSpace(value) ? null : value;

    private void AddMediaItem(string type)
    {
        _postMediaItems.Add(new BlogMediaItem
        {
            Type      = type,
            Position  = "after_article",
            SortOrder = _postMediaItems.Count
        });
    }

    private void RemoveMediaItem(int index)
    {
        if (index >= 0 && index < _postMediaItems.Count)
            _postMediaItems.RemoveAt(index);
    }

    private void MoveMediaItem(int index, int direction)
    {
        var target = index + direction;
        if (target < 0 || target >= _postMediaItems.Count) return;
        (_postMediaItems[index], _postMediaItems[target]) = (_postMediaItems[target], _postMediaItems[index]);
    }

    private void DropMediaItem(int toIndex)
    {
        if (_dragFromIndex < 0 || _dragFromIndex == toIndex)
        {
            _dragFromIndex = -1;
            return;
        }
        var item = _postMediaItems[_dragFromIndex];
        _postMediaItems.RemoveAt(_dragFromIndex);
        _postMediaItems.Insert(toIndex, item);
        _dragFromIndex = -1;
    }

    private static List<BlogMediaItem> NormaliseSortOrder(List<BlogMediaItem> items)
    {
        for (int i = 0; i < items.Count; i++) items[i].SortOrder = i;
        return items;
    }

    /// <summary>Converts the legacy newline-separated GalleryImages string into MediaItems (all "after_article" images).</summary>
    private static List<BlogMediaItem> MigrateGalleryImagesToMediaItems(string? galleryImages)
    {
        if (string.IsNullOrWhiteSpace(galleryImages)) return [];
        return galleryImages
            .Split('\n', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .Select((url, i) => new BlogMediaItem { Url = url, Type = "image", Position = "after_article", SortOrder = i })
            .ToList();
    }

    private static DateTime ParseDate(string dateStr) =>
        DateTime.TryParse(dateStr, out var dt)
            ? DateTime.SpecifyKind(dt, DateTimeKind.Utc)
            : DateTime.UtcNow;

