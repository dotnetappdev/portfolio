    private async Task CancelEditPage()
    {
        // Setting _pageShowEditor = false unmounts the RichTextEditor component, which
        // automatically discards its content. No LoadAsync call is needed or safe here.
        _pageShowEditor      = false;
        _editingPage         = null;
        _pageTitle           = string.Empty;
        _pageSlug            = string.Empty;
        _pageIsPublished     = true;
        _pagePublishedDateStr = DateTime.Today.ToString("yyyy-MM-dd");
        _pageFeaturedImage   = null;
        _pageMetaTitle       = null;
        _pageMetaDescription = null;
        _pageOgImage         = null;
        _pageCanonicalUrl    = null;
        await Task.CompletedTask;
    }

    private async Task SavePage()
    {
        await _pageForm.ValidateAsync();
        if (!_pageFormValid) return;

        _savingPage = true;

        var body          = await _pageBodyEditor.GetValueAsync();
        var publishedDate = ParseDate(_pagePublishedDateStr);
        var token         = await GetAdminTokenAsync();

        if (_editingPage != null)
        {
            _editingPage.Title           = _pageTitle;
            _editingPage.Slug            = _pageSlug;
            _editingPage.Body            = body;
            _editingPage.IsPublished     = _pageIsPublished;
            _editingPage.PublishedDate   = publishedDate;
            _editingPage.FeaturedImage   = NullIfEmpty(_pageFeaturedImage);
            _editingPage.MetaTitle       = NullIfEmpty(_pageMetaTitle);
            _editingPage.MetaDescription = NullIfEmpty(_pageMetaDescription);
            _editingPage.OgImage         = NullIfEmpty(_pageOgImage);
            _editingPage.CanonicalUrl    = NullIfEmpty(_pageCanonicalUrl);
            await CmsPageService.UpdateAsync(_editingPage, token ?? string.Empty);
            Snackbar.Add("Page updated.", Severity.Success);
        }
        else
        {
            var newPage = new Portfolio.Shared.Models.CmsPageDto
            {
                Title           = _pageTitle,
                Slug            = _pageSlug,
                Body            = body,
                IsPublished     = _pageIsPublished,
                PublishedDate   = publishedDate,
                FeaturedImage   = NullIfEmpty(_pageFeaturedImage),
                MetaTitle       = NullIfEmpty(_pageMetaTitle),
                MetaDescription = NullIfEmpty(_pageMetaDescription),
                OgImage         = NullIfEmpty(_pageOgImage),
                CanonicalUrl    = NullIfEmpty(_pageCanonicalUrl)
            };
            await CmsPageService.CreateAsync(newPage, token ?? string.Empty);
            Snackbar.Add("Page created.", Severity.Success);
        }

        _cmsPages  = await CmsPageService.GetAllForAdminAsync(token ?? string.Empty);
        _savingPage = false;
        await CancelEditPage();
    }

