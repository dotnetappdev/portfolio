@page "/admin"
@rendermode InteractiveServer
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@using Portfolio.Web.Components.Shared
@using Portfolio.Shared.Models
@inject Portfolio.Web.Services.PortfolioApiAuthService ApiAuthService
@inject Portfolio.Web.Services.SmsSender SmsSender
@inject Portfolio.Web.Services.EmailSender EmailSender
@inject Portfolio.Web.Services.BlogService BlogService
@inject Portfolio.Web.Services.CmsPageService CmsPageService
@inject Portfolio.Web.Services.MenuService MenuService
@inject Portfolio.Web.Services.AppSettingsService AppSettingsService
@inject Portfolio.Web.Services.StaticSiteGeneratorService StaticSiteGenerator
@inject Portfolio.Web.Services.PortfolioApiService ApiService
@inject ISnackbar Snackbar
@inject IJSRuntime JSRuntime
@inject AuthenticationStateProvider AuthStateProvider
@inject IDialogService DialogService

<PageTitle>Admin | David Buckley Portfolio</PageTitle>

<div class="page-banner">
    <MudContainer MaxWidth="MaxWidth.ExtraLarge">
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
            <MudAvatar Color="Color.Primary" Size="Size.Large" Style="background:rgba(196,181,253,0.15);">
                <MudIcon Icon="@Icons.Material.Filled.AdminPanelSettings" Style="font-size:32px;" />
            </MudAvatar>
            <MudStack Spacing="0">
                <MudText Typo="Typo.h4" Class="fw-bold">Admin Dashboard</MudText>
                <MudText Typo="Typo.subtitle1">Manage users, hero stats, SMS settings and portfolio content</MudText>
            </MudStack>
        </MudStack>
    </MudContainer>
</div>

<div class="page-content">

<MudTabs Elevation="2" Rounded="true" ApplyEffectsToContainer="true" Class="mt-4">

    <!-- ── Hero Stats tab ──────────────────────────────── -->
    <MudTabPanel Text="Hero Stats" Icon="@Icons.Material.Filled.Dashboard">
        <MudGrid Class="mt-4">
            <MudItem xs="12" md="5">
                <MudCard Elevation="3">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6">
                                <MudIcon Icon="@(_editingStat == null ? Icons.Material.Filled.AddChart : Icons.Material.Filled.Edit)" Class="mr-2" />
                                @(_editingStat == null ? "Add New Stat Card" : "Edit Stat Card")
                            </MudText>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent>
                        <MudForm @ref="_statForm" @bind-IsValid="_statFormValid">
                            <MudTextField @bind-Value="_statValue" Label="Value (e.g. 30+, AI, £1M+)"
                                          Required="true" RequiredError="Value is required"
                                          Variant="Variant.Outlined" Class="mb-3" />
                            <MudTextField @bind-Value="_statLabel" Label="Label (e.g. Years in .NET)"
                                          Required="true" RequiredError="Label is required"
                                          Variant="Variant.Outlined" Class="mb-3" />
                            <MudSelect @bind-Value="_statColor" Label="Colour" Variant="Variant.Outlined" Class="mb-3">
                                <MudSelectItem Value="@("Primary")">Primary (Violet)</MudSelectItem>
                                <MudSelectItem Value="@("Secondary")">Secondary (Cyan)</MudSelectItem>
                                <MudSelectItem Value="@("Tertiary")">Tertiary (Emerald)</MudSelectItem>
                                <MudSelectItem Value="@("Error")">Error (Red)</MudSelectItem>
                                <MudSelectItem Value="@("Success")">Success (Green)</MudSelectItem>
                                <MudSelectItem Value="@("Warning")">Warning (Amber)</MudSelectItem>
                            </MudSelect>
                            <MudNumericField @bind-Value="_statSortOrder" Label="Sort Order"
                                             Variant="Variant.Outlined" Class="mb-3" Min="1" />
                        </MudForm>
                    </MudCardContent>
                    <MudCardActions>
                        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                                   OnClick="@SaveStat" Disabled="@_savingStat"
                                   StartIcon="@Icons.Material.Filled.Save">
                            @(_savingStat ? "Saving..." : (_editingStat == null ? "Add Stat" : "Save Changes"))
                        </MudButton>
                        @if (_editingStat != null)
                        {
                            <MudButton Variant="Variant.Text" Color="Color.Default"
                                       OnClick="@CancelEditStat" Class="ml-2">
                                Cancel
                            </MudButton>
                        }
                    </MudCardActions>
                </MudCard>
            </MudItem>

            <MudItem xs="12" md="7">
                <MudCard Elevation="3">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6">
                                <MudIcon Icon="@Icons.Material.Filled.ViewModule" Class="mr-2" />
                                Current Stat Cards
                            </MudText>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent>
                        @if (_heroStats == null)
                        {
                            <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
                        }
                        else if (_heroStats.Count == 0)
                        {
                            <MudText Color="Color.Secondary">No stat cards yet. Add one using the form.</MudText>
                        }
                        else
                        {
                            <MudList T="string" Dense="true">
                                @foreach (var stat in _heroStats.OrderBy(s => s.SortOrder))
                                {
                                    <MudListItem>
                                        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                                <MudChip T="string" Color="@GetMudColor(stat.Color)" Size="Size.Small" Variant="Variant.Filled">
                                                    @stat.Value
                                                </MudChip>
                                                <MudStack Spacing="0">
                                                    <MudText Typo="Typo.body2">@stat.Label</MudText>
                                                    <MudText Typo="Typo.caption" Color="Color.Secondary">Order: @stat.SortOrder · @stat.Color</MudText>
                                                </MudStack>
                                            </MudStack>
                                            <MudStack Row="true" Spacing="0">
                                                <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                                               Size="Size.Small" Color="Color.Primary"
                                                               OnClick="@(() => StartEditStat(stat))"
                                                               aria-label="Edit stat card" />
                                                <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                                               Size="Size.Small" Color="Color.Error"
                                                               OnClick="@(() => DeleteStat(stat.Id))"
                                                               aria-label="Delete stat card" />
                                            </MudStack>
                                        </MudStack>
                                    </MudListItem>
                                }
                            </MudList>
                        }
                    </MudCardContent>
                </MudCard>
            </MudItem>
        </MudGrid>
    </MudTabPanel>

    <!-- ── Users tab ──────────────────────────────────── -->
    <MudTabPanel Text="Users" Icon="@Icons.Material.Filled.People">
        <MudGrid Class="mt-4">

            <!-- ── Create / Edit User ── -->
            <MudItem xs="12" md="5">
                <MudCard Elevation="3">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6">
                                <MudIcon Icon="@(_editingUser == null ? Icons.Material.Filled.PersonAdd : Icons.Material.Filled.Edit)" Class="mr-2" />
                                @(_editingUser == null ? "Create New Account" : "Edit Account")
                            </MudText>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent>
                        <MudForm @ref="_form" @bind-IsValid="_isValid">
                            <MudTextField @bind-Value="_newUser.Email" Label="Email Address" Required="true"
                                          RequiredError="Email is required" InputType="InputType.Email"
                                          Variant="Variant.Outlined" Class="mb-3" />
                            <MudTextField @bind-Value="_firstName" Label="First Name"
                                          Variant="Variant.Outlined" Class="mb-3" />
                            <MudTextField @bind-Value="_lastName" Label="Last Name"
                                          Variant="Variant.Outlined" Class="mb-3" />
                            @if (_editingUser == null)
                            {
                                <MudTextField @bind-Value="_newUser.Password" Label="Password" Required="true"
                                              RequiredError="Password is required"
                                              InputType="@(_showPassword ? InputType.Text : InputType.Password)"
                                              Variant="Variant.Outlined" Class="mb-3"
                                              Adornment="Adornment.End"
                                              AdornmentIcon="@(_showPassword ? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility)"
                                              OnAdornmentClick="@(() => _showPassword = !_showPassword)"
                                              HelperText="Min 8 chars, must include uppercase, number and special character" />
                            }
                            else
                            {
                                <MudTextField @bind-Value="_newPassword" Label="New Password (leave blank to keep current)"
                                              InputType="@(_showPassword ? InputType.Text : InputType.Password)"
                                              Variant="Variant.Outlined" Class="mb-3"
                                              Adornment="Adornment.End"
                                              AdornmentIcon="@(_showPassword ? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility)"
                                              OnAdornmentClick="@(() => _showPassword = !_showPassword)" />
                            }
                        </MudForm>
                    </MudCardContent>
                    <MudCardActions>
                        @if (_editingUser == null)
                        {
                            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                                       OnClick="@HandleCreateUser" Disabled="@_creating"
                                       StartIcon="@Icons.Material.Filled.PersonAdd">
                                @(_creating ? "Creating..." : "Create Account")
                            </MudButton>
                        }
                        else
                        {
                            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                                       OnClick="@HandleUpdateUser" Disabled="@_creating"
                                       StartIcon="@Icons.Material.Filled.Save">
                                @(_creating ? "Saving..." : "Save Changes")
                            </MudButton>
                            <MudButton Variant="Variant.Text" Color="Color.Default"
                                       OnClick="@CancelEditUser" Class="ml-2">Cancel</MudButton>
                        }
                    </MudCardActions>
                </MudCard>

                <!-- ── Roles Management ── -->
                <MudCard Elevation="3" Class="mt-4">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6">
                                <MudIcon Icon="@Icons.Material.Filled.Badge" Class="mr-2" />
                                Roles Management
                            </MudText>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent>
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-3">
                            <MudTextField @bind-Value="_newRoleName" Label="New Role Name"
                                          Variant="Variant.Outlined" Style="flex:1" />
                            <MudButton Variant="Variant.Filled" Color="Color.Secondary"
                                       OnClick="@HandleCreateRole"
                                       StartIcon="@Icons.Material.Filled.Add">Add</MudButton>
                        </MudStack>
                        @if (_roles == null)
                        {
                            <MudProgressCircular Indeterminate="true" Color="Color.Primary" Size="Size.Small" />
                        }
                        else
                        {
                            <MudList T="string" Dense="true">
                                @foreach (var role in _roles)
                                {
                                    <MudListItem>
                                        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                                            <MudChip T="string" Color="Color.Primary" Size="Size.Small" Variant="Variant.Outlined">@role.Name</MudChip>
                                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error"
                                                           OnClick="@(() => HandleDeleteRole(role.Name))"
                                                           aria-label="@($"Delete role {role.Name}")" />
                                        </MudStack>
                                    </MudListItem>
                                }
                            </MudList>
                        }
                    </MudCardContent>
                </MudCard>
            </MudItem>

            <!-- ── Existing Users ── -->
            <MudItem xs="12" md="7">
                <MudCard Elevation="3">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6">
                                <MudIcon Icon="@Icons.Material.Filled.People" Class="mr-2" />
                                Application Users
                            </MudText>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent>
                        @if (_users == null)
                        {
                            <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
                        }
                        else
                        {
                            <MudList T="string">
                                @foreach (var user in _users)
                                {
                                    <MudListItem>
                                        <MudStack Spacing="1">
                                            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                                    <MudAvatar Color="Color.Primary" Size="Size.Small">
                                                        <MudIcon Icon="@Icons.Material.Filled.Person" />
                                                    </MudAvatar>
                                                    <MudStack Spacing="0">
                                                        <MudText Typo="Typo.body2">@user.Email</MudText>
                                                        @if (!string.IsNullOrEmpty(user.FirstName))
                                                        {
                                                            <MudText Typo="Typo.caption" Color="Color.Secondary">@user.FirstName @user.LastName</MudText>
                                                        }
                                                    </MudStack>
                                                </MudStack>
                                                <MudStack Row="true" Spacing="0">
                                                    <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Color="Color.Primary"
                                                                   OnClick="@(() => StartEditUser(user))"
                                                                   aria-label="Edit user" />
                                                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error"
                                                                   OnClick="@(() => HandleDeleteUser(user.Id))"
                                                                   aria-label="Delete user" />
                                                </MudStack>
                                            </MudStack>
                                            <!-- Roles row -->
                                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1" Class="ml-9">
                                                @foreach (var role in user.Roles)
                                                {
                                                    <MudChip T="string" Size="Size.Small" Color="Color.Secondary" Variant="Variant.Filled"
                                                             OnClose="@(() => HandleRemoveUserRole(user.Id, role))"
                                                             CloseIcon="@Icons.Material.Filled.Close">
                                                        @role
                                                    </MudChip>
                                                }
                                                <!-- Add role button -->
                                                @if (_roles != null && _roles.Any(r => !user.Roles.Contains(r.Name)))
                                                {
                                                    <MudMenu Icon="@Icons.Material.Filled.AddCircleOutline" Size="Size.Small"
                                                             Color="Color.Primary" Dense="true"
                                                             aria-label="Assign role">
                                                        @foreach (var role in _roles.Where(r => !user.Roles.Contains(r.Name)))
                                                        {
                                                            <MudMenuItem OnClick="@(() => HandleAddUserRole(user.Id, role.Name))">@role.Name</MudMenuItem>
                                                        }
                                                    </MudMenu>
                                                }
                                            </MudStack>
                                            <!-- Claims row -->
                                            @if (user.Claims.Count > 0)
                                            {
                                                <MudStack Row="true" Spacing="1" Class="ml-9">
                                                    @foreach (var claim in user.Claims)
                                                    {
                                                        <MudTooltip Text="@claim.Type">
                                                            <MudChip T="string" Size="Size.Small" Color="Color.Tertiary" Variant="Variant.Outlined">
                                                                @claim.Value
                                                            </MudChip>
                                                        </MudTooltip>
                                                    }
                                                </MudStack>
                                            }
                                        </MudStack>
                                    </MudListItem>
                                }
                            </MudList>
                        }
                    </MudCardContent>
                </MudCard>
            </MudItem>
        </MudGrid>
    </MudTabPanel>
    <!-- ── Settings tab ───────────────────────────────────── -->
    <MudTabPanel Text="Settings" Icon="@Icons.Material.Filled.Settings">
        <MudGrid Class="mt-4">

            <!-- ── API Settings card ── -->
            <MudItem xs="12" md="6">
                <MudCard Elevation="3">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6">
                                <MudIcon Icon="@Icons.Material.Filled.Api" Class="mr-2" />
                                API Settings
                            </MudText>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent>
                        @if (_appSettings == null)
                        {
                            <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
                        }
                        else
                        {
                            <MudTextField @bind-Value="_appSettings.ApiBaseUrl"
                                          Label="Portfolio API Base URL"
                                          Variant="Variant.Outlined" Class="mb-3"
                                          HelperText="Base URL of the Portfolio API, e.g. https://api.example.com/ (used by the Projects, Skills and Contact pages)"
                                          Placeholder="https://localhost:7002/" />
                        }
                    </MudCardContent>
                    @if (_appSettings != null)
                    {
                    <MudCardActions>
                        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                                   OnClick="@SaveAppSettings" Disabled="@_savingAppSettings"
                                   StartIcon="@Icons.Material.Filled.Save">
                            @(_savingAppSettings ? "Saving..." : "Save API Settings")
                        </MudButton>
                    </MudCardActions>
                    }
                </MudCard>
            </MudItem>

            <!-- ── Google Analytics card ── -->
            <MudItem xs="12" md="6">
                <MudCard Elevation="3">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6">
                                <MudIcon Icon="@Icons.Material.Filled.Analytics" Class="mr-2" />
                                Google Analytics
                            </MudText>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent>
                        @if (_appSettings == null)
                        {
                            <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
                        }
                        else
                        {
                            <MudTextField @bind-Value="_appSettings.GoogleAnalyticsId"
                                          Label="GA4 Measurement ID"
                                          Variant="Variant.Outlined" Class="mb-3"
                                          HelperText="Your Google Analytics 4 Measurement ID, e.g. G-XXXXXXXXXX. Leave empty to disable analytics."
                                          Placeholder="G-XXXXXXXXXX" />
                            @if (!string.IsNullOrWhiteSpace(_appSettings.GoogleAnalyticsId))
                            {
                                <MudAlert Severity="Severity.Success" Dense="true" Class="mt-2">
                                    Analytics active — tracking ID: <strong>@_appSettings.GoogleAnalyticsId</strong>
                                </MudAlert>
                            }
                            else
                            {
                                <MudAlert Severity="Severity.Info" Dense="true" Class="mt-2">
                                    Analytics disabled. Enter a Measurement ID to enable tracking.
                                </MudAlert>
                            }
                        }
                    </MudCardContent>
                    @if (_appSettings != null)
                    {
                    <MudCardActions>
                        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                                   OnClick="@SaveAppSettings" Disabled="@_savingAppSettings"
                                   StartIcon="@Icons.Material.Filled.Save">
                            @(_savingAppSettings ? "Saving..." : "Save Analytics Settings")
                        </MudButton>
                    </MudCardActions>
                    }
                </MudCard>
            </MudItem>

            <!-- ── SMS Settings cards ── -->
            @if (_smsSettings == null)
            {
                <MudItem xs="12"><MudProgressCircular Indeterminate="true" Color="Color.Primary" Class="mt-4" /></MudItem>
            }
            else
            {
                <!-- Provider & global settings -->
                <MudItem xs="12" md="6">
                    <MudCard Elevation="3">
                        <MudCardHeader>
                            <CardHeaderContent>
                                <MudText Typo="Typo.h6">
                                    <MudIcon Icon="@Icons.Material.Filled.SettingsPhone" Class="mr-2" />
                                    SMS Provider
                                </MudText>
                            </CardHeaderContent>
                        </MudCardHeader>
                        <MudCardContent>
                            <MudSwitch @bind-Value="_smsSettings.IsEnabled" Label="Enable SMS sending"
                                       Color="Color.Success" Class="mb-3" />

                            <MudSelect @bind-Value="_smsSettings.Provider" Label="Provider"
                                       Variant="Variant.Outlined" Class="mb-3">
                                <MudSelectItem Value="@("None")">None (disabled)</MudSelectItem>
                                <MudSelectItem Value="@("Twilio")">Twilio</MudSelectItem>
                                <MudSelectItem Value="@("ClickSend")">ClickSend</MudSelectItem>
                            </MudSelect>

                            <MudTextField @bind-Value="_smsSettings.AdminReceiverNumber"
                                          Label="Admin receiver number (E.164, e.g. +447911123456)"
                                          Variant="Variant.Outlined" Class="mb-3"
                                          HelperText="Contact-form alerts are sent to this number" />

                            <!-- Twilio credentials -->
                            @if (_smsSettings.Provider == "Twilio")
                            {
                                <MudDivider Class="my-3" />
                                <MudText Typo="Typo.subtitle2" Class="mb-2">Twilio credentials</MudText>
                                <MudTextField @bind-Value="_smsSettings.TwilioAccountSid"
                                              Label="Account SID" Variant="Variant.Outlined" Class="mb-3" />
                                <MudTextField @bind-Value="_smsSettings.TwilioAuthToken"
                                              Label="Auth Token"
                                              InputType="@(_showTwilioToken ? InputType.Text : InputType.Password)"
                                              Variant="Variant.Outlined" Class="mb-3"
                                              Adornment="Adornment.End"
                                              AdornmentIcon="@(_showTwilioToken ? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility)"
                                              OnAdornmentClick="@(() => _showTwilioToken = !_showTwilioToken)" />
                                <MudTextField @bind-Value="_smsSettings.TwilioFromNumber"
                                              Label="From number (E.164 or Messaging Service SID)"
                                              Variant="Variant.Outlined" Class="mb-3" />
                            }

                            <!-- ClickSend credentials -->
                            @if (_smsSettings.Provider == "ClickSend")
                            {
                                <MudDivider Class="my-3" />
                                <MudText Typo="Typo.subtitle2" Class="mb-2">ClickSend credentials</MudText>
                                <MudTextField @bind-Value="_smsSettings.ClickSendUsername"
                                              Label="Username (email)" Variant="Variant.Outlined" Class="mb-3" />
                                <MudTextField @bind-Value="_smsSettings.ClickSendApiKey"
                                              Label="API Key"
                                              InputType="@(_showClickSendKey ? InputType.Text : InputType.Password)"
                                              Variant="Variant.Outlined" Class="mb-3"
                                              Adornment="Adornment.End"
                                              AdornmentIcon="@(_showClickSendKey ? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility)"
                                              OnAdornmentClick="@(() => _showClickSendKey = !_showClickSendKey)" />
                                <MudTextField @bind-Value="_smsSettings.ClickSendFromName"
                                              Label="Sender ID (up to 11 chars or phone number)"
                                              Variant="Variant.Outlined" Class="mb-3" />
                            }
                        </MudCardContent>
                        <MudCardActions>
                            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                                       OnClick="@SaveSmsSettings" Disabled="@_savingSms"
                                       StartIcon="@Icons.Material.Filled.Save">
                                @(_savingSms ? "Saving..." : "Save SMS Settings")
                            </MudButton>
                            <MudButton Variant="Variant.Outlined" Color="Color.Secondary"
                                       OnClick="@SendTestSms" Disabled="@(!_smsSettings.IsEnabled || _sendingTestSms)"
                                       StartIcon="@Icons.Material.Filled.Send" Class="ml-2">
                                @(_sendingTestSms ? "Sending..." : "Send Test SMS")
                            </MudButton>
                        </MudCardActions>
                    </MudCard>
                </MudItem>

                <!-- Info card -->
                <MudItem xs="12" md="6">
                    <MudCard Elevation="3">
                        <MudCardHeader>
                            <CardHeaderContent>
                                <MudText Typo="Typo.h6">
                                    <MudIcon Icon="@Icons.Material.Filled.Info" Class="mr-2" />
                                    Setup Guide
                                </MudText>
                            </CardHeaderContent>
                        </MudCardHeader>
                        <MudCardContent>
                            <MudText Typo="Typo.subtitle2" Class="mb-1">Twilio</MudText>
                            <MudText Typo="Typo.body2" Class="mb-2">
                                Sign up at <strong>twilio.com</strong>. Copy your <em>Account SID</em> and
                                <em>Auth Token</em> from the Console dashboard. Add a verified phone number as
                                the From number.
                            </MudText>
                            <MudDivider Class="my-2" />
                            <MudText Typo="Typo.subtitle2" Class="mb-1">ClickSend</MudText>
                            <MudText Typo="Typo.body2" Class="mb-2">
                                Sign up at <strong>clicksend.com</strong>. Your login email is the username;
                                generate an API key in <em>Account → API Credentials</em>.
                                The Sender ID can be up to 11 alphanumeric characters.
                            </MudText>
                            <MudDivider Class="my-2" />
                            <MudText Typo="Typo.subtitle2" Class="mb-1">Admin receiver number</MudText>
                            <MudText Typo="Typo.body2">
                                Contact-form submissions send an SMS alert to this number.
                                Must be in international E.164 format, e.g. <code>+447911123456</code>.
                            </MudText>
                        </MudCardContent>
                    </MudCard>
                </MudItem>
            }

            <!-- ── Mail (SMTP) Settings ── -->
            @if (_mailSettings == null)
            {
                <MudItem xs="12"><MudProgressCircular Indeterminate="true" Color="Color.Primary" Class="mt-4" /></MudItem>
            }
            else
            {
                <MudItem xs="12" md="6">
                    <MudCard Elevation="3">
                        <MudCardHeader>
                            <CardHeaderContent>
                                <MudText Typo="Typo.h6">
                                    <MudIcon Icon="@Icons.Material.Filled.Email" Class="mr-2" />
                                    Mail (SMTP) Settings
                                </MudText>
                            </CardHeaderContent>
                        </MudCardHeader>
                        <MudCardContent>
                            <MudSwitch @bind-Value="_mailSettings.IsEnabled" Label="Enable outbound email"
                                       Color="Color.Success" Class="mb-3" />
                            <MudTextField @bind-Value="_mailSettings.SmtpHost"
                                          Label="SMTP Host" Variant="Variant.Outlined" Class="mb-3"
                                          Placeholder="smtp.gmail.com" />
                            <MudNumericField @bind-Value="_mailSettings.SmtpPort"
                                             Label="SMTP Port" Variant="Variant.Outlined" Class="mb-3"
                                             Min="1" Max="65535" />
                            <MudSwitch @bind-Value="_mailSettings.UseSsl" Label="Use SSL/TLS"
                                       Color="Color.Primary" Class="mb-3" />
                            <MudTextField @bind-Value="_mailSettings.SmtpUsername"
                                          Label="Username" Variant="Variant.Outlined" Class="mb-3" />
                            <MudTextField @bind-Value="_mailSettings.SmtpPassword"
                                          Label="Password"
                                          InputType="@(_showSmtpPassword ? InputType.Text : InputType.Password)"
                                          Variant="Variant.Outlined" Class="mb-3"
                                          Adornment="Adornment.End"
                                          AdornmentIcon="@(_showSmtpPassword ? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility)"
                                          OnAdornmentClick="@(() => _showSmtpPassword = !_showSmtpPassword)" />
                            <MudTextField @bind-Value="_mailSettings.FromAddress"
                                          Label="From Address" Variant="Variant.Outlined" Class="mb-3"
                                          Placeholder="noreply@example.com" />
                            <MudTextField @bind-Value="_mailSettings.FromName"
                                          Label="From Name" Variant="Variant.Outlined" Class="mb-3"
                                          Placeholder="David Buckley Portfolio" />
                        </MudCardContent>
                        <MudCardActions>
                            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                                       OnClick="@SaveMailSettings" Disabled="@_savingMail"
                                       StartIcon="@Icons.Material.Filled.Save">
                                @(_savingMail ? "Saving..." : "Save Mail Settings")
                            </MudButton>
                            <MudButton Variant="Variant.Outlined" Color="Color.Secondary"
                                       OnClick="@SendTestEmail" Disabled="@(!_mailSettings.IsEnabled || _sendingTestEmail)"
                                       StartIcon="@Icons.Material.Filled.Send" Class="ml-2">
                                @(_sendingTestEmail ? "Sending..." : "Send Test Email")
                            </MudButton>
                        </MudCardActions>
                    </MudCard>
                </MudItem>

                <!-- Visitor Notification Settings -->
                <MudItem xs="12" md="6">
                    <MudCard Elevation="3">
                        <MudCardHeader>
                            <CardHeaderContent>
                                <MudText Typo="Typo.h6">
                                    <MudIcon Icon="@Icons.Material.Filled.Visibility" Class="mr-2" />
                                    Visitor Notifications
                                </MudText>
                            </CardHeaderContent>
                        </MudCardHeader>
                        <MudCardContent>
                            @if (_appSettings == null)
                            {
                                <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
                            }
                            else
                            {
                                <MudSwitch @bind-Value="_appSettings.VisitorNotificationsEnabled"
                                           Label="Email me when a new visitor arrives"
                                           Color="Color.Success" Class="mb-3" />
                                <MudTextField @bind-Value="_appSettings.VisitorNotificationEmail"
                                              Label="Notification Email Address"
                                              Variant="Variant.Outlined" Class="mb-3"
                                              HelperText="Leave blank to use the Mail Settings From Address"
                                              Placeholder="you@example.com" />
                                <MudText Typo="Typo.subtitle2" Class="mb-1">Email Template</MudText>
                                <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-2">
                                    Available placeholders: <code>{{ip}}</code>, <code>{{page}}</code>, <code>{{time}}</code>
                                </MudText>
                                <MudTextField @bind-Value="_appSettings.VisitorEmailTemplate"
                                              Label="HTML Email Body"
                                              Variant="Variant.Outlined"
                                              Lines="6"
                                              Placeholder="@DefaultVisitorTemplate"
                                              HelperText="Leave blank to use the default template" />
                            }
                        </MudCardContent>
                        @if (_appSettings != null)
                        {
                        <MudCardActions>
                            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                                       OnClick="@SaveAppSettings" Disabled="@_savingAppSettings"
                                       StartIcon="@Icons.Material.Filled.Save">
                                @(_savingAppSettings ? "Saving..." : "Save Visitor Settings")
                            </MudButton>
                        </MudCardActions>
                        }
                    </MudCard>

                    <!-- Theme Colors card -->
                    @if (_appSettings != null)
                    {
                    <MudCard Elevation="2" Class="mb-4">
                        <MudCardHeader>
                            <CardHeaderContent>
                                <MudText Typo="Typo.h6">
                                    <MudIcon Icon="@Icons.Material.Filled.Palette" Class="mr-2" />
                                    Site Theme Colors
                                </MudText>
                            </CardHeaderContent>
                        </MudCardHeader>
                        <MudCardContent>
                            <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-3">
                                Customise the primary, secondary, and tertiary brand colours. Leave blank to use the default BookIt palette.
                            </MudText>
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-2">
                                <MudTextField @bind-Value="_appSettings.PrimaryColor" Label="Primary Color"
                                              Variant="Variant.Outlined" Placeholder="#5B5BD6" Style="flex:1;" />
                                @if (!string.IsNullOrWhiteSpace(_appSettings.PrimaryColor))
                                {
                                    <div style="width:32px;height:32px;border-radius:50%;background:@_appSettings.PrimaryColor;border:1px solid rgba(0,0,0,0.2);flex-shrink:0;"></div>
                                }
                            </MudStack>
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-2">
                                <MudTextField @bind-Value="_appSettings.SecondaryColor" Label="Secondary Color"
                                              Variant="Variant.Outlined" Placeholder="#0EA5E9" Style="flex:1;" />
                                @if (!string.IsNullOrWhiteSpace(_appSettings.SecondaryColor))
                                {
                                    <div style="width:32px;height:32px;border-radius:50%;background:@_appSettings.SecondaryColor;border:1px solid rgba(0,0,0,0.2);flex-shrink:0;"></div>
                                }
                            </MudStack>
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-2">
                                <MudTextField @bind-Value="_appSettings.TertiaryColor" Label="Tertiary / Accent Color"
                                              Variant="Variant.Outlined" Placeholder="#10B981" Style="flex:1;" />
                                @if (!string.IsNullOrWhiteSpace(_appSettings.TertiaryColor))
                                {
                                    <div style="width:32px;height:32px;border-radius:50%;background:@_appSettings.TertiaryColor;border:1px solid rgba(0,0,0,0.2);flex-shrink:0;"></div>
                                }
                            </MudStack>
                        </MudCardContent>
                        <MudCardActions>
                            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                                       OnClick="@SaveAppSettings" Disabled="@_savingAppSettings"
                                       StartIcon="@Icons.Material.Filled.Save">
                                @(_savingAppSettings ? "Saving..." : "Save Theme Colors")
                            </MudButton>
                        </MudCardActions>
                    </MudCard>
                    }

                    <!-- Blog Post Image Slots card -->
                    @if (_appSettings != null)
                    {
                    <MudCard Elevation="2" Class="mb-4">
                        <MudCardHeader>
                            <CardHeaderContent>
                                <MudText Typo="Typo.h6">
                                    <MudIcon Icon="@Icons.Material.Filled.GridView" Class="mr-2" />
                                    Blog Post Media Slots
                                </MudText>
                            </CardHeaderContent>
                        </MudCardHeader>
                        <MudCardContent>
                            <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-3">
                                Set how many image / video slots appear in the blog post editor and on each published post.
                                The first slot is always the hero image; the rest are gallery slots. Default: 10.
                            </MudText>
                            <MudNumericField @bind-Value="_appSettings.BlogPostImageSlots"
                                             Label="Total image slots per post" Min="1" Max="50"
                                             Variant="Variant.Outlined" Style="max-width:220px;" />
                        </MudCardContent>
                        <MudCardActions>
                            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                                       OnClick="@SaveAppSettings" Disabled="@_savingAppSettings"
                                       StartIcon="@Icons.Material.Filled.Save">
                                @(_savingAppSettings ? "Saving..." : "Save Media Settings")
                            </MudButton>
                        </MudCardActions>
                    </MudCard>
                    }
                </MudItem>
            }

        </MudGrid>
    </MudTabPanel>

        <!-- ── Blog Posts tab ─────────────────────────────────── -->
    <MudTabPanel Text="Blog Posts" Icon="@Icons.Material.Filled.Article">
        <MudGrid Class="mt-4">

            @if (!_postShowEditor)
            {
                <!-- ── Posts: list view (like WP "All Posts") ── -->
                <MudItem xs="12">
                    <MudCard Elevation="3">
                        <MudCardHeader>
                            <CardHeaderContent>
                                <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                                    <MudText Typo="Typo.h6">
                                        <MudIcon Icon="@Icons.Material.Filled.Article" Class="mr-2" />
                                        Posts
                                        @if (_blogPosts != null)
                                        {
                                            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="ml-2">(@_blogPosts.Count total)</MudText>
                                        }
                                    </MudText>
                                    <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
                                               StartIcon="@Icons.Material.Filled.Add"
                                               OnClick="@OpenNewPostEditor">
                                        Add New Post
                                    </MudButton>
                                </MudStack>
                            </CardHeaderContent>
                        </MudCardHeader>
                        <MudCardContent>
                            <!-- Status filter tabs -->
                            <!-- Search bar -->
                            <MudTextField @bind-Value="_postSearchQuery"
                                          Placeholder="Search posts by title, category or tags…"
                                          Adornment="Adornment.Start"
                                          AdornmentIcon="@Icons.Material.Filled.Search"
                                          Variant="Variant.Outlined"
                                          Margin="Margin.Dense"
                                          Clearable="true"
                                          Class="mb-3" />

                            <!-- Status filter chips -->
                            <MudStack Row="true" Spacing="1" Class="mb-2" Style="flex-wrap:wrap;">
                                @foreach (var label in new[] { "All", "Published", "Drafts" })
                                {
                                    var count = label switch {
                                        "Published" => _blogPosts?.Count(p => p.IsPublished) ?? 0,
                                        "Drafts"    => _blogPosts?.Count(p => !p.IsPublished) ?? 0,
                                        _           => _blogPosts?.Count ?? 0
                                    };
                                    <MudChip T="string" Size="Size.Small" OnClick="@(() => _postStatusFilter = label)"
                                             Color="@(_postStatusFilter == label ? Color.Primary : Color.Default)"
                                             Variant="@(_postStatusFilter == label ? Variant.Filled : Variant.Outlined)">
                                        @label (@count)
                                    </MudChip>
                                }
                            </MudStack>

                            <!-- Category quick-filter chips -->
                            @{
                                var categories = _blogPosts?
                                    .Select(p => p.Category)
                                    .Where(c => !string.IsNullOrWhiteSpace(c))
                                    .Distinct()
                                    .OrderBy(c => c)
                                    .ToList() ?? [];
                            }
                            @if (categories.Count > 0)
                            {
                                <MudStack Row="true" Spacing="1" Class="mb-3" Style="flex-wrap:wrap;">
                                    @foreach (var cat in categories)
                                    {
                                        var isActive = _postStatusFilter == "cat:" + cat;
                                        <MudChip T="string" Size="Size.Small"
                                                 OnClick="@(() => _postStatusFilter = isActive ? "All" : "cat:" + cat)"
                                                 Color="@(isActive ? Color.Secondary : Color.Default)"
                                                 Variant="@(isActive ? Variant.Filled : Variant.Outlined)">
                                            @cat
                                        </MudChip>
                                    }
                                </MudStack>
                            }

                            @if (_blogPosts == null)
                            {
                                <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
                            }
                            else
                            {
                                IEnumerable<Portfolio.Shared.Models.BlogPostDto> filtered = _postStatusFilter switch {
                                    "Published"                                 => _blogPosts.Where(p => p.IsPublished),
                                    "Drafts"                                    => _blogPosts.Where(p => !p.IsPublished),
                                    var s when s.StartsWith("cat:")             => _blogPosts.Where(p => p.Category == s[4..]),
                                    _                                           => _blogPosts
                                };
                                if (!string.IsNullOrWhiteSpace(_postSearchQuery))
                                {
                                    var q = _postSearchQuery.Trim().ToLowerInvariant();
                                    filtered = filtered.Where(p =>
                                        p.Title.Contains(q, StringComparison.OrdinalIgnoreCase) ||
                                        p.Category.Contains(q, StringComparison.OrdinalIgnoreCase) ||
                                        (p.Tags ?? string.Empty).Contains(q, StringComparison.OrdinalIgnoreCase));
                                }
                                var filteredList = filtered.ToList();

                                @if (filteredList.Count == 0)
                                {
                                    <MudText Color="Color.Secondary" Class="pa-4">No posts in this view.</MudText>
                                }
                                else
                                {
                                     <MudTable Items="@filteredList" Hover="true" Dense="true" Breakpoint="Breakpoint.Sm"
                                                      RowsPerPage="10">
                                        <HeaderContent>
                                            <MudTh>Title</MudTh>
                                            <MudTh>Category</MudTh>
                                            <MudTh>Date</MudTh>
                                            <MudTh>Status</MudTh>
                                            <MudTh>Actions</MudTh>
                                        </HeaderContent>
                                        <RowTemplate>
                                            <MudTd DataLabel="Title">
                                                <MudStack Spacing="0">
                                                    <MudText Typo="Typo.body2" Class="fw-bold">@context.Title</MudText>
                                                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                                        <MudText Typo="Typo.caption" Color="Color.Secondary">/@context.Slug</MudText>
                                                        @if (context.IsPublished)
                                                        {
                                                            <MudLink Href="@($"/blog/{context.Slug}")" Target="_blank"
                                                                     Typo="Typo.caption" Color="Color.Primary" Style="font-size:0.7rem;">
                                                                View ↗
                                                            </MudLink>
                                                        }
                                                    </MudStack>
                                                </MudStack>
                                            </MudTd>
                                            <MudTd DataLabel="Category">
                                                <MudChip T="string" Size="Size.Small" Color="@GetCategoryColor(context.Category)" Variant="Variant.Filled">
                                                    @context.Category
                                                </MudChip>
                                            </MudTd>
                                            <MudTd DataLabel="Date">
                                                <MudStack Spacing="0">
                                                    <MudText Typo="Typo.body2">@context.PublishedDate.ToString("d MMM yyyy")</MudText>
                                                    @if (context.UpdatedAt.HasValue)
                                                    {
                                                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                                                            Updated @context.UpdatedAt.Value.ToString("d MMM yyyy")
                                                        </MudText>
                                                    }
                                                </MudStack>
                                            </MudTd>
                                            <MudTd DataLabel="Status">
                                                @if (context.IsPublished)
                                                {
                                                    <MudChip T="string" Size="Size.Small" Color="Color.Success" Variant="Variant.Filled">Published</MudChip>
                                                }
                                                else
                                                {
                                                    <MudChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Outlined">Draft</MudChip>
                                                }
                                            </MudTd>
                                            <MudTd DataLabel="Actions">
                                                <MudStack Row="true" Spacing="0">
                                                    <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                                                   Size="Size.Small" Color="Color.Primary"
                                                                   OnClick="@(() => StartEditPost(context))"
                                                                   aria-label="Edit post" />
                                                    <MudIconButton Icon="@(context.IsPublished ? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility)"
                                                                   Size="Size.Small" Color="Color.Secondary"
                                                                   OnClick="@(() => TogglePublishPost(context))"
                                                                   aria-label="@(context.IsPublished ? "Unpublish" : "Publish")" />
                                                    <MudIconButton Icon="@Icons.Material.Filled.ContentCopy"
                                                                   Size="Size.Small" Color="Color.Default"
                                                                   OnClick="@(() => DuplicatePost(context))"
                                                                   aria-label="Duplicate post" />
                                                    <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                                                   Size="Size.Small" Color="Color.Error"
                                                                   OnClick="@(() => DeletePost(context.Id))"
                                                                   aria-label="Delete post" />
                                                </MudStack>
                                            </MudTd>
                                        </RowTemplate>
                                        <PagerContent>
                                            <MudTablePager PageSizeOptions="new int[] { 5, 10, 25 }" />
                                        </PagerContent>
                                    </MudTable>
                                }
                            }
                        </MudCardContent>
                    </MudCard>
                </MudItem>
            }
            else
            {
                <!-- ── Posts: editor view (WordPress-style) ── -->
                <MudItem xs="12">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-3" Spacing="1">
                        <MudButton Variant="Variant.Text" Color="Color.Default" Size="Size.Small"
                                   StartIcon="@Icons.Material.Filled.ArrowBack"
                                   OnClick="@CancelEditPost">
                            ← Posts
                        </MudButton>
                        <MudText Typo="Typo.h6">
                            @(_editingPost == null ? "Add New Post" : "Edit Post")
                        </MudText>
                    </MudStack>
                </MudItem>

                <!-- Editor: left content + right sidebar -->
                <MudItem xs="12" md="8">
                    <MudForm @ref="_postForm" @bind-IsValid="_postFormValid">
                        <!-- Title -->
                        <MudCard Elevation="2" Class="mb-4">
                            <MudCardContent Class="pb-0">
                                <MudTextField @bind-Value="_postTitle" Label="Post Title" Required="true"
                                              RequiredError="Title is required"
                                              Variant="Variant.Outlined"
                                              Typo="Typo.h5"
                                              OnBlur="@GenerateSlugFromTitle"
                                              Style="font-size:1.4rem;font-weight:600;" />
                                <MudStack Row="true" AlignItems="AlignItems.Center" Class="mt-1 mb-2" Spacing="1">
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">Permalink:</MudText>
                                    <MudTextField @bind-Value="_postSlug" Required="true"
                                                  RequiredError="Slug is required"
                                                  Variant="Variant.Text" Margin="Margin.Dense"
                                                  Typo="Typo.caption"
                                                  Style="max-width:320px;" />
                                </MudStack>
                            </MudCardContent>
                        </MudCard>

                        <!-- Body -->
                        <MudCard Elevation="2" Class="mb-4">
                            <MudCardContent>
                                <MudText Typo="Typo.subtitle2" Class="mb-2">Content</MudText>
                                <RichTextEditor @ref="_postBodyEditor" Placeholder="Write your post here…" />
                            </MudCardContent>
                        </MudCard>

                        <!-- Excerpt / Summary -->
                        <MudCard Elevation="2" Class="mb-4">
                            <MudCardContent>
                                <MudText Typo="Typo.subtitle2" Class="mb-2">Excerpt</MudText>
                                <MudTextField @bind-Value="_postSummary" Label="Excerpt" Required="true"
                                              RequiredError="Excerpt is required"
                                              Variant="Variant.Outlined" Lines="3"
                                              HelperText="Used on blog listing cards and as the default meta description." />
                            </MudCardContent>
                        </MudCard>
                    </MudForm>
                </MudItem>

                <!-- Sidebar -->
                <MudItem xs="12" md="4">

                    <!-- Publish card -->
                    <MudCard Elevation="2" Class="mb-4">
                        <MudCardHeader>
                            <CardHeaderContent>
                                <MudText Typo="Typo.subtitle2">
                                    <MudIcon Icon="@Icons.Material.Filled.Publish" Size="Size.Small" Class="mr-1" />
                                    Publish
                                </MudText>
                            </CardHeaderContent>
                        </MudCardHeader>
                        <MudCardContent>
                            <MudStack Spacing="2">
                                <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                                    <MudText Typo="Typo.body2">Status</MudText>
                                    <MudChip T="string" Size="Size.Small"
                                             Color="@(_postIsPublished ? Color.Success : Color.Default)"
                                             Variant="@(_postIsPublished ? Variant.Filled : Variant.Outlined)">
                                        @(_postIsPublished ? "Published" : "Draft")
                                    </MudChip>
                                </MudStack>
                                <MudSwitch @bind-Value="_postIsPublished" Label="@(_postIsPublished ? "Published" : "Save as Draft")"
                                           Color="Color.Success" />
                                <MudTextField @bind-Value="_postPublishedDateStr" Label="Publish Date"
                                              InputType="InputType.Date" Variant="Variant.Outlined"
                                              Margin="Margin.Dense" />
                            </MudStack>
                        </MudCardContent>
                        <MudCardActions>
                            <MudStack Style="width:100%;" Spacing="1">
                                <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true"
                                           OnClick="@SavePost" Disabled="@_savingPost"
                                           StartIcon="@Icons.Material.Filled.Save">
                                    @(_savingPost ? "Saving…" : (_editingPost == null ? (_postIsPublished ? "Publish" : "Save Draft") : "Update"))
                                </MudButton>
                                @if (_editingPost != null && _editingPost.IsPublished)
                                {
                                    <MudButton Variant="Variant.Outlined" Color="Color.Default" FullWidth="true"
                                               Href="@($"/blog/{_editingPost.Slug}")" Target="_blank"
                                               StartIcon="@Icons.Material.Filled.OpenInNew"
                                               Size="Size.Small">
                                        View Post
                                    </MudButton>
                                }
                            </MudStack>
                        </MudCardActions>
                    </MudCard>

                    <!-- Document settings card -->
                    <MudCard Elevation="2" Class="mb-4">
                        <MudCardHeader>
                            <CardHeaderContent>
                                <MudText Typo="Typo.subtitle2">
                                    <MudIcon Icon="@Icons.Material.Filled.Tune" Size="Size.Small" Class="mr-1" />
                                    Post Settings
                                </MudText>
                            </CardHeaderContent>
                        </MudCardHeader>
                        <MudCardContent>
                            <MudTextField @bind-Value="_postCategory" Label="Category" Required="true"
                                          RequiredError="Category is required"
                                          Variant="Variant.Outlined" Class="mb-3"
                                          HelperText="e.g. AI, Security, .NET" />
                            <MudTextField @bind-Value="_postTags" Label="Tags"
                                          Variant="Variant.Outlined" Class="mb-3"
                                          HelperText="Comma-separated, e.g. AI, .NET, C#" />
                            <MudNumericField @bind-Value="_postReadMinutes" Label="Read time (min)"
                                             Variant="Variant.Outlined" Min="1" />
                        </MudCardContent>
                    </MudCard>

                    <!-- Featured Image card -->
                    <MudCard Elevation="2" Class="mb-4">
                        <MudCardHeader>
                            <CardHeaderContent>
                                <MudText Typo="Typo.subtitle2">
                                    <MudIcon Icon="@Icons.Material.Filled.Image" Size="Size.Small" Class="mr-1" />
                                    Featured Image
                                </MudText>
                            </CardHeaderContent>
                        </MudCardHeader>
                        <MudCardContent>
                            @if (!string.IsNullOrWhiteSpace(_postFeaturedImage))
                            {
                                <img src="@_postFeaturedImage" alt="Featured image preview"
                                     style="width:100%;max-height:160px;object-fit:cover;border-radius:4px;margin-bottom:8px;" />
                            }
                            <MudTextField @bind-Value="_postFeaturedImage" Label="Featured Image URL"
                                          Variant="Variant.Outlined"
                                          HelperText="Full URL to the hero image (recommended 1200×630)" />
                        </MudCardContent>
                    </MudCard>

                    <!-- GitHub URL card -->
                    <MudCard Elevation="2" Class="mb-4">
                        <MudCardHeader>
                            <CardHeaderContent>
                                <MudText Typo="Typo.subtitle2">
                                    <MudIcon Icon="@Icons.Custom.Brands.GitHub" Size="Size.Small" Class="mr-1" />
                                    Source Repository
                                </MudText>
                            </CardHeaderContent>
                        </MudCardHeader>
                        <MudCardContent>
                            <MudTextField @bind-Value="_postGitHubUrl" Label="GitHub URL"
                                          Variant="Variant.Outlined"
                                          Placeholder="https://github.com/dotnetappdev/..."
                                          HelperText="Optional link shown on the blog post page" />
                            @if (!string.IsNullOrWhiteSpace(_postGitHubUrl))
                            {
                                <MudButton Variant="Variant.Outlined" Color="Color.Default"
                                           StartIcon="@Icons.Custom.Brands.GitHub"
                                           Href="@_postGitHubUrl" Target="_blank" Class="mt-2" Size="Size.Small">
                                    Preview link
                                </MudButton>
                            }
                        </MudCardContent>
                    </MudCard>

                    <!-- Media Gallery card — slot-based (WordPress-style) -->
                    <MudCard Elevation="2" Class="mb-4">
                        <MudCardHeader>
                            <CardHeaderContent>
                                <MudText Typo="Typo.subtitle2">
                                    <MudIcon Icon="@Icons.Material.Filled.PermMedia" Size="Size.Small" Class="mr-1" />
                                    Media Gallery
                                </MudText>
                            </CardHeaderContent>
                            <CardHeaderActions>
                                <MudTooltip Text="Drag slots to reorder. Click + to add from library or upload. Click × to clear a slot.">
                                    <MudIcon Icon="@Icons.Material.Filled.HelpOutline" Size="Size.Small"
                                             Style="color:var(--mud-palette-text-secondary);" />
                                </MudTooltip>
                            </CardHeaderActions>
                        </MudCardHeader>
                        <MudCardContent>
                            @{
                                var totalSlots = (_appSettings?.BlogPostImageSlots ?? 10);
                            }

                            <!-- Hero (primary) slot -->
                            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-1 d-block">
                                Hero Image (primary — shown at the top of the post)
                            </MudText>
                            @{
                                var heroItem = _postMediaItems.Count > 0 ? _postMediaItems[0] : null;
                                bool heroHasContent = !string.IsNullOrWhiteSpace(heroItem?.Url);
                            }
                            <div draggable="true"
                                 @ondragstart="@(() => _dragFromIndex = 0)"
                                 @ondragover:preventDefault="true"
                                 @ondrop="@(() => DropMediaItem(0))"
                                 style="position:relative;width:100%;height:160px;border:2px dashed @(heroHasContent ? "var(--mud-palette-primary)" : "var(--mud-palette-lines-default)");border-radius:8px;margin-bottom:12px;overflow:hidden;background:var(--mud-palette-background-grey);">
                                @if (heroHasContent)
                                {
                                    @if (heroItem!.Type == "image")
                                    {
                                        <img src="@heroItem.Url" alt="@(heroItem.Caption ?? "Hero image")"
                                             style="width:100%;height:100%;object-fit:cover;" />
                                    }
                                    else
                                    {
                                        <div style="display:flex;align-items:center;justify-content:center;height:100%;background:var(--mud-palette-background);">
                                            <MudIcon Icon="@Icons.Material.Filled.PlayCircle" Style="font-size:48px;opacity:0.6;" />
                                            <MudText Typo="Typo.caption" Class="ml-2" Style="word-break:break-all;max-width:80%;">@heroItem.Url</MudText>
                                        </div>
                                    }
                                    <div style="position:absolute;top:4px;right:4px;display:flex;gap:4px;">
                                        <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                                                       Style="background:rgba(0,0,0,0.5);color:white;"
                                                       OnClick="@(() => OpenSlotPicker(0))" />
                                        <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small"
                                                       Style="background:rgba(220,38,38,0.8);color:white;"
                                                       OnClick="@(() => ClearSlot(0))" />
                                    </div>
                                    <div style="position:absolute;top:4px;left:4px;background:var(--mud-palette-primary);color:white;font-size:10px;padding:2px 6px;border-radius:3px;">HERO</div>
                                }
                                else
                                {
                                    <div style="display:flex;flex-direction:column;align-items:center;justify-content:center;height:100%;cursor:pointer;"
                                         @onclick="@(() => OpenSlotPicker(0))">
                                        <MudIcon Icon="@Icons.Material.Filled.AddPhotoAlternate" Size="Size.Large"
                                                 Style="color:var(--mud-palette-text-secondary);opacity:0.5;" />
                                        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-1">Hero Image — click + to add</MudText>
                                        <MudIconButton Icon="@Icons.Material.Filled.Add" Variant="Variant.Filled"
                                                       Color="Color.Primary" Size="Size.Small" Class="mt-2"
                                                       OnClick="@(() => OpenSlotPicker(0))" />
                                    </div>
                                }
                            </div>

                            <!-- Secondary gallery slots (eBay-style dotted grid) -->
                            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-2 d-block">
                                Gallery Slots (@(totalSlots - 1) additional — drag to reorder)
                            </MudText>
                            <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(130px,1fr));gap:8px;margin-bottom:8px;">
                                @for (int si = 1; si < totalSlots; si++)
                                {
                                    var slotIdx = si;
                                    var slotItem = slotIdx < _postMediaItems.Count ? _postMediaItems[slotIdx] : null;
                                    bool slotHasContent = !string.IsNullOrWhiteSpace(slotItem?.Url);
                                    <div draggable="true"
                                         @ondragstart="@(() => _dragFromIndex = slotIdx)"
                                         @ondragover:preventDefault="true"
                                         @ondrop="@(() => DropMediaItem(slotIdx))"
                                         style="position:relative;width:100%;aspect-ratio:1;border:2px dashed @(slotHasContent ? "var(--mud-palette-primary)" : "var(--mud-palette-lines-default)");border-radius:6px;overflow:hidden;background:var(--mud-palette-background-grey);cursor:@(slotHasContent ? "grab" : "pointer");"
                                         @onclick="@(() => { if (!slotHasContent) OpenSlotPicker(slotIdx); })">
                                        @if (slotHasContent)
                                        {
                                            @if (slotItem!.Type == "image")
                                            {
                                                <img src="@slotItem.Url" alt="@(slotItem.Caption ?? $"Slot {slotIdx}")"
                                                     style="width:100%;height:100%;object-fit:cover;" />
                                            }
                                            else
                                            {
                                                <div style="display:flex;align-items:center;justify-content:center;height:100%;background:var(--mud-palette-background);">
                                                    <MudIcon Icon="@Icons.Material.Filled.PlayCircle" Size="Size.Medium"
                                                             Style="opacity:0.7;" />
                                                </div>
                                            }
                                            <div style="position:absolute;top:2px;right:2px;display:flex;gap:2px;">
                                                <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                                                               Style="background:rgba(0,0,0,0.5);color:white;padding:2px;"
                                                               OnClick="@(() => OpenSlotPicker(slotIdx))" />
                                                <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small"
                                                               Style="background:rgba(220,38,38,0.8);color:white;padding:2px;"
                                                               OnClick="@(() => ClearSlot(slotIdx))" />
                                            </div>
                                            <div style="position:absolute;bottom:0;left:0;right:0;background:rgba(0,0,0,0.45);color:white;font-size:9px;padding:2px 4px;text-align:center;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">
                                                @(string.IsNullOrWhiteSpace(slotItem.Caption) ? $"Slot {slotIdx}" : slotItem.Caption)
                                            </div>
                                        }
                                        else
                                        {
                                            <div style="display:flex;flex-direction:column;align-items:center;justify-content:center;height:100%;">
                                                <MudIcon Icon="@Icons.Material.Filled.Add"
                                                         Style="color:var(--mud-palette-text-secondary);opacity:0.4;font-size:28px;" />
                                                <MudText Typo="Typo.caption" Color="Color.Secondary"
                                                         Style="font-size:9px;margin-top:2px;">@slotIdx</MudText>
                                            </div>
                                        }
                                    </div>
                                }
                            </div>
                        </MudCardContent>
                    </MudCard>

                    <!-- Media Slot Picker (inline panel) -->
                    @if (_showMediaPicker)
                    {
                    <MudCard Elevation="4" Class="mb-4" Style="border:2px solid var(--mud-palette-primary);">
                        <MudCardHeader>
                            <CardHeaderContent>
                                <MudText Typo="Typo.subtitle2">
                                    <MudIcon Icon="@Icons.Material.Filled.PhotoLibrary" Size="Size.Small" Class="mr-1" />
                                    @(_pickerTargetSlot == 0 ? "Set Hero Image" : $"Set Slot {_pickerTargetSlot}")
                                </MudText>
                            </CardHeaderContent>
                            <CardHeaderActions>
                                <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small"
                                               OnClick="@ClosePicker" />
                            </CardHeaderActions>
                        </MudCardHeader>
                        <MudCardContent>
                            <MudTabs Elevation="0">
                                <!-- URL / Library tab -->
                                <MudTabPanel Text="URL or Library" Icon="@Icons.Material.Filled.Link">
                                    <MudStack Spacing="2" Class="pt-2">
                                        <MudSelect T="string" @bind-Value="_pickerType" Label="Type"
                                                   Variant="Variant.Outlined" Margin="Margin.Dense" Style="width:110px;">
                                            <MudSelectItem Value="@("image")">Image</MudSelectItem>
                                            <MudSelectItem Value="@("video")">Video</MudSelectItem>
                                        </MudSelect>
                                        <MudTextField @bind-Value="_pickerUrl"
                                                      Label="URL" Variant="Variant.Outlined" Margin="Margin.Dense"
                                                      Placeholder="@(_pickerType == "video" ? "YouTube / Vimeo / direct video URL…" : "https://…")" />
                                        <MudTextField @bind-Value="_pickerCaption"
                                                      Label="Caption (optional)" Variant="Variant.Outlined" Margin="Margin.Dense" />
                                        <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
                                                   Disabled="@string.IsNullOrWhiteSpace(_pickerUrl)"
                                                   OnClick="@ConfirmPickerUrl">
                                            Use This URL
                                        </MudButton>

                                        @if (_mediaFiles.Count > 0)
                                        {
                                            <MudDivider Class="my-2" />
                                            <MudText Typo="Typo.caption" Color="Color.Secondary">— or pick from your media library —</MudText>
                                            <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(80px,1fr));gap:6px;max-height:240px;overflow-y:auto;">
                                                @foreach (var mf in _mediaFiles)
                                                {
                                                    <div style="position:relative;aspect-ratio:1;border:2px solid transparent;border-radius:4px;overflow:hidden;cursor:pointer;background:var(--mud-palette-background-grey);"
                                                         @onclick="@(() => PickFromLibrary(mf))">
                                                        @if (mf.MediaType == "image")
                                                        {
                                                            <img src="@mf.Url" alt="@(mf.Alt ?? mf.OriginalName)"
                                                                 style="width:100%;height:100%;object-fit:cover;" />
                                                        }
                                                        else
                                                        {
                                                            <div style="display:flex;align-items:center;justify-content:center;height:100%;">
                                                                <MudIcon Icon="@Icons.Material.Filled.PlayCircle"
                                                                         Style="opacity:0.7;" />
                                                            </div>
                                                        }
                                                        <div style="position:absolute;bottom:0;left:0;right:0;background:rgba(0,0,0,0.5);color:white;font-size:8px;padding:1px 3px;overflow:hidden;white-space:nowrap;text-overflow:ellipsis;">
                                                            @mf.OriginalName
                                                        </div>
                                                    </div>
                                                }
                                            </div>
                                        }
                                    </MudStack>
                                </MudTabPanel>

                                <!-- Upload tab -->
                                <MudTabPanel Text="Upload" Icon="@Icons.Material.Filled.Upload">
                                    <MudStack Spacing="2" Class="pt-2">
                                        <MudText Typo="Typo.body2" Color="Color.Secondary">
                                            Upload an image (JPEG, PNG, GIF, WebP, SVG) or video (MP4, WebM, OGG, MOV) up to 100 MB.
                                        </MudText>
                                        <InputFile id="slotUploadInput" OnChange="@HandleSlotFileUpload"
                                                   accept="image/*,video/*" style="display:none;" />
                                        <MudButton Variant="Variant.Filled" Color="Color.Secondary" Size="Size.Small"
                                                   StartIcon="@Icons.Material.Filled.Upload"
                                                   Disabled="@_pickerUploading"
                                                   OnClick="@(() => JSRuntime.InvokeVoidAsync("triggerInputClick", "slotUploadInput"))">
                                            @(_pickerUploading ? "Uploading…" : "Browse & Upload")
                                        </MudButton>
                                        @if (_pickerUploading)
                                        {
                                            <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
                                        }
                                    </MudStack>
                                </MudTabPanel>
                            </MudTabs>
                        </MudCardContent>
                    </MudCard>
                    }

                    <!-- SEO card -->
                    <MudExpansionPanel Text="SEO & Social" Icon="@Icons.Material.Filled.TravelExplore"
                                       Class="mb-4">
                        <MudStack Spacing="3" Class="pa-2">
                            <MudTextField @bind-Value="_postMetaTitle" Label="Meta Title"
                                          Variant="Variant.Outlined"
                                          HelperText="Leave blank to use the post title" />
                            <MudTextField @bind-Value="_postMetaDescription" Label="Meta Description"
                                          Variant="Variant.Outlined" Lines="2"
                                          HelperText="Leave blank to use the excerpt" />
                            <MudTextField @bind-Value="_postOgImage" Label="OG Image URL"
                                          Variant="Variant.Outlined"
                                          HelperText="Leave blank to use featured image" />
                            <MudTextField @bind-Value="_postCanonicalUrl" Label="Canonical URL"
                                          Variant="Variant.Outlined"
                                          HelperText="Leave blank to use the current URL" />
                        </MudStack>
                    </MudExpansionPanel>

                </MudItem>
            }

        </MudGrid>
    </MudTabPanel>

    <!-- ── Pages tab ──────────────────────────────────────── -->
    <MudTabPanel Text="Pages" Icon="@Icons.Material.Filled.Pages">
        <MudGrid Class="mt-4">

            @if (!_pageShowEditor)
            {
                <!-- ── Pages: list view ── -->
                <MudItem xs="12">
                    <MudCard Elevation="3">
                        <MudCardHeader>
                            <CardHeaderContent>
                                <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                                    <MudText Typo="Typo.h6">
                                        <MudIcon Icon="@Icons.Material.Filled.Pages" Class="mr-2" />
                                        Pages
                                        @if (_cmsPages != null)
                                        {
                                            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="ml-2">(@_cmsPages.Count total)</MudText>
                                        }
                                    </MudText>
                                    <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
                                               StartIcon="@Icons.Material.Filled.Add"
                                               OnClick="@OpenNewPageEditor">
                                        Add New Page
                                    </MudButton>
                                </MudStack>
                            </CardHeaderContent>
                        </MudCardHeader>
                        <MudCardContent>
                            <!-- Status filter -->
                            <MudStack Row="true" Spacing="1" Class="mb-3">
                                @foreach (var label in new[] { "All", "Published", "Drafts" })
                                {
                                    var count = label switch {
                                        "Published" => _cmsPages?.Count(p => p.IsPublished) ?? 0,
                                        "Drafts"    => _cmsPages?.Count(p => !p.IsPublished) ?? 0,
                                        _           => _cmsPages?.Count ?? 0
                                    };
                                    <MudChip T="string" Size="Size.Small" OnClick="@(() => _pageStatusFilter = label)"
                                             Color="@(_pageStatusFilter == label ? Color.Primary : Color.Default)"
                                             Variant="@(_pageStatusFilter == label ? Variant.Filled : Variant.Outlined)">
                                        @label (@count)
                                    </MudChip>
                                }
                            </MudStack>

                            @if (_cmsPages == null)
                            {
                                <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
                            }
                            else
                            {
                                var filtered = _pageStatusFilter switch {
                                    "Published" => _cmsPages.Where(p => p.IsPublished).ToList(),
                                    "Drafts"    => _cmsPages.Where(p => !p.IsPublished).ToList(),
                                    _           => _cmsPages
                                };
                                @if (filtered.Count == 0)
                                {
                                    <MudText Color="Color.Secondary" Class="pa-4">No pages in this view.</MudText>
                                }
                                else
                                {
                                    <MudTable Items="@filtered" Hover="true" Dense="true" Breakpoint="Breakpoint.Sm">
                                        <HeaderContent>
                                            <MudTh>Title</MudTh>
                                            <MudTh>URL</MudTh>
                                            <MudTh>Date</MudTh>
                                            <MudTh>Status</MudTh>
                                            <MudTh>Actions</MudTh>
                                        </HeaderContent>
                                        <RowTemplate>
                                            <MudTd DataLabel="Title">
                                                <MudText Typo="Typo.body2" Class="fw-bold">@context.Title</MudText>
                                            </MudTd>
                                            <MudTd DataLabel="URL">
                                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                                    <MudText Typo="Typo.caption" Color="Color.Secondary">/@context.Slug</MudText>
                                                    @if (context.IsPublished)
                                                    {
                                                        <MudLink Href="@($"/{context.Slug}")" Target="_blank"
                                                                 Typo="Typo.caption" Color="Color.Primary" Style="font-size:0.7rem;">
                                                            View ↗
                                                        </MudLink>
                                                    }
                                                </MudStack>
                                            </MudTd>
                                            <MudTd DataLabel="Date">
                                                <MudStack Spacing="0">
                                                    <MudText Typo="Typo.body2">@context.PublishedDate.ToString("d MMM yyyy")</MudText>
                                                    @if (context.UpdatedAt.HasValue)
                                                    {
                                                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                                                            Updated @context.UpdatedAt.Value.ToString("d MMM yyyy")
                                                        </MudText>
                                                    }
                                                </MudStack>
                                            </MudTd>
                                            <MudTd DataLabel="Status">
                                                @if (context.IsPublished)
                                                {
                                                    <MudChip T="string" Size="Size.Small" Color="Color.Success" Variant="Variant.Filled">Published</MudChip>
                                                }
                                                else
                                                {
                                                    <MudChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Outlined">Draft</MudChip>
                                                }
                                            </MudTd>
                                            <MudTd DataLabel="Actions">
                                                <MudStack Row="true" Spacing="0">
                                                    <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                                                   Size="Size.Small" Color="Color.Primary"
                                                                   OnClick="@(() => StartEditPage(context))"
                                                                   aria-label="Edit page" />
                                                    <MudIconButton Icon="@(context.IsPublished ? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility)"
                                                                   Size="Size.Small" Color="Color.Secondary"
                                                                   OnClick="@(() => TogglePublishPage(context))"
                                                                   aria-label="@(context.IsPublished ? "Unpublish" : "Publish")" />
                                                    <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                                                   Size="Size.Small" Color="Color.Error"
                                                                   OnClick="@(() => DeletePage(context.Id))"
                                                                   aria-label="Delete page" />
                                                </MudStack>
                                            </MudTd>
                                        </RowTemplate>
                                    </MudTable>
                                }
                            }
                        </MudCardContent>
                    </MudCard>
                </MudItem>
            }
            else
            {
                <!-- ── Pages: editor view (WordPress-style) ── -->
                <MudItem xs="12">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-3" Spacing="1">
                        <MudButton Variant="Variant.Text" Color="Color.Default" Size="Size.Small"
                                   StartIcon="@Icons.Material.Filled.ArrowBack"
                                   OnClick="@CancelEditPage">
                            ← Pages
                        </MudButton>
                        <MudText Typo="Typo.h6">
                            @(_editingPage == null ? "Add New Page" : "Edit Page")
                        </MudText>
                    </MudStack>
                </MudItem>

                <!-- Editor: left content + right sidebar -->
                <MudItem xs="12" md="8">
                    <MudForm @ref="_pageForm" @bind-IsValid="_pageFormValid">
                        <!-- Title -->
                        <MudCard Elevation="2" Class="mb-4">
                            <MudCardContent Class="pb-0">
                                <MudTextField @bind-Value="_pageTitle" Label="Page Title" Required="true"
                                              RequiredError="Title is required"
                                              Variant="Variant.Outlined"
                                              OnBlur="@GeneratePageSlugFromTitle"
                                              Style="font-size:1.4rem;font-weight:600;" />
                                <MudStack Row="true" AlignItems="AlignItems.Center" Class="mt-1 mb-2" Spacing="1">
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">Permalink:</MudText>
                                    <MudTextField @bind-Value="_pageSlug" Required="true"
                                                  RequiredError="Slug is required"
                                                  Variant="Variant.Text" Margin="Margin.Dense"
                                                  Typo="Typo.caption"
                                                  Style="max-width:320px;"
                                                  HelperText="e.g. my-custom-page → /my-custom-page" />
                                </MudStack>
                            </MudCardContent>
                        </MudCard>

                        <!-- Body -->
                        <MudCard Elevation="2" Class="mb-4">
                            <MudCardContent>
                                <MudText Typo="Typo.subtitle2" Class="mb-2">Content</MudText>
                                <RichTextEditor @ref="_pageBodyEditor" Placeholder="Write your page content here…" />
                            </MudCardContent>
                        </MudCard>
                    </MudForm>
                </MudItem>

                <!-- Sidebar -->
                <MudItem xs="12" md="4">

                    <!-- Publish card -->
                    <MudCard Elevation="2" Class="mb-4">
                        <MudCardHeader>
                            <CardHeaderContent>
                                <MudText Typo="Typo.subtitle2">
                                    <MudIcon Icon="@Icons.Material.Filled.Publish" Size="Size.Small" Class="mr-1" />
                                    Publish
                                </MudText>
                            </CardHeaderContent>
                        </MudCardHeader>
                        <MudCardContent>
                            <MudStack Spacing="2">
                                <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                                    <MudText Typo="Typo.body2">Status</MudText>
                                    <MudChip T="string" Size="Size.Small"
                                             Color="@(_pageIsPublished ? Color.Success : Color.Default)"
                                             Variant="@(_pageIsPublished ? Variant.Filled : Variant.Outlined)">
                                        @(_pageIsPublished ? "Published" : "Draft")
                                    </MudChip>
                                </MudStack>
                                <MudSwitch @bind-Value="_pageIsPublished" Label="@(_pageIsPublished ? "Published" : "Save as Draft")"
                                           Color="Color.Success" />
                                <MudTextField @bind-Value="_pagePublishedDateStr" Label="Publish Date"
                                              InputType="InputType.Date" Variant="Variant.Outlined"
                                              Margin="Margin.Dense" />
                            </MudStack>
                        </MudCardContent>
                        <MudCardActions>
                            <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true"
                                       OnClick="@SavePage" Disabled="@_savingPage"
                                       StartIcon="@Icons.Material.Filled.Save">
                                @(_savingPage ? "Saving…" : (_editingPage == null ? (_pageIsPublished ? "Publish" : "Save Draft") : "Update"))
                            </MudButton>
                        </MudCardActions>
                    </MudCard>

                    <!-- Featured Image card -->
                    <MudCard Elevation="2" Class="mb-4">
                        <MudCardHeader>
                            <CardHeaderContent>
                                <MudText Typo="Typo.subtitle2">
                                    <MudIcon Icon="@Icons.Material.Filled.Image" Size="Size.Small" Class="mr-1" />
                                    Featured Image
                                </MudText>
                            </CardHeaderContent>
                        </MudCardHeader>
                        <MudCardContent>
                            @if (!string.IsNullOrWhiteSpace(_pageFeaturedImage))
                            {
                                <img src="@_pageFeaturedImage" alt="Featured image preview"
                                     style="width:100%;max-height:160px;object-fit:cover;border-radius:4px;margin-bottom:8px;" />
                            }
                            <MudTextField @bind-Value="_pageFeaturedImage" Label="Featured Image URL"
                                          Variant="Variant.Outlined"
                                          HelperText="Full URL to the hero image" />
                        </MudCardContent>
                    </MudCard>

                    <!-- SEO card -->
                    <MudExpansionPanel Text="SEO & Social" Icon="@Icons.Material.Filled.TravelExplore"
                                       Class="mb-4">
                        <MudStack Spacing="3" Class="pa-2">
                            <MudTextField @bind-Value="_pageMetaTitle" Label="Meta Title"
                                          Variant="Variant.Outlined"
                                          HelperText="Leave blank to use the page title" />
                            <MudTextField @bind-Value="_pageMetaDescription" Label="Meta Description"
                                          Variant="Variant.Outlined" Lines="2"
                                          HelperText="Shown in search results (150–160 characters)" />
                            <MudTextField @bind-Value="_pageOgImage" Label="OG Image URL"
                                          Variant="Variant.Outlined"
                                          HelperText="Leave blank to use featured image" />
                            <MudTextField @bind-Value="_pageCanonicalUrl" Label="Canonical URL"
                                          Variant="Variant.Outlined"
                                          HelperText="Leave blank to use the current URL" />
                        </MudStack>
                    </MudExpansionPanel>

                </MudItem>
            }

        </MudGrid>
    </MudTabPanel>

    <!-- ── Menus tab ───────────────────────────────────────── -->
    <MudTabPanel Text="Menus" Icon="@Icons.Material.Filled.Menu">
        <MudGrid Class="mt-4">

            <!-- Add / edit form -->
            <MudItem xs="12" md="5">
                <MudCard Elevation="3">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6">
                                <MudIcon Icon="@(_editingMenuItem == null ? Icons.Material.Filled.AddLink : Icons.Material.Filled.Edit)" Class="mr-2" />
                                @(_editingMenuItem == null ? "Add Menu Item" : "Edit Menu Item")
                            </MudText>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent>
                        <MudForm @ref="_menuForm" @bind-IsValid="_menuFormValid">
                            <MudTextField @bind-Value="_menuLabel" Label="Label" Required="true"
                                          RequiredError="Label is required"
                                          Variant="Variant.Outlined" Class="mb-3" />
                            <MudTextField @bind-Value="_menuUrl" Label="URL" Required="true"
                                          RequiredError="URL is required"
                                          Variant="Variant.Outlined" Class="mb-3"
                                          HelperText="Use /path for internal, https:// for external" />
                            <MudSelect @bind-Value="_menuIcon" Label="Icon" Variant="Variant.Outlined" Class="mb-3">
                                <MudSelectItem Value="@("NavigateNext")">Default arrow</MudSelectItem>
                                <MudSelectItem Value="@("Home")">Home</MudSelectItem>
                                <MudSelectItem Value="@("Apps")">Apps/Projects</MudSelectItem>
                                <MudSelectItem Value="@("Code")">Code/Skills</MudSelectItem>
                                <MudSelectItem Value="@("Person")">Person/About</MudSelectItem>
                                <MudSelectItem Value="@("Article")">Article/Blog</MudSelectItem>
                                <MudSelectItem Value="@("Email")">Email/Contact</MudSelectItem>
                                <MudSelectItem Value="@("Pages")">Page</MudSelectItem>
                                <MudSelectItem Value="@("Description")">Document</MudSelectItem>
                                <MudSelectItem Value="@("Link")">External Link</MudSelectItem>
                            </MudSelect>
                            <MudNumericField @bind-Value="_menuSortOrder" Label="Sort Order"
                                             Variant="Variant.Outlined" Class="mb-3" Min="1" />
                            <MudSwitch @bind-Value="_menuIsVisible" Label="Visible in navigation"
                                       Color="Color.Success" Class="mb-2" />
                            <MudSwitch @bind-Value="_menuOpenInNewTab" Label="Open in new tab"
                                       Color="Color.Info" />
                        </MudForm>
                    </MudCardContent>
                    <MudCardActions>
                        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                                   OnClick="@SaveMenuItem" Disabled="@_savingMenuItem"
                                   StartIcon="@Icons.Material.Filled.Save">
                            @(_savingMenuItem ? "Saving..." : (_editingMenuItem == null ? "Add Item" : "Save Changes"))
                        </MudButton>
                        @if (_editingMenuItem != null)
                        {
                            <MudButton Variant="Variant.Text" Color="Color.Default"
                                       OnClick="@CancelEditMenuItem" Class="ml-2">Cancel</MudButton>
                        }
                    </MudCardActions>
                </MudCard>
            </MudItem>

            <!-- Menu item list -->
            <MudItem xs="12" md="7">
                <MudCard Elevation="3">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6">
                                <MudIcon Icon="@Icons.Material.Filled.List" Class="mr-2" />
                                Navigation Menu
                            </MudText>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent>
                        @if (_menuItems == null)
                        {
                            <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
                        }
                        else if (_menuItems.Count == 0)
                        {
                            <MudText Color="Color.Secondary">No menu items yet.</MudText>
                        }
                        else
                        {
                            <MudList T="string" Dense="true">
                                @foreach (var item in _menuItems.OrderBy(m => m.SortOrder))
                                {
                                    <MudListItem>
                                        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                                <MudText Typo="Typo.caption" Color="Color.Secondary" Style="min-width:24px;">@item.SortOrder</MudText>
                                                <MudStack Spacing="0">
                                                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                                        <MudText Typo="Typo.body2" Class="fw-bold">@item.Label</MudText>
                                                        @if (!item.IsVisible)
                                                        {
                                                            <MudChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Outlined">hidden</MudChip>
                                                        }
                                                        @if (item.OpenInNewTab)
                                                        {
                                                            <MudIcon Icon="@Icons.Material.Filled.OpenInNew" Size="Size.Small" Color="Color.Secondary" />
                                                        }
                                                    </MudStack>
                                                    <MudText Typo="Typo.caption" Color="Color.Secondary">@item.Url</MudText>
                                                </MudStack>
                                            </MudStack>
                                            <MudStack Row="true" Spacing="0">
                                                <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                                               Size="Size.Small" Color="Color.Primary"
                                                               OnClick="@(() => StartEditMenuItem(item))"
                                                               aria-label="Edit menu item" />
                                                <MudIconButton Icon="@(item.IsVisible ? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility)"
                                                               Size="Size.Small" Color="Color.Secondary"
                                                               OnClick="@(() => ToggleMenuItemVisibility(item))"
                                                               aria-label="Toggle visibility" />
                                                <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                                               Size="Size.Small" Color="Color.Error"
                                                               OnClick="@(() => DeleteMenuItem(item.Id))"
                                                               aria-label="Delete menu item" />
                                            </MudStack>
                                        </MudStack>
                                    </MudListItem>
                                }
                            </MudList>
                        }
                    </MudCardContent>
                </MudCard>
            </MudItem>

        </MudGrid>
    </MudTabPanel>

    <!-- ── Projects tab ───────────────────────────────────── -->
    <MudTabPanel Text="Projects" Icon="@Icons.Material.Filled.Apps">
        <MudGrid Class="mt-4">

            @if (!_projectShowEditor)
            {
                <!-- ── Projects: list view ── -->
                <MudItem xs="12">
                    <MudCard Elevation="3">
                        <MudCardHeader>
                            <CardHeaderContent>
                                <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                                    <MudText Typo="Typo.h6">
                                        <MudIcon Icon="@Icons.Material.Filled.Apps" Class="mr-2" />
                                        Projects
                                        @if (_projects != null)
                                        {
                                            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="ml-2">(@_projects.Count total)</MudText>
                                        }
                                    </MudText>
                                    <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
                                               StartIcon="@Icons.Material.Filled.Add"
                                               OnClick="@OpenNewProjectEditor">
                                        Add New Project
                                    </MudButton>
                                </MudStack>
                            </CardHeaderContent>
                        </MudCardHeader>
                        <MudCardContent>
                            @if (_projects == null)
                            {
                                <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
                            }
                            else if (_projects.Count == 0)
                            {
                                <MudText Color="Color.Secondary" Class="pa-4">No projects yet. Add one using the button above.</MudText>
                            }
                            else
                            {
                                <MudTable Items="@_projects" Hover="true" Dense="true" Breakpoint="Breakpoint.Sm"
                                          RowsPerPage="10">
                                    <HeaderContent>
                                        <MudTh>Title</MudTh>
                                        <MudTh>Category</MudTh>
                                        <MudTh>GitHub</MudTh>
                                        <MudTh>Featured</MudTh>
                                        <MudTh>Order</MudTh>
                                        <MudTh>Actions</MudTh>
                                    </HeaderContent>
                                    <RowTemplate>
                                        <MudTd DataLabel="Title">
                                            <MudStack Spacing="0">
                                                <MudText Typo="Typo.body2" Class="fw-bold">@context.Title</MudText>
                                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                                    <MudText Typo="Typo.caption" Color="Color.Secondary">/projects/@context.Slug</MudText>
                                                    {
                                                        <MudLink Href="@($"/projects/{context.Slug}")" Target="_blank"
                                                                 Typo="Typo.caption" Color="Color.Primary" Style="font-size:0.7rem;">
                                                            View ↗
                                                        </MudLink>
                                                    }
                                                </MudStack>
                                            </MudStack>
                                        </MudTd>
                                        <MudTd DataLabel="Category">
                                            <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Outlined">@context.Category</MudChip>
                                        </MudTd>
                                        <MudTd DataLabel="GitHub">
                                            @if (!string.IsNullOrWhiteSpace(context.GitHubUrl))
                                            {
                                                <MudLink Href="@context.GitHubUrl" Target="_blank" Color="Color.Default">
                                                    <MudIcon Icon="@Icons.Custom.Brands.GitHub" Size="Size.Small" Class="mr-1" />
                                                    View
                                                </MudLink>
                                            }
                                            else
                                            {
                                                <MudText Typo="Typo.caption" Color="Color.Secondary">—</MudText>
                                            }
                                        </MudTd>
                                        <MudTd DataLabel="Featured">
                                            @if (context.IsFeatured)
                                            {
                                                <MudChip T="string" Size="Size.Small" Color="Color.Warning" Variant="Variant.Filled">Featured</MudChip>
                                            }
                                        </MudTd>
                                        <MudTd DataLabel="Order">@context.SortOrder</MudTd>
                                        <MudTd DataLabel="Actions">
                                            <MudStack Row="true" Spacing="0">
                                                <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                                               Size="Size.Small" Color="Color.Primary"
                                                               OnClick="@(() => StartEditProject(context))"
                                                               aria-label="Edit project" />
                                                <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                                               Size="Size.Small" Color="Color.Error"
                                                               OnClick="@(() => DeleteProject(context.Id))"
                                                               aria-label="Delete project" />
                                            </MudStack>
                                        </MudTd>
                                    </RowTemplate>
                                    <PagerContent>
                                        <MudTablePager PageSizeOptions="new int[] { 5, 10, 25 }" />
                                    </PagerContent>
                                </MudTable>
                            }
                        </MudCardContent>
                    </MudCard>
                </MudItem>
            }
            else
            {
                <!-- ── Projects: editor view ── -->
                <MudItem xs="12">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-3" Spacing="1">
                        <MudButton Variant="Variant.Text" Color="Color.Default" Size="Size.Small"
                                   StartIcon="@Icons.Material.Filled.ArrowBack"
                                   OnClick="@CancelEditProject">
                            ← Projects
                        </MudButton>
                        <MudText Typo="Typo.h6">
                            @(_editingProject == null ? "Add New Project" : "Edit Project")
                        </MudText>
                    </MudStack>
                </MudItem>

                <MudItem xs="12" md="8">
                    <MudForm @ref="_projectForm" @bind-IsValid="_projectFormValid">
                        <!-- Title, Slug & Short Description -->
                        <MudCard Elevation="2" Class="mb-4">
                            <MudCardContent Class="pb-0">
                                <MudTextField @bind-Value="_projectTitle" Label="Project Title" Required="true"
                                              RequiredError="Title is required"
                                              Variant="Variant.Outlined" Class="mb-2"
                                              Typo="Typo.h5"
                                              OnBlur="@GenerateProjectSlugFromTitle"
                                              Style="font-size:1.4rem;font-weight:600;" />
                                <MudStack Row="true" AlignItems="AlignItems.Center" Class="mt-1 mb-3" Spacing="1">
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">Permalink: /projects/</MudText>
                                    <MudTextField @bind-Value="_projectSlug" Required="true"
                                                  RequiredError="Slug is required"
                                                  Variant="Variant.Text" Margin="Margin.Dense"
                                                  Typo="Typo.caption"
                                                  Style="max-width:320px;"
                                                  HelperText="SEO-friendly URL slug, e.g. bookit" />
                                </MudStack>
                                <MudTextField @bind-Value="_projectShortDescription" Label="Short Description" Required="true"
                                              RequiredError="Short description is required"
                                              Variant="Variant.Outlined" Class="mb-3"
                                              HelperText="Used on listing cards — keep it under 100 characters." />
                            </MudCardContent>
                        </MudCard>

                        <!-- Full Description -->
                        <MudCard Elevation="2" Class="mb-4">
                            <MudCardContent>
                                <MudText Typo="Typo.subtitle2" Class="mb-2">Full Description</MudText>
                                <MudTextField @bind-Value="_projectDescription" Label="Description" Required="true"
                                              RequiredError="Description is required"
                                              Variant="Variant.Outlined" Lines="5" />
                            </MudCardContent>
                        </MudCard>

                        <!-- Tech Stack -->
                        <MudCard Elevation="2" Class="mb-4">
                            <MudCardContent>
                                <MudTextField @bind-Value="_projectTechStack" Label="Tech Stack"
                                              Variant="Variant.Outlined"
                                              HelperText="Comma-separated, e.g. Blazor, ASP.NET Core, SQL Server" />
                            </MudCardContent>
                        </MudCard>
                    </MudForm>
                </MudItem>

                <!-- Sidebar -->
                <MudItem xs="12" md="4">

                    <!-- Save card -->
                    <MudCard Elevation="2" Class="mb-4">
                        <MudCardHeader>
                            <CardHeaderContent>
                                <MudText Typo="Typo.subtitle2">
                                    <MudIcon Icon="@Icons.Material.Filled.Save" Size="Size.Small" Class="mr-1" />
                                    Save
                                </MudText>
                            </CardHeaderContent>
                        </MudCardHeader>
                        <MudCardActions>
                            <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true"
                                       OnClick="@SaveProject" Disabled="@_savingProject"
                                       StartIcon="@Icons.Material.Filled.Save">
                                @(_savingProject ? "Saving…" : (_editingProject == null ? "Add Project" : "Save Changes"))
                            </MudButton>
                        </MudCardActions>
                    </MudCard>

                    <!-- Project Settings -->
                    <MudCard Elevation="2" Class="mb-4">
                        <MudCardHeader>
                            <CardHeaderContent>
                                <MudText Typo="Typo.subtitle2">
                                    <MudIcon Icon="@Icons.Material.Filled.Tune" Size="Size.Small" Class="mr-1" />
                                    Project Settings
                                </MudText>
                            </CardHeaderContent>
                        </MudCardHeader>
                        <MudCardContent>
                            <MudTextField @bind-Value="_projectCategory" Label="Category" Required="true"
                                          RequiredError="Category is required"
                                          Variant="Variant.Outlined" Class="mb-3"
                                          HelperText="e.g. Work Project, Healthcare, AI, Security" />
                            <MudNumericField @bind-Value="_projectSortOrder" Label="Sort Order"
                                             Variant="Variant.Outlined" Class="mb-3" Min="1"
                                             HelperText="Lower numbers appear first" />
                            <MudSwitch @bind-Value="_projectIsFeatured" Label="@(_projectIsFeatured ? "Featured on home page" : "Not featured")"
                                       Color="Color.Warning" />
                        </MudCardContent>
                    </MudCard>

                    <!-- GitHub & Live URL card -->
                    <MudCard Elevation="2" Class="mb-4">
                        <MudCardHeader>
                            <CardHeaderContent>
                                <MudText Typo="Typo.subtitle2">
                                    <MudIcon Icon="@Icons.Custom.Brands.GitHub" Size="Size.Small" Class="mr-1" />
                                    Links
                                </MudText>
                            </CardHeaderContent>
                        </MudCardHeader>
                        <MudCardContent>
                            <!-- GitHub URL with validate button -->
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1" Class="mb-3">
                                <MudTextField @bind-Value="_projectGitHubUrl" Label="GitHub Repository URL"
                                              Variant="Variant.Outlined" FullWidth="true"
                                              Placeholder="https://github.com/username/repo"
                                              HelperText="Optional — shown as a GitHub button on project cards" />
                                <MudTooltip Text="Open GitHub URL in new tab to validate">
                                    <MudIconButton Icon="@Icons.Material.Filled.OpenInNew"
                                                   Color="Color.Default" Size="Size.Medium"
                                                   Disabled="@string.IsNullOrWhiteSpace(_projectGitHubUrl)"
                                                   OnClick="@(() => ValidateUrl(_projectGitHubUrl))"
                                                   aria-label="Validate GitHub URL" />
                                </MudTooltip>
                            </MudStack>

                            <!-- Live URL with validate button -->
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1" Class="mb-3">
                                <MudTextField @bind-Value="_projectLiveUrl" Label="Live Demo URL"
                                              Variant="Variant.Outlined" FullWidth="true"
                                              Placeholder="https://example.com"
                                              HelperText="Optional — shown as a Live Demo button on project cards" />
                                <MudTooltip Text="Open Live URL in new tab to validate">
                                    <MudIconButton Icon="@Icons.Material.Filled.OpenInNew"
                                                   Color="Color.Default" Size="Size.Medium"
                                                   Disabled="@string.IsNullOrWhiteSpace(_projectLiveUrl)"
                                                   OnClick="@(() => ValidateUrl(_projectLiveUrl))"
                                                   aria-label="Validate live URL" />
                                </MudTooltip>
                            </MudStack>

                            <!-- Image URL -->
                            <MudTextField @bind-Value="_projectImageUrl" Label="Image URL"
                                          Variant="Variant.Outlined"
                                          Placeholder="/images/project.png"
                                          HelperText="Optional project image" />

                            <!-- Blog Story Slug -->
                            <MudTextField @bind-Value="_projectBlogSlug" Label="Blog Story Slug" Class="mt-3"
                                          Variant="Variant.Outlined"
                                          Placeholder="building-my-project-story"
                                          HelperText="Slug of the blog post that tells this project's story (adds a 'Read Story' button)" />
                        </MudCardContent>
                    </MudCard>

                </MudItem>
            }

        </MudGrid>
    </MudTabPanel>

    <!-- ── Media Library tab ───────────────────────────────── -->
    <MudTabPanel Text="Media" Icon="@Icons.Material.Filled.PermMedia">
        <MudGrid Class="mt-4">
            <MudItem xs="12">
                <MudCard Elevation="2">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6">
                                <MudIcon Icon="@Icons.Material.Filled.PhotoLibrary" Class="mr-2" />
                                Media Library
                            </MudText>
                        </CardHeaderContent>
                        <CardHeaderActions>
                            <InputFile id="mediaLibraryUpload" OnChange="@HandleMediaLibraryUpload"
                                       accept="image/*,video/*" style="display:none;" multiple />
                            <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
                                       StartIcon="@Icons.Material.Filled.Upload"
                                       Disabled="@_uploadingMedia"
                                       OnClick="@(() => JSRuntime.InvokeVoidAsync("triggerInputClick", "mediaLibraryUpload"))">
                                @(_uploadingMedia ? "Uploading…" : "Upload Files")
                            </MudButton>
                        </CardHeaderActions>
                    </MudCardHeader>
                    <MudCardContent>
                        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-3">
                            Upload images and videos to your media library. Files are served from the API server. Supported formats: JPEG, PNG, GIF, WebP, SVG (images); MP4, WebM, OGG, MOV (video). Max size: 100 MB per file.
                        </MudText>
                        @if (_uploadingMedia)
                        {
                            <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-3" />
                        }
                        @if (_mediaFiles.Count == 0)
                        {
                            <MudAlert Severity="Severity.Info" Class="mb-3">
                                No media files yet. Click <strong>Upload Files</strong> to add your first image or video.
                            </MudAlert>
                        }
                        else
                        {
                            <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(150px,1fr));gap:12px;">
                                @foreach (var mf in _mediaFiles)
                                {
                                    <MudCard Elevation="1" Style="overflow:hidden;">
                                        <div style="position:relative;aspect-ratio:1;background:var(--mud-palette-background-grey);">
                                            @if (mf.MediaType == "image")
                                            {
                                                <img src="@mf.Url" alt="@(mf.Alt ?? mf.OriginalName)"
                                                     style="width:100%;height:100%;object-fit:cover;" />
                                            }
                                            else
                                            {
                                                <div style="display:flex;flex-direction:column;align-items:center;justify-content:center;height:100%;">
                                                    <MudIcon Icon="@Icons.Material.Filled.PlayCircle"
                                                             Style="font-size:40px;opacity:0.6;" />
                                                    <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-1">Video</MudText>
                                                </div>
                                            }
                                            <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                                           Size="Size.Small" Color="Color.Error"
                                                           Style="position:absolute;top:2px;right:2px;background:rgba(0,0,0,0.5);"
                                                           OnClick="@(() => DeleteMediaFile(mf.Id))" />
                                        </div>
                                        <MudCardContent Class="pa-2">
                                            <MudText Typo="Typo.caption" Style="word-break:break-all;display:block;max-height:36px;overflow:hidden;"
                                                     title="@mf.OriginalName">
                                                @mf.OriginalName
                                            </MudText>
                                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                                @FormatFileSize(mf.FileSize) · @mf.UploadedAt.ToString("d MMM yyyy")
                                            </MudText>
                                        </MudCardContent>
                                        <MudCardActions Class="pa-1">
                                            <MudTooltip Text="Copy URL to clipboard">
                                                <MudIconButton Icon="@Icons.Material.Filled.ContentCopy" Size="Size.Small"
                                                               OnClick="@(() => CopyMediaUrl(mf.Url))" />
                                            </MudTooltip>
                                            <MudTooltip Text="Open in new tab">
                                                <MudIconButton Icon="@Icons.Material.Filled.OpenInNew" Size="Size.Small"
                                                               Href="@mf.Url" Target="_blank" />
                                            </MudTooltip>
                                        </MudCardActions>
                                    </MudCard>
                                }
                            </div>
                        }
                    </MudCardContent>
                </MudCard>
            </MudItem>
        </MudGrid>
    </MudTabPanel>

    <!-- ── Static Site tab ─────────────────────────────────── -->
    <MudTabPanel Text="Static Site" Icon="@Icons.Material.Filled.Download">
        <MudGrid Class="mt-4">
            <MudItem xs="12" md="8">
                <MudCard Elevation="3">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6">
                                <MudIcon Icon="@Icons.Material.Filled.FolderZip" Class="mr-2" />
                                Generate Static Site
                            </MudText>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent>
                        <MudText Typo="Typo.body1" Class="mb-3">
                            Generate a complete, self-contained static HTML snapshot of your portfolio, dark mode by default,
                            with all blog posts, projects, skills, and CMS pages baked in. The result is a ZIP file ready
                            to deploy to GitHub Pages, Netlify, Azure Static Web Apps, or any static host.
                        </MudText>
                        <MudList T="string" Dense="true" Class="mb-4">
                            <MudListItem Icon="@Icons.Material.Filled.CheckCircle" IconColor="Color.Success">Home, About, Projects, Skills, Contact pages</MudListItem>
                            <MudListItem Icon="@Icons.Material.Filled.CheckCircle" IconColor="Color.Success">Blog listing and individual post pages</MudListItem>
                            <MudListItem Icon="@Icons.Material.Filled.CheckCircle" IconColor="Color.Success">All custom CMS pages</MudListItem>
                            <MudListItem Icon="@Icons.Material.Filled.CheckCircle" IconColor="Color.Success">Dark mode by default with the portfolio brand theme</MudListItem>
                            <MudListItem Icon="@Icons.Material.Filled.CheckCircle" IconColor="Color.Success">Responsive navigation with mobile hamburger menu</MudListItem>
                            <MudListItem Icon="@Icons.Material.Filled.CheckCircle" IconColor="Color.Success">Technology chips on projects and blog posts</MudListItem>
                            <MudListItem Icon="@Icons.Material.Filled.CheckCircle" IconColor="Color.Success">Project images and featured images included</MudListItem>
                        </MudList>
                        @if (_generatingStaticSite)
                        {
                            <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="mb-3" />
                            <MudText Typo="Typo.body2" Color="Color.Secondary">Generating static site, this may take a few seconds…</MudText>
                        }
                        else if (!string.IsNullOrEmpty(_staticSiteMessage))
                        {
                            <MudAlert Severity="@_staticSiteSeverity" Class="mb-3">@_staticSiteMessage</MudAlert>
                        }
                    </MudCardContent>
                    <MudCardActions>
                        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                                   OnClick="@GenerateStaticSite"
                                   Disabled="@_generatingStaticSite"
                                   StartIcon="@Icons.Material.Filled.FolderZip">
                            @(_generatingStaticSite ? "Generating…" : "Generate & Download ZIP")
                        </MudButton>
                    </MudCardActions>
                </MudCard>
            </MudItem>
            <MudItem xs="12" md="4">
                <MudCard Elevation="2">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.subtitle2">
                                <MudIcon Icon="@Icons.Material.Filled.Info" Size="Size.Small" Class="mr-1" />
                                Deployment Tips
                            </MudText>
                        </CardHeaderContent>
                    </MudCardHeader>
