    // ── Media Slot Picker ─────────────────────────────────────
    private bool _showMediaPicker;
    private int  _pickerTargetSlot;
    private string _pickerUrl     = string.Empty;
    private string _pickerCaption = string.Empty;
    private string _pickerType    = "image";
    private bool _pickerUploading;

    private void OpenSlotPicker(int slotIndex)
    {
        _pickerTargetSlot = slotIndex;
        // Pre-fill from existing slot if any
        var existing = slotIndex < _postMediaItems.Count ? _postMediaItems[slotIndex] : null;
        _pickerUrl     = existing?.Url     ?? string.Empty;
        _pickerCaption = existing?.Caption ?? string.Empty;
        _pickerType    = existing?.Type    ?? "image";
        _showMediaPicker = true;
    }

    private void ClosePicker()
    {
        _showMediaPicker = false;
        _pickerUrl = string.Empty;
        _pickerCaption = string.Empty;
        _pickerType = "image";
    }

    private void ConfirmPickerUrl()
    {
        if (string.IsNullOrWhiteSpace(_pickerUrl)) return;
        SetSlot(_pickerTargetSlot, _pickerUrl, _pickerType, _pickerCaption);
        ClosePicker();
    }

    private void PickFromLibrary(Portfolio.Shared.Models.MediaFileDto mf)
    {
        SetSlot(_pickerTargetSlot, mf.Url, mf.MediaType, mf.Alt ?? string.Empty);
        ClosePicker();
    }

    private void SetSlot(int slotIndex, string url, string type, string caption)
    {
        // Expand list to accommodate the slot index
        while (_postMediaItems.Count <= slotIndex)
            _postMediaItems.Add(new BlogMediaItem
            {
                Type     = "image",
                Position = slotIndex == 0 ? "before_article" : "after_article",
                SortOrder = _postMediaItems.Count
            });

        _postMediaItems[slotIndex].Url     = url;
        _postMediaItems[slotIndex].Type    = type;
        _postMediaItems[slotIndex].Caption = string.IsNullOrWhiteSpace(caption) ? null : caption;
        _postMediaItems[slotIndex].Position = slotIndex == 0 ? "before_article" : "after_article";
    }

    private void ClearSlot(int slotIndex)
    {
        if (slotIndex < _postMediaItems.Count)
        {
            _postMediaItems[slotIndex].Url     = string.Empty;
            _postMediaItems[slotIndex].Caption = null;
        }
    }

    private async Task HandleSlotFileUpload(InputFileChangeEventArgs e)
    {
        var token = await GetAdminTokenAsync();
        _pickerUploading = true;
        StateHasChanged();
        try
        {
            // Slot picker uploads only one file at a time
            var file = e.File;
            await using var stream = file.OpenReadStream(maxAllowedSize: 100 * 1024 * 1024);
            var (mf, err) = await ApiService.UploadMediaFileAsync(stream, file.Name, file.ContentType, token ?? string.Empty);
            if (mf is not null)
            {
                _mediaFiles.Insert(0, mf);
                SetSlot(_pickerTargetSlot, mf.Url, mf.MediaType, string.Empty);
                ClosePicker();
                Snackbar.Add($"Uploaded: {file.Name}", Severity.Success);
            }
            else
            {
                Snackbar.Add($"Upload failed: {err}", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Upload error: {ex.Message}", Severity.Error);
        }
        finally
        {
            _pickerUploading = false;
        }
    }

    private async Task HandleMediaLibraryUpload(InputFileChangeEventArgs e)
    {
        var token = await GetAdminTokenAsync();
        _uploadingMedia = true;
        StateHasChanged();
        try
        {
            foreach (var file in e.GetMultipleFiles(20))
            {
                await using var stream = file.OpenReadStream(maxAllowedSize: 100 * 1024 * 1024);
                var (mf, err) = await ApiService.UploadMediaFileAsync(stream, file.Name, file.ContentType, token ?? string.Empty);
                if (mf is not null)
                {
                    _mediaFiles.Insert(0, mf);
                    Snackbar.Add($"Uploaded: {file.Name}", Severity.Success);
                }
                else
                {
                    Snackbar.Add($"Upload failed for {file.Name}: {err}", Severity.Error);
                }
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Upload error: {ex.Message}", Severity.Error);
        }
        finally
        {
            _uploadingMedia = false;
        }
    }

