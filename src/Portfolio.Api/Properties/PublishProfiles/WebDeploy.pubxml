<?xml version="1.0" encoding="utf-8"?>
<!--
  Web Deploy publish profile for Portfolio.Api.

  Sensitive values (MSDeployServiceURL, DeployIisAppPath, UserName, Password) are supplied
  as /p: overrides at publish time — for example from GitHub Actions secrets — and are
  never stored in this file.

  Required GitHub Actions secrets:
    API_MSDEPLOY_URL          - Web Deploy endpoint, e.g. myhost.site4now.net:8172/msdeploy.axd
    API_DEPLOY_IISAPP_PATH    - IIS application path, e.g. mysite.com
    API_MSDEPLOY_USERNAME     - Hosting control panel username
    API_MSDEPLOY_PASSWORD     - Hosting control panel password
-->
<Project ToolsVersion="4.0" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <PropertyGroup>
    <WebPublishMethod>MSDeploy</WebPublishMethod>
    <LastUsedBuildConfiguration>Release</LastUsedBuildConfiguration>
    <LastUsedPlatform>Any CPU</LastUsedPlatform>
    <LaunchSiteAfterPublish>false</LaunchSiteAfterPublish>
    <ExcludeApp_Data>false</ExcludeApp_Data>
    <MSDeployPublishMethod>WMSVC</MSDeployPublishMethod>
    <EnableMSDeployBackup>false</EnableMSDeployBackup>
    <SkipExtraFilesOnServer>true</SkipExtraFilesOnServer>
    <AllowUntrustedCertificate>true</AllowUntrustedCertificate>
    <_SavePWD>false</_SavePWD>
    <!-- Self-contained: ships the .NET runtime so no runtime install is needed on the host. -->
    <SelfContained>true</SelfContained>
    <RuntimeIdentifier>win-x86</RuntimeIdentifier>
    <PublishReadyToRun>false</PublishReadyToRun>
  </PropertyGroup>
</Project>
