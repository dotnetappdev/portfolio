# Copy this file to .env and fill in your values before running docker compose.
# The .env file is excluded from version control (see .gitignore).

# REQUIRED: JWT signing key — must be at least 32 characters long.
JWT_KEY=your-secret-key-minimum-32-characters-long

# Admin account seeded on first run (change before going live).
ADMIN_EMAIL=admin@portfolio.com
ADMIN_PASSWORD=Admin@123456!

# CORS allowed origin for the API (should match the web app's public URL).
ALLOWED_ORIGINS=http://localhost:5072
